using System;
using System.Collections.ObjectModel;
using System.ComponentModel;
using System.Runtime.CompilerServices;
using System.Windows.Input;
using AlparslanOBS.Models;

namespace AlparslanOBS.ViewModels
{
    /// <summary>
    /// Main view model for the application. Exposes student collection and basic commands.
    /// This class is intentionally lightweight and will be expanded with services and
    /// async loading per the project specification.
    /// </summary>
    public class MainViewModel : INotifyPropertyChanged
    {
        private string _searchText = string.Empty;

        /// <summary>
        /// Students shown in the main list.
        /// </summary>
        public ObservableCollection<Student> Students { get; } = new ObservableCollection<Student>();

        /// <summary>
        /// Live search text used for filtering.
        /// </summary>
        public string SearchText
        {
            get => _searchText;
            set
            {
                if (_searchText != value)
                {
                    _searchText = value;
                    OnPropertyChanged();
                    // TODO: trigger live search/filtering
                }
            }
        }

        /// <summary>
        /// Placeholder command for loading data (to be implemented with services).
        /// </summary>
        public ICommand LoadDataCommand { get; }

        public MainViewModel()
        {
            // TODO: inject services via DI in future
            LoadDataCommand = new RelayCommand(_ => LoadSampleData());
        }

        private void LoadSampleData()
        {
            Students.Clear();
            Students.Add(new Student { StudentNumber = "1001", FirstName = "Ali", LastName = "Veli", Class = "10A", ClassNo = 1 });
            Students.Add(new Student { StudentNumber = "1002", FirstName = "Ayse", LastName = "Kara", Class = "10B", ClassNo = 2 });
        }

        public event PropertyChangedEventHandler? PropertyChanged;

        protected void OnPropertyChanged([CallerMemberName] string? name = null)
        {
            PropertyChanged?.Invoke(this, new PropertyChangedEventArgs(name));
        }
    }

    /// <summary>
    /// Minimal RelayCommand implementation for view model commands.
    /// </summary>
    public class RelayCommand : ICommand
    {
        private readonly Action<object?> _execute;
        private readonly Func<object?, bool>? _canExecute;

        public RelayCommand(Action<object?> execute, Func<object?, bool>? canExecute = null)
        {
            _execute = execute ?? throw new ArgumentNullException(nameof(execute));
            _canExecute = canExecute;
        }

        public bool CanExecute(object? parameter) => _canExecute?.Invoke(parameter) ?? true;

        public void Execute(object? parameter) => _execute(parameter);

        public event EventHandler? CanExecuteChanged
        {
            add { CommandManager.RequerySuggested += value; }
            remove { CommandManager.RequerySuggested -= value; }
        }
    }
}
