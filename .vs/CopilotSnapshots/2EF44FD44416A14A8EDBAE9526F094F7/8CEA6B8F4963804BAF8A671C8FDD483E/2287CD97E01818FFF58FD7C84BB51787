using System;
using System.Collections.Generic;
using System.IO;
using System.Text.RegularExpressions;
using Microsoft.Data.Sqlite;
using AlparslanOBS.Models;
using AlparslanOBS.DataAccess;

namespace AlparslanOBS.Services
{
    /// <summary>
    /// Responsible for merging imported student data into the database following the
    /// project's rules: UPSERT by StudentNumber (ON CONFLICT DO UPDATE), transactional,
    /// no automatic deletes, normalization of StudentNumber, and logging.
    /// </summary>
    public class MergeService
    {
        private readonly StudentRepository _repo = new StudentRepository();

        /// <summary>
        /// Merge a collection of imported students into persistent storage.
        /// This method must:
        /// - Normalize StudentNumber
        /// - Use UPSERT (ON CONFLICT DO UPDATE) to avoid REPLACE
        /// - Execute inside a transaction and rollback on error
        /// - Overwrite photo when provided
        /// - Not delete any existing DB rows that are missing from import
        /// </summary>
        public void MergeStudents(IEnumerable<Student> importedStudents)
        {
            if (importedStudents == null) return;

            var dbPath = DatabaseConnection.GetDatabasePath();
            var photosFolder = DatabaseConnection.GetPhotosFolder();
            var logsFolder = DatabaseConnection.GetLogsFolder();
            var logFile = Path.Combine(logsFolder, "app_log.txt");

            using var conn = DatabaseConnection.GetConnection();
            conn.Open();
            using var tx = conn.BeginTransaction();
            try
            {
                foreach (var imported in importedStudents)
                {
                    try
                    {
                        if (string.IsNullOrWhiteSpace(imported.StudentNumber))
                        {
                            File.AppendAllText(logFile, $"[{DateTime.UtcNow:o}] Skipped student with empty StudentNumber.\n");
                            continue;
                        }

                        // Normalize StudentNumber: trim and collapse whitespace
                        imported.StudentNumber = NormalizeStudentNumber(imported.StudentNumber);

                        // Handle photo copying/overwrite if a source path is provided and exists
                        if (!string.IsNullOrWhiteSpace(imported.PhotoPath) && File.Exists(imported.PhotoPath))
                        {
                            try
                            {
                                var ext = Path.GetExtension(imported.PhotoPath);
                                if (string.IsNullOrEmpty(ext)) ext = ".jpg";
                                var fileName = Slugify($"{imported.FirstName}_{imported.LastName}_{imported.StudentNumber}") + ext;
                                var dest = Path.Combine(photosFolder, fileName);
                                File.Copy(imported.PhotoPath, dest, overwrite: true);
                                imported.PhotoPath = dest;
                            }
                            catch (Exception ex)
                            {
                                File.AppendAllText(logFile, $"[{DateTime.UtcNow:o}] Failed to copy photo for {imported.StudentNumber}: {ex.Message}\n");
                                // keep original PhotoPath or set empty
                                imported.PhotoPath = string.Empty;
                            }
                        }

                        // Perform UPSERT via repository participating in transaction
                        _repo.Upsert(imported, conn, tx);
                    }
                    catch (Exception ex)
                    {
                        File.AppendAllText(logFile, $"[{DateTime.UtcNow:o}] Error merging student {imported?.StudentNumber}: {ex.Message}\n");
                        throw; // will be caught by outer try and rollback
                    }
                }

                tx.Commit();
            }
            catch (Exception ex)
            {
                try
                {
                    tx.Rollback();
                }
                catch { }

                File.AppendAllText(logFile, $"[{DateTime.UtcNow:o}] Merge failed, transaction rolled back: {ex.Message}\n");
                throw;
            }
        }

        private static string NormalizeStudentNumber(string input)
        {
            if (string.IsNullOrWhiteSpace(input)) return string.Empty;
            // Trim and collapse whitespace
            var s = Regex.Replace(input.Trim(), "\\s+", " ");
            return s;
        }

        private static string Slugify(string input)
        {
            if (string.IsNullOrWhiteSpace(input)) return string.Empty;
            // Replace Turkish characters and other diacritics with ASCII equivalents
            var map = new Dictionary<char, char>
            {
                ['ç'] = 'c', ['Ç'] = 'C', ['ş'] = 's', ['Ş'] = 'S', ['ğ'] = 'g', ['Ğ'] = 'G',
                ['ü'] = 'u', ['Ü'] = 'U', ['ö'] = 'o', ['Ö'] = 'O', ['ı'] = 'i', ['İ'] = 'I'
            };

            var normalized = new System.Text.StringBuilder();
            foreach (var ch in input)
            {
                if (map.TryGetValue(ch, out var rep)) normalized.Append(rep);
                else normalized.Append(ch);
            }

            var s = normalized.ToString();
            // remove invalid path chars
            foreach (var c in Path.GetInvalidFileNameChars()) s = s.Replace(c, '_');
            // replace spaces with underscore
            s = Regex.Replace(s, "\\s+", "_").ToLowerInvariant();
            return s;
        }
    }
}
