using System;
using System.Collections.Generic;
using System.IO;
using System.Linq;
using System.Text.RegularExpressions;
using AlparslanOBS.Models;
using iText.Kernel.Pdf;
using iText.Kernel.Pdf.Canvas.Parser;
using iText.Kernel.Pdf.Xobject;

namespace AlparslanOBS.Services
{
    /// <summary>
    /// PDF ayrıştırma işlemleri için arayüz. Bağımlılık enjeksiyonu (DI) ve test edilebilirlik için eklendi.
    /// </summary>
    public interface IPdfExtractionService
    {
        IEnumerable<Student> ExtractStudentsFromKunyePdf(string pdfPath);
        IEnumerable<(string StudentNumber, string Class)> ExtractClassList(string pdfPath);
        void CleanupTempFiles();
    }

    /// <summary>
    /// iText7 kullanarak PDF'lerden metin ve embedded fotoğraf ayrıştıran servis.
    /// Anayasa Kuralı: IDisposable yönetimi ile RAM tahliyesi yapılır. 
    /// Çıkarılan resimler sistemin Temp klasörüne atılır ve işlem bitince temizlenir.
    /// </summary>
    public class PdfExtractionService : IPdfExtractionService
    {
        // Temizlik kuralı için işlem sırasında oluşturulan geçici (temp) dosyaların kaydını tutarız
        private readonly List<string> _tempFilesCreated = new List<string>();

        public IEnumerable<Student> ExtractStudentsFromKunyePdf(string pdfPath)
        {
            var results = new List<Student>();

            if (string.IsNullOrWhiteSpace(pdfPath) || !File.Exists(pdfPath))
                return results;

            try
            {
                // Anayasa Kuralı: IDisposable kullanımı. using bloğu ile bellek işlem biter bitmez tahliye edilir.
                using var pdfReader = new PdfReader(pdfPath);
                using var pdfDocument = new PdfDocument(pdfReader);

                for (int pageNum = 1; pageNum <= pdfDocument.GetNumberOfPages(); pageNum++)
                {
                    try
                    {
                        var page = pdfDocument.GetPage(pageNum);
                        var text = ExtractTextFromPage(page);

                        if (string.IsNullOrWhiteSpace(text)) continue;

                        var student = new Student
                        {
                            StudentNumber = FindStudentNumber(text) ?? string.Empty,
                            TcNo = FindTcNo(text) ?? string.Empty,
                            BirthDate = FindBirthDate(text)
                        };

                        var name = FindName(text);
                        if (!string.IsNullOrEmpty(name))
                        {
                            var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                            student.FirstName = parts.Length > 0 ? parts[0] : string.Empty;
                            student.LastName = parts.Length > 1 ? string.Join(' ', parts.Skip(1)) : string.Empty;
                        }

                        // Fotoğraf Çıkarma ve Geçici (Temp) Dosya Kuralı
                        var imageData = ExtractImageFromPage(page);
                        if (imageData != null && imageData.Length > 0)
                        {
                            // Fotoğrafı geçici klasöre kaydet. MergeService onaylarsa kalıcıya kopyalayacak.
                            string tempFileName = Path.Combine(Path.GetTempPath(), $"OBS_Temp_{Guid.NewGuid()}.jpg");
                            File.WriteAllBytes(tempFileName, imageData);

                            student.PhotoPath = tempFileName;
                            _tempFilesCreated.Add(tempFileName); // Çöp toplayıcı için listeye ekle
                        }

                        results.Add(student);
                    }
                    catch
                    {
                        // Hatalı sayfa tüm süreci çökertmemeli, diğer sayfaya geç
                    }
                }
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"PDF Ayrıştırma Hatası: {ex.Message}");
            }

            return results;
        }

        public IEnumerable<(string StudentNumber, string Class)> ExtractClassList(string pdfPath)
        {
            var results = new List<(string, string)>();

            if (string.IsNullOrWhiteSpace(pdfPath) || !File.Exists(pdfPath))
                return results;

            try
            {
                using var pdfReader = new PdfReader(pdfPath);
                using var pdfDocument = new PdfDocument(pdfReader);

                for (int pageNum = 1; pageNum <= pdfDocument.GetNumberOfPages(); pageNum++)
                {
                    try
                    {
                        var page = pdfDocument.GetPage(pageNum);
                        var text = ExtractTextFromPage(page);

                        if (string.IsNullOrWhiteSpace(text)) continue;

                        var classInfo = ExtractClassFromHeader(text);
                        if (string.IsNullOrEmpty(classInfo)) continue;

                        var lines = text.Split('\n', StringSplitOptions.RemoveEmptyEntries);
                        foreach (var line in lines)
                        {
                            var sn = FindStudentNumberFromClassListLine(line);
                            if (!string.IsNullOrEmpty(sn))
                            {
                                results.Add((sn, classInfo));
                            }
                        }
                    }
                    catch
                    {
                        // Sayfayı atla
                    }
                }
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"Sınıf Listesi Ayrıştırma Hatası: {ex.Message}");
            }

            return results;
        }

        /// <summary>
        /// Anayasa Kuralı: İşlem sırasında oluşan geçici dosyalar sistemden temizlenmelidir.
        /// Merge işlemi bittikten sonra ViewModel tarafından çağrılır.
        /// </summary>
        public void CleanupTempFiles()
        {
            foreach (var tempFile in _tempFilesCreated)
            {
                if (File.Exists(tempFile))
                {
                    try { File.Delete(tempFile); } catch { /* Kilitlenmişse yoksay */ }
                }
            }
            _tempFilesCreated.Clear();
        }

        private static string ExtractTextFromPage(PdfPage page)
        {
            try
            {
                return PdfTextExtractor.GetTextFromPage(page) ?? string.Empty;
            }
            catch
            {
                return string.Empty;
            }
        }

        /// <summary>
        /// PDF içerisindeki en büyük gömülü (embedded) resmi bulur ve RAM'i şişirmeden baytlarını çıkarır.
        /// </summary>
        private static byte[]? ExtractImageFromPage(PdfPage page)
        {
            try
            {
                var resources = page.GetResources();
                if (resources == null) return null;

                var xObjectResource = resources.GetResource(new PdfName("XObject"));
                if (!(xObjectResource is PdfDictionary xObjects) || xObjects.IsEmpty()) return null;

                byte[]? largestImage = null;
                int largestSize = 0;

                foreach (var xObjectName in xObjects.KeySet())
                {
                    var obj = xObjects.Get(xObjectName);
                    if (obj is PdfStream stream)
                    {
                        var subtype = stream.GetAsName(new PdfName("Subtype"));
                        if (PdfName.Image.Equals(subtype))
                        {
                            try
                            {
                                // iText7'nin güvenli resim okuma nesnesi
                                var imageXObject = new PdfImageXObject(stream);
                                byte[] imageBytes = imageXObject.GetImageBytes();

                                // En büyük image alınır kuralı
                                if (imageBytes != null && imageBytes.Length > largestSize)
                                {
                                    largestSize = imageBytes.Length;
                                    largestImage = imageBytes;
                                }
                            }
                            catch { continue; }
                        }
                    }
                }
                return largestImage;
            }
            catch
            {
                return null;
            }
        }

        #region Heuristics (Metin Arama Algoritmaları)

        private static string? FindStudentNumber(string text)
        {
            var m = Regex.Match(text, "Okul\\s*No\\s*:\\s*(\\d+)", RegexOptions.IgnoreCase);
            if (m.Success) return m.Groups[1].Value.Trim();
            m = Regex.Match(text, "\\b\\d{3,}\\b");
            return m.Success ? m.Value : null;
        }

        private static string? FindName(string text)
        {
            if (string.IsNullOrWhiteSpace(text)) return null;
            var lines = text.Split('\n', StringSplitOptions.RemoveEmptyEntries);
            string? firstName = null, lastName = null;

            foreach (var line in lines)
            {
                if (line.Contains("Adı:", StringComparison.OrdinalIgnoreCase) &&
                    !line.Contains("Baba", StringComparison.OrdinalIgnoreCase) &&
                    !line.Contains("Anne", StringComparison.OrdinalIgnoreCase))
                {
                    var match = Regex.Match(line, "Adı\\s*:\\s*([A-Za-zİıŞşÇçĞğÜüÖö]+)", RegexOptions.IgnoreCase);
                    if (match.Success) firstName = match.Groups[1].Value.Trim();
                }
                if (line.Contains("Soyadı:", StringComparison.OrdinalIgnoreCase))
                {
                    var match = Regex.Match(line, "Soyadı\\s*:\\s*([A-Za-zİıŞşÇçĞğÜüÖö\\s]+)", RegexOptions.IgnoreCase);
                    if (match.Success) lastName = match.Groups[1].Value.Trim();
                }
                if (!string.IsNullOrEmpty(firstName) && !string.IsNullOrEmpty(lastName))
                    return $"{firstName} {lastName}";
            }
            return !string.IsNullOrEmpty(firstName) ? firstName : null;
        }

        private static string? FindTcNo(string text)
        {
            var m = Regex.Match(text, "T\\.?C\\.?\\s*Kimlik\\s*No\\s*:\\s*(\\d{11})", RegexOptions.IgnoreCase);
            if (m.Success) return m.Groups[1].Value.Trim();
            m = Regex.Match(text, "\\b\\d{11}\\b");
            return m.Success ? m.Value : null;
        }

        private static DateTime? FindBirthDate(string text)
        {
            var m = Regex.Match(text, "Doğum\\s+(?:Yeri\\s*,)?\\s*Tarihi?\\s*:\\s*(?:[A-Za-zİıŞşÇçĞğÜüÖö]+\\s+)?(\\d{1,2}[./-]\\d{1,2}[./-]\\d{2,4})", RegexOptions.IgnoreCase);
            if (m.Success && DateTime.TryParse(m.Groups[1].Value, out var dt)) return dt;
            return null;
        }

        private static string? ExtractClassFromHeader(string text)
        {
            var m = Regex.Match(text, "(\\d+)\\.\\s*Sınıf\\s*(?:/\\s*)?([A-Za-z])?\\s*Şubesi", RegexOptions.IgnoreCase);
            if (m.Success)
            {
                var classNum = m.Groups[1].Value.Trim();
                var section = m.Groups[2].Value.Trim().ToUpperInvariant();
                return section.Length > 0 ? $"{classNum}/{section}" : classNum;
            }
            return null;
        }

        private static string? FindStudentNumberFromClassListLine(string line)
        {
            var m = Regex.Match(line, "^\\s*(\\d+)\\s+");
            if (m.Success) return m.Groups[1].Value.Trim();
            m = Regex.Match(line, "\\b(\\d{3,})\\b");
            return m.Success ? m.Value : null;
        }
        #endregion
    }
}