<UserControl x:Class="AlparslanOBS.Views.Components.ManagementButtonComponent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="350" d:DesignWidth="200">
    
    <UserControl.Resources>
        <Storyboard x:Key="SlideInStoryboard">
            <DoubleAnimation Storyboard.TargetName="MenuPopup"
                           Storyboard.TargetProperty="Opacity"
                           From="0"
                           To="1"
                           Duration="0:0:0.2"/>
            <DoubleAnimation Storyboard.TargetName="MenuPopup"
                           Storyboard.TargetProperty="RenderTransform.(TranslateTransform.X)"
                           From="20"
                           To="0"
                           Duration="0:0:0.2"/>
        </Storyboard>
        
        <Storyboard x:Key="SlideOutStoryboard">
            <DoubleAnimation Storyboard.TargetName="MenuPopup"
                           Storyboard.TargetProperty="Opacity"
                           From="1"
                           To="0"
                           Duration="0:0:0.2"/>
            <DoubleAnimation Storyboard.TargetName="MenuPopup"
                           Storyboard.TargetProperty="RenderTransform.(TranslateTransform.X)"
                           From="0"
                           To="20"
                           Duration="0:0:0.2"/>
        </Storyboard>
    </UserControl.Resources>

    <Grid>
        <!-- Main Menu Button -->
        <Button x:Name="SettingsButton"
                Width="56"
                Height="56"
                Background="#2563eb"
                BorderThickness="0"
                Cursor="Hand"
                Click="SettingsButton_Click"
                ToolTip="Menu">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="28"
                            Padding="0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" 
                                            ShadowDepth="4" 
                                            Opacity="0.3"
                                            Color="#000000"/>
                        </Border.Effect>
                        <TextBlock Text="⚙️" 
                                   FontSize="24" 
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="#2563eb"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#1d4ed8"/>
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="1.08" ScaleY="1.08" CenterX="28" CenterY="28"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.95" ScaleY="0.95" CenterX="28" CenterY="28"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>

        <!-- Popup Menu -->
        <Border x:Name="MenuPopup"
                Background="#ffffff"
                BorderBrush="#e2e8f0"
                BorderThickness="1"
                CornerRadius="12"
                Padding="12"
                Width="220"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,-5,70"
                Visibility="Collapsed"
                Opacity="0"
                RenderTransformOrigin="1,0">
            <Border.RenderTransform>
                <TranslateTransform X="0" Y="0"/>
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" 
                                ShadowDepth="2" 
                                Opacity="0.1"
                                Color="#000000"/>
            </Border.Effect>

            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="400">
                <StackPanel>
                    <!-- VERİ YÜKLEME SECTION -->
                    <TextBlock Text="VERİ AKTARIMI" 
                             FontSize="10" 
                             FontWeight="Bold" 
                             Foreground="#94a3b8"
                             Margin="0,0,0,10"/>

                    <Button Content="📄 Künye PDF Yükle"
                            Height="36"
                            Background="Transparent"
                            Foreground="#1e293b"
                            BorderThickness="0"
                            HorizontalContentAlignment="Left"
                            Padding="12,8"
                            Cursor="Hand"
                            FontSize="12"
                            Margin="0,0,0,6"
                            Click="LoadPdf_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#f8fafc"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="📋 Sınıf Listesi PDF Yükle"
                            Height="36"
                            Background="Transparent"
                            Foreground="#1e293b"
                            BorderThickness="0"
                            HorizontalContentAlignment="Left"
                            Padding="12,8"
                            Cursor="Hand"
                            FontSize="12"
                            Margin="0,0,0,6"
                            Click="LoadClassPdf_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#f8fafc"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="📸 Fotoğraf Listesi PDF Yükle"
                            Height="36"
                            Background="Transparent"
                            Foreground="#1e293b"
                            BorderThickness="0"
                            HorizontalContentAlignment="Left"
                            Padding="12,8"
                            Cursor="Hand"
                            FontSize="12"
                            Margin="0,0,0,6"
                            Click="LoadPhotoPdf_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#f8fafc"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Separator -->
                    <Separator Margin="0,8" Background="#e2e8f0" Height="1"/>

                    <!-- SYSTEM SECTION -->
                    <TextBlock Text="GÜVENLİK VE BAKIM" 
                             FontSize="10" 
                             FontWeight="Bold" 
                             Foreground="#94a3b8"
                             Margin="0,8,0,10"/>

                    <Button Content="🔄 Sistemi Sıfırla"
                            Height="36"
                            Background="Transparent"
                            Foreground="#ef4444"
                            BorderThickness="0"
                            HorizontalContentAlignment="Left"
                            Padding="12,8"
                            Cursor="Hand"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Margin="0,0,0,6"
                            Click="ResetSystem_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#fef2f2"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
