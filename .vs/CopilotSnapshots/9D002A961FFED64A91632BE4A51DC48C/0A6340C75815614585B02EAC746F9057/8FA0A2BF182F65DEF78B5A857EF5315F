<UserControl x:Class="AlparslanOBS.Views.Components.StudentCardComponent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="140" d:DesignWidth="400">
    
    <UserControl.Resources>
        <Style x:Key="KunyeButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#ef4444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#dc2626"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#991b1b"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    
    <Border Background="#ffffff" 
            BorderBrush="#e2e8f0" 
            BorderThickness="1" 
            CornerRadius="8" 
            Padding="12"
            Cursor="Hand"
            MouseEnter="Card_MouseEnter"
            MouseLeave="Card_MouseLeave">
        <Border.Effect>
            <DropShadowEffect BlurRadius="6" 
                            ShadowDepth="1" 
                            Opacity="0.08"
                            Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Profile Image -->
            <Border Grid.Column="0" 
                    Background="#edf2f7" 
                    CornerRadius="6"
                    Margin="0,0,12,0">
                <Image Source="{Binding PhotoPath}"
                       Stretch="UniformToFill"
                       ContextMenuOpening="Photo_ContextMenuOpening">
                    <Image.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="PNG olarak kaydet" 
                                     Click="ExportToPng_Click"/>
                        </ContextMenu>
                    </Image.ContextMenu>
                </Image>
            </Border>

            <!-- Center: Student Info -->
            <StackPanel Grid.Column="1" VerticalAlignment="Top" Gap="4">
                <!-- Name + Star -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding FullName}" 
                               FontSize="14" 
                               FontWeight="Bold" 
                               Foreground="#1e293b"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1"
                            Content="☆" 
                            Width="24" 
                            Height="24" 
                            Background="Transparent"
                            BorderThickness="0"
                            FontSize="16"
                            Cursor="Hand"
                            Click="FavoriteButton_Click"
                            Margin="8,0,0,0"
                            Padding="0"
                            Foreground="#cbd5e0"
                            ToolTip="Favorilere Ekle">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="RenderTransform">
                                            <Setter.Value>
                                                <ScaleTransform ScaleX="1.2" ScaleY="1.2" CenterX="12" CenterY="12"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <!-- Info Row: Class, Number, ID -->
                <StackPanel Orientation="Horizontal" Gap="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Sınıf:" 
                                   FontSize="11" 
                                   Foreground="#64748b"
                                   FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding ClassName}" 
                                   FontSize="11" 
                                   Foreground="#1e293b"
                                   Margin="4,0,0,0"
                                   FontWeight="Medium"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="No:" 
                                   FontSize="11" 
                                   Foreground="#64748b"
                                   FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding StudentNumber}" 
                                   FontSize="11" 
                                   Foreground="#1e293b"
                                   Margin="4,0,0,0"
                                   FontWeight="Medium"/>
                    </Grid>
                </StackPanel>

                <!-- Info Row: ID Number, Birth Date -->
                <StackPanel Orientation="Horizontal" Gap="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="TC No:" 
                                   FontSize="11" 
                                   Foreground="#64748b"
                                   FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding IdentityNumber}" 
                                   FontSize="11" 
                                   Foreground="#1e293b"
                                   Margin="4,0,0,0"
                                   FontWeight="Medium"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="D.Tarihi:" 
                                   FontSize="11" 
                                   Foreground="#64748b"
                                   FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding BirthDate, StringFormat=dd/MM/yyyy}" 
                                   FontSize="11" 
                                   Foreground="#1e293b"
                                   Margin="4,0,0,0"
                                   FontWeight="Medium"/>
                    </Grid>
                </StackPanel>
            </StackPanel>

            <!-- Right: Künye Button -->
            <Button Grid.Column="2"
                    Content="Künye" 
                    Style="{StaticResource KunyeButtonStyle}"
                    Click="KunyeButton_Click"
                    Margin="12,0,0,0"
                    VerticalAlignment="Bottom"/>
        </Grid>
    </Border>
</UserControl>
