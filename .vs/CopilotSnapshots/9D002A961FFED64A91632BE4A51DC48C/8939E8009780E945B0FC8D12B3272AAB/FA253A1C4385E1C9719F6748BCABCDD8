<UserControl x:Class="AlparslanOBS.Views.Components.HeaderComponent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="90" d:DesignWidth="450">
    
    <Grid Background="#ffffff" MinHeight="90">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Bar: Title, Favorites & Settings -->
        <Border Grid.Row="0"
                Background="#ffffff"
                BorderBrush="#e2e8f0"
                BorderThickness="0,0,0,1"
                Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo and Title -->
                <StackPanel Grid.Column="0"
                           Orientation="Horizontal"
                           VerticalAlignment="Center"
                           Margin="0,0,0,0">
                    <Image Source="favicon.ico" 
                           Width="40" 
                           Height="40"
                           Stretch="UniformToFill"
                           Margin="0,0,12,0"/>
                    <TextBlock Text="Alparslan Ortaokulu"
                              FontSize="16"
                              FontWeight="SemiBold"
                              Foreground="#1e293b"
                              VerticalAlignment="Center"
                              FontFamily="Segoe UI"/>
                </StackPanel>

                <!-- Favorites & Settings Buttons -->
                <StackPanel Grid.Column="2"
                           Orientation="Horizontal"
                           VerticalAlignment="Center"
                           Margin="0,0,0,0">
                    <Button Content="☆" 
                           Width="32" 
                           Height="32" 
                           Background="Transparent"
                           Foreground="#cbd5e0"
                           BorderThickness="0"
                           FontSize="18"
                           Cursor="Hand"
                           Padding="0"
                           Margin="0,0,10,0"
                           ToolTip="Favorileri Aç/Kapat">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="RenderTransform">
                                            <Setter.Value>
                                                <ScaleTransform ScaleX="1.1" ScaleY="1.1" CenterX="16" CenterY="16"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="⚙️" 
                           Width="32" 
                           Height="32" 
                           Background="Transparent"
                           BorderThickness="0"
                           FontSize="18"
                           Cursor="Hand"
                           Padding="0"
                           ToolTip="Ayarlar">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="RenderTransform">
                                            <Setter.Value>
                                                <ScaleTransform ScaleX="1.1" ScaleY="1.1" CenterX="16" CenterY="16"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
