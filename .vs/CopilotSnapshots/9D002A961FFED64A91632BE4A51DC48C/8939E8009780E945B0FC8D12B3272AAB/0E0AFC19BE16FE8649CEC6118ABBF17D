<Window x:Class="AlparslanOBS.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AlparslanOBS.Views"
        xmlns:components="clr-namespace:AlparslanOBS.Views.Components"
        xmlns:helpers="clr-namespace:AlparslanOBS.Helpers"
        xmlns:converters="clr-namespace:AlparslanOBS.Converters"
        mc:Ignorable="d"
        Title="Öğrenci Bilgi Sistemi" 
        Height="750" 
        Width="450"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="False"
        Background="#f1f5f9"
        Topmost="True"
        WindowStartupLocation="CenterScreen" 
        PreviewMouseDown="Window_PreviewMouseDown">
    
    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        
        <!-- SearchBox Style -->
        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,10,12,10"/>
            <Setter Property="BorderBrush" Value="#e2e8f0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#ffffff"/>
            <Setter Property="Foreground" Value="#1e293b"/>
            <Setter Property="CaretBrush" Value="#2563eb"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="Background" Value="#ffffff"/>
                    <Setter Property="BorderBrush" Value="#2563eb"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ComboBox Style -->
        <Style x:Key="ClassComboBoxStyle" TargetType="ComboBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,10,12,10"/>
            <Setter Property="BorderBrush" Value="#e2e8f0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#f8fafc"/>
            <Setter Property="Foreground" Value="#1e293b"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
    </Window.Resources>

    <Grid MouseLeftButtonDown="Window_MouseLeftButtonDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER COMPONENT -->
        <components:HeaderComponent Grid.Row="0"/>

        <!-- SEARCH BAR -->
        <Border Grid.Row="1" 
                Background="#ffffff" 
                BorderBrush="#e2e8f0" 
                BorderThickness="0,0,0,1"
                Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" 
                           Text="🔍" 
                           FontSize="14" 
                           Foreground="#64748b" 
                           VerticalAlignment="Center"
                           Opacity="0.6"/>
                
                <TextBox Grid.Column="1"
                         x:Name="SearchBox"
                         Style="{StaticResource SearchBoxStyle}"
                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         helpers:TextBoxPlaceholderHelper.Placeholder="Öğrenci Ara (Ad, No)..."
                         Margin="8,0,0,0"/>
            </Grid>
        </Border>

        <!-- CLASS FILTER -->
        <Border Grid.Row="2" 
                Background="#ffffff" 
                BorderBrush="#e2e8f0" 
                BorderThickness="0,0,0,1"
                Padding="15,10">
            <ComboBox x:Name="ClassComboBox"
                      Style="{StaticResource ClassComboBoxStyle}"
                      SelectedItem="{Binding SelectedClass, UpdateSourceTrigger=PropertyChanged}"
                      ItemsSource="{Binding AvailableClasses}">
                <ComboBoxItem>Sınıf Seçiniz...</ComboBoxItem>
            </ComboBox>
        </Border>

        <!-- ACTION BUTTONS -->
        <Border Grid.Row="3" 
                Background="#ffffff" 
                BorderBrush="#e2e8f0" 
                BorderThickness="0,1,0,1"
                Padding="15,10"
                Visibility="{Binding HasClassSelected, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <Button Content="Sınıf Listesi" 
                        Background="#2563eb" 
                        Foreground="White"
                        Padding="12,8"
                        FontSize="11"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="0,0,10,0"/>
                <Button Content="Fotoğraf Listesi" 
                        Background="#2563eb" 
                        Foreground="White"
                        Padding="12,8"
                        FontSize="11"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="0,0,10,0"/>
                <Button Content="Excel Aktar" 
                        Background="#10b981" 
                        Foreground="White"
                        Padding="12,8"
                        FontSize="11"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- STUDENT CARDS AREA -->
        <ScrollViewer Grid.Row="4" 
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="#f1f5f9"
                      Padding="15,15,15,20">
            <ItemsControl ItemsSource="{Binding FilteredStudents}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,15">
                            <components:StudentCardComponent 
                                DataContext="{Binding}"
                                FavoriteToggled="StudentCard_FavoriteToggled"
                                KunyeOpened="StudentCard_KunyeOpened"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- FAVORITES BUTTON -->
        <Button Grid.Row="4"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Width="56"
                Height="56"
                Margin="20,0,0,20"
                Background="Transparent"
                BorderThickness="0"
                Cursor="Hand"
                Command="{Binding ToggleFavoritesPanelCommand}"
                Panel.ZIndex="10"
                ToolTip="Favoriler">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="#2563eb"
                            CornerRadius="28"
                            Padding="0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" 
                                            ShadowDepth="4" 
                                            Opacity="0.3"
                                            Color="#000000"/>
                        </Border.Effect>
                        <TextBlock Text="⭐" 
                                   FontSize="28" 
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"
                                   Foreground="White"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
            <Button.Style>
                <Style TargetType="Button">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="1.08" ScaleY="1.08" CenterX="28" CenterY="28"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.95" ScaleY="0.95" CenterX="28" CenterY="28"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>

        <!-- MANAGEMENT BUTTON -->
        <components:ManagementButtonComponent 
            Grid.Row="4"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="0,0,20,20"
            Panel.ZIndex="10"/>
    </Grid>
</Window>
