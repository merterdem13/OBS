<UserControl x:Class="AlparslanOBS.Views.Components.StudentCardComponent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="120" d:DesignWidth="380">
    
    <UserControl.Resources>
        <Style x:Key="KunyeButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#ef5350"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#f44336"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#e53935"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    
    <Border Background="#1c2127" 
            BorderBrush="#283039" 
            BorderThickness="1" 
            CornerRadius="6" 
            Padding="10"
            Cursor="Hand"
            MouseEnter="Card_MouseEnter"
            MouseLeave="Card_MouseLeave">
        <Border.Effect>
            <DropShadowEffect BlurRadius="6" 
                            ShadowDepth="1" 
                            Opacity="0.2"
                            Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Profile Image (Çerçevesiz) -->
            <Image Grid.Column="0" 
                   Source="{Binding PhotoPath}"
                   Width="70" 
                   Height="70" 
                   Stretch="UniformToFill"
                   Margin="0,0,10,0"
                   ContextMenuOpening="Photo_ContextMenuOpening">
                <Image.Clip>
                    <RectangleGeometry Rect="0,0,70,70" RadiusX="4" RadiusY="4"/>
                </Image.Clip>
                <Image.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="PNG olarak kaydet" 
                                 Click="ExportToPng_Click"/>
                    </ContextMenu>
                </Image.ContextMenu>
            </Image>

            <!-- Center: Student Info -->
            <Grid Grid.Column="1" VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Name -->
                <TextBlock Grid.Row="0"
                           Text="{Binding FullName}" 
                           FontSize="13" 
                           FontWeight="SemiBold" 
                           Foreground="#ffffff"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,0,0,3"/>

                <!-- NO + SINIF -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,2">
                    <TextBlock Text="NO: " 
                               FontSize="10" 
                               Foreground="#7a8a96" 
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding StudentNumber}" 
                               FontSize="10" 
                               Foreground="#cccccc"
                               Margin="0,0,12,0"/>
                    <TextBlock Text="SINIF: " 
                               FontSize="10" 
                               Foreground="#7a8a96" 
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Class}" 
                               FontSize="10" 
                               Foreground="#137fec"
                               FontWeight="Bold"/>
                </StackPanel>

                <!-- TC -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,2">
                    <TextBlock Text="TC: " 
                               FontSize="10" 
                               Foreground="#7a8a96" 
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TcNo}" 
                               FontSize="10" 
                               Foreground="#cccccc"/>
                </StackPanel>

                <!-- Doğum Tarihi + Veli No -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,2">
                    <TextBlock Text="D.T: " 
                               FontSize="10" 
                               Foreground="#7a8a96" 
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding BirthDateString}" 
                               FontSize="10" 
                               Foreground="#cccccc"
                               Margin="0,0,12,0"/>
                    <TextBlock Text="Veli: " 
                               FontSize="10" 
                               Foreground="#7a8a96" 
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding GuardianPhone}" 
                               FontSize="10" 
                               Foreground="#cccccc"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="80"/>
                </StackPanel>

                <!-- Künye Button -->
                <Button Grid.Row="4"
                        Content="📋 Künye" 
                        Style="{StaticResource KunyeButtonStyle}"
                        HorizontalAlignment="Right"
                        Padding="6,2"
                        Click="KunyeButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="3"
                                    Padding="{TemplateBinding Padding}">
                                <TextBlock Text="{TemplateBinding Content}"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontSize="{TemplateBinding FontSize}"
                                           FontWeight="{TemplateBinding FontWeight}"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Right: Star Button -->
            <Button Grid.Column="2"
                    Content="☆" 
                    Width="24" 
                    Height="24" 
                    Background="Transparent"
                    BorderThickness="0"
                    FontSize="14"
                    Cursor="Hand"
                    Click="FavoriteButton_Click"
                    Margin="8,0,0,0"
                    VerticalAlignment="Top"
                    ToolTip="{Binding FavoriteTooltip}">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Foreground" Value="#7a8a96"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                <Setter Property="Content" Value="★"/>
                                <Setter Property="Foreground" Value="#ffc107"/>
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#ffc107"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Border>
</UserControl>
