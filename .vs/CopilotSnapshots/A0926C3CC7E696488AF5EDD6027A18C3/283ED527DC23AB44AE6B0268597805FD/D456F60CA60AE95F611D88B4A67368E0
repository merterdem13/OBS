using System;
using System.Windows;
using System.Windows.Controls;
using Microsoft.Win32;
using AlparslanOBS.Helpers;
using AlparslanOBS.Models;

namespace AlparslanOBS.Views.Components
{
    /// <summary>
    /// Student Card Component - Modüler Öğrenci Kartı Bileşeni
    /// İSTEM METNİ GEREĞİ: Öğrenci kartı ayrı bir component olacak.
    /// </summary>
    public partial class StudentCardComponent : UserControl
    {
        public StudentCardComponent()
        {
            InitializeComponent();
        }

        /// <summary>
        /// Fotoğraf üzerine sağ tık → PNG export
        /// </summary>
        private void Photo_ContextMenuOpening(object sender, ContextMenuEventArgs e)
        {
            // Context menu zaten XAML'de tanımlı
        }

        /// <summary>
        /// PNG olarak kaydet menü öğesi tıklama
        /// İSTEM METNİ GEREĞİ: Sağ tık → PNG export (Ad_Soyad_Numara.png)
        /// </summary>
        private void ExportToPng_Click(object sender, RoutedEventArgs e)
        {
            try
            {
                var student = DataContext as dynamic;
                if (student == null) return;

                // Kaydetme dosya dialogu
                var saveDialog = new SaveFileDialog
                {
                    Filter = "PNG Image|*.png",
                    FileName = SlugifyHelper.CreatePhotoFileName(
                        student.FirstName?.ToString() ?? "",
                        student.LastName?.ToString() ?? "",
                        student.StudentNumber?.ToString() ?? ""
                    ).Replace(".jpg", ".png")
                };

                if (saveDialog.ShowDialog() == true)
                {
                    var sourcePath = student.PhotoPath?.ToString();
                    if (!string.IsNullOrWhiteSpace(sourcePath))
                    {
                        PhotoHelper.ExportPhotoAsPng(sourcePath, saveDialog.FileName);
                        MessageBox.Show("Fotoğraf başarıyla kaydedildi!", "Başarılı", 
                            MessageBoxButton.OK, MessageBoxImage.Information);
                    }
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Fotoğraf kaydedilemedi: {ex.Message}", "Hata", 
                    MessageBoxButton.OK, MessageBoxImage.Error);
            }
        }

        /// <summary>
        /// Favori butonu tıklama
        /// </summary>
        private void FavoriteButton_Click(object sender, RoutedEventArgs e)
        {
            // Event'i parent'a ilet (ViewModel tarafından handle edilecek)
            RaiseFavoriteToggleEvent();
        }

        /// <summary>
        /// Künye butonu tıklama
        /// </summary>
        private void KunyeButton_Click(object sender, RoutedEventArgs e)
        {
            // Event'i parent'a ilet (ViewModel tarafından handle edilecek)
            RaiseKunyeOpenEvent();
        }

        /// <summary>
        /// Favori toggle event'ini tetikler
        /// </summary>
        private void RaiseFavoriteToggleEvent()
        {
            var args = new RoutedEventArgs(FavoriteToggledEvent, this);
            RaiseEvent(args);
        }

        /// <summary>
        /// Künye açma event'ini tetikler
        /// </summary>
        private void RaiseKunyeOpenEvent()
        {
            var args = new RoutedEventArgs(KunyeOpenedEvent, this);
            RaiseEvent(args);
        }

        // Custom Routed Events
        public static readonly RoutedEvent FavoriteToggledEvent =
            EventManager.RegisterRoutedEvent(
                "FavoriteToggled",
                RoutingStrategy.Bubble,
                typeof(RoutedEventHandler),
                typeof(StudentCardComponent));

        public static readonly RoutedEvent KunyeOpenedEvent =
            EventManager.RegisterRoutedEvent(
                "KunyeOpened",
                RoutingStrategy.Bubble,
                typeof(RoutedEventHandler),
                typeof(StudentCardComponent));

        public event RoutedEventHandler FavoriteToggled
        {
            add { AddHandler(FavoriteToggledEvent, value); }
            remove { RemoveHandler(FavoriteToggledEvent, value); }
        }

        public event RoutedEventHandler KunyeOpened
        {
            add { AddHandler(KunyeOpenedEvent, value); }
            remove { RemoveHandler(KunyeOpenedEvent, value); }
        }
    }
}
