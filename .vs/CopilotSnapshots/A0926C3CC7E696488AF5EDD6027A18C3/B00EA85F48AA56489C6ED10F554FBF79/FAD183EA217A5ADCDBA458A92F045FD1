<Window x:Class="AlparslanOBS.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AlparslanOBS.Views"
        xmlns:components="clr-namespace:AlparslanOBS.Views.Components"
        xmlns:helpers="clr-namespace:AlparslanOBS.Helpers"
        xmlns:converters="clr-namespace:AlparslanOBS.Converters"
        mc:Ignorable="d"
        Title="Öğrenci Bilgi Sistemi" 
        Height="750" 
        Width="400"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="False"
        Background="#101922"
        Topmost="True"
        WindowStartupLocation="CenterScreen" 
        PreviewMouseDown="Window_PreviewMouseDown">
    
    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        
        <!-- SearchBox Style -->
        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,10,12,10"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#283039"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="CaretBrush" Value="#137fec"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="Background" Value="#2f3a42"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ComboBox Style -->
        <Style x:Key="ClassComboBoxStyle" TargetType="ComboBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,10,12,10"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#283039"/>
            <Setter Property="Foreground" Value="#ffffff"/>
        </Style>
    </Window.Resources>

    <Grid MouseLeftButtonDown="Window_MouseLeftButtonDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>  <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Search Bar + Class Filter -->
            <RowDefinition Height="*"/>    <!-- Student Cards -->
        </Grid.RowDefinitions>

        <!-- HEADER COMPONENT -->
        <components:HeaderComponent Grid.Row="0"/>

        <!-- SEARCH & FILTER BAR -->
        <Border Grid.Row="1" 
                Background="#1c2127" 
                BorderBrush="#283039" 
                BorderThickness="0,1,0,1"
                Padding="16,12">
            <StackPanel>
                <!-- Search Box -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" 
                               Text="🔍" 
                               FontSize="16" 
                               Foreground="#999999" 
                               Margin="0,0,8,0" 
                               VerticalAlignment="Center"/>
                    
                    <TextBox Grid.Column="1"
                             x:Name="SearchBox"
                             Style="{StaticResource SearchBoxStyle}"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             helpers:TextBoxPlaceholderHelper.Placeholder="Öğrenci Ara (Ad, Soyad, No)..."/>
                </Grid>

                <!-- Class Filter -->
                <ComboBox x:Name="ClassComboBox"
                          Style="{StaticResource ClassComboBoxStyle}"
                          SelectedItem="{Binding SelectedClass, UpdateSourceTrigger=PropertyChanged}"
                          ItemsSource="{Binding AvailableClasses}">
                    <ComboBoxItem>Sınıf Seç</ComboBoxItem>
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- STUDENT CARDS AREA -->
        <ScrollViewer Grid.Row="2" 
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="#101922"
                      Padding="6,4,6,80">
            <ItemsControl ItemsSource="{Binding FilteredStudents}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,4">
                            <components:StudentCardComponent 
                                DataContext="{Binding}"
                                FavoriteToggled="StudentCard_FavoriteToggled"
                                KunyeOpened="StudentCard_KunyeOpened"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- FAVORITES BUTTON (Bottom Left) -->
        <Button Grid.Row="2"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Width="56"
                Height="56"
                Margin="20,0,0,20"
                Background="#137fec"
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"
                Command="{Binding ToggleFavoritesPanelCommand}"
                ToolTip="Favoriler">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="28"
                            Padding="0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" 
                                            ShadowDepth="4" 
                                            Opacity="0.4"
                                            Color="#000000"/>
                        </Border.Effect>
                        <TextBlock Text="⭐" 
                                   FontSize="28" 
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="#137fec"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#1e88f5"/>
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="1.08" ScaleY="1.08" CenterX="28" CenterY="28"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.95" ScaleY="0.95" CenterX="28" CenterY="28"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>

        <!-- MANAGEMENT BUTTON (Bottom Right) -->
        <components:ManagementButtonComponent 
            Grid.Row="2"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="0,0,20,20"/>
    </Grid>
</Window>
