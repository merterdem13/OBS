<UserControl x:Class="AlparslanOBS.Views.Components.StudentCardComponent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="380">
    
    <UserControl.Resources>
        <Style x:Key="KunyeButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#ef5350"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="5,1"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#f44336"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#e53935"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    
    <Border Background="#1c2127" 
            BorderBrush="#283039" 
            BorderThickness="1" 
            CornerRadius="4" 
            Padding="6,5"
            Cursor="Hand"
            MouseEnter="Card_MouseEnter"
            MouseLeave="Card_MouseLeave">
        <Border.Effect>
            <DropShadowEffect BlurRadius="6" 
                            ShadowDepth="1" 
                            Opacity="0.2"
                            Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Profile Image (Çerçevesiz) -->
            <Image Grid.Column="0" 
                   Source="{Binding PhotoPath}"
                   Width="60" 
                   Height="60" 
                   Stretch="UniformToFill"
                   Margin="0,0,8,0"
                   ContextMenuOpening="Photo_ContextMenuOpening">
                <Image.Clip>
                    <RectangleGeometry Rect="0,0,60,60" RadiusX="3" RadiusY="3"/>
                </Image.Clip>
                <Image.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="PNG olarak kaydet" 
                                 Click="ExportToPng_Click"/>
                    </ContextMenu>
                </Image.ContextMenu>
            </Image>

            <!-- Center: Student Info -->
            <Grid Grid.Column="1" VerticalAlignment="Top">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Name -->
                <TextBlock Grid.Row="0"
                           Text="{Binding FullName}" 
                           FontSize="12" 
                           FontWeight="SemiBold" 
                           Foreground="#ffffff"
                           TextTrimming="CharacterEllipsis"
                           LineHeight="14"
                           Margin="0,0,0,1"/>

                <!-- NO + SINIF -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,1">
                    <TextBlock Text="NO: " 
                               FontSize="9" 
                               Foreground="#7a8a96" 
                               FontWeight="SemiBold"
                               LineHeight="11"/>
                    <TextBlock Text="{Binding StudentNumber}" 
                               FontSize="9" 
                               Foreground="#cccccc"
                               Margin="0,0,8,0"
                               LineHeight="11"/>
                    <TextBlock Text="SINIF: " 
                               FontSize="9" 
                               Foreground="#7a8a96" 
                               FontWeight="SemiBold"
                               LineHeight="11"/>
                    <TextBlock Text="{Binding Class}" 
                               FontSize="9" 
                               Foreground="#137fec"
                               FontWeight="Bold"
                               LineHeight="11"/>
                </StackPanel>

                <!-- TC -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,1">
                    <TextBlock Text="TC: " 
                               FontSize="9" 
                               Foreground="#7a8a96" 
                               FontWeight="SemiBold"
                               LineHeight="11"/>
                    <TextBlock Text="{Binding TcNo}" 
                               FontSize="9" 
                               Foreground="#cccccc"
                               LineHeight="11"/>
                </StackPanel>

                <!-- Doğum Tarihi + Veli No -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,0">
                    <TextBlock Text="D.T: " 
                               FontSize="9" 
                               Foreground="#7a8a96" 
                               FontWeight="SemiBold"
                               LineHeight="11"/>
                    <TextBlock Text="{Binding BirthDateString}" 
                               FontSize="9" 
                               Foreground="#cccccc"
                               Margin="0,0,8,0"
                               LineHeight="11"/>
                    <TextBlock Text="Veli: " 
                               FontSize="9" 
                               Foreground="#7a8a96" 
                               FontWeight="SemiBold"
                               LineHeight="11"/>
                    <TextBlock Text="{Binding GuardianPhone}" 
                               FontSize="9" 
                               Foreground="#cccccc"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="70"
                               LineHeight="11"/>
                </StackPanel>
            </Grid>

            <!-- Right: Star Button + Künye -->
            <StackPanel Grid.Column="2" VerticalAlignment="Top" Orientation="Vertical">
                <!-- Star Button -->
                <Button Content="☆" 
                        Width="20" 
                        Height="20" 
                        Background="Transparent"
                        BorderThickness="0"
                        FontSize="12"
                        Cursor="Hand"
                        Click="FavoriteButton_Click"
                        Margin="0,0,0,0"
                        Padding="0"
                        ToolTip="{Binding FavoriteTooltip}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Foreground" Value="#7a8a96"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                    <Setter Property="Content" Value="★"/>
                                    <Setter Property="Foreground" Value="#ffc107"/>
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="#ffc107"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Künye Button -->
                <Button Content="Künye" 
                        Style="{StaticResource KunyeButtonStyle}"
                        Padding="5,1"
                        Margin="0,3,0,0"
                        Click="KunyeButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="2"
                                    Padding="{TemplateBinding Padding}">
                                <TextBlock Text="{TemplateBinding Content}"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontSize="{TemplateBinding FontSize}"
                                           FontWeight="{TemplateBinding FontWeight}"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center"
                                           LineHeight="11"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
