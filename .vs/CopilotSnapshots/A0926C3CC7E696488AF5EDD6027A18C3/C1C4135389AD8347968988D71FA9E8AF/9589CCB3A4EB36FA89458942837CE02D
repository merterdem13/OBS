<UserControl x:Class="AlparslanOBS.Views.Components.StudentCardComponent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="140" d:DesignWidth="380">
    
    <UserControl.Resources>
        <Style x:Key="KunyeButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#ef5350"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#f44336"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#e53935"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    
    <Border Background="#1c2127" 
            BorderBrush="#283039" 
            BorderThickness="1" 
            CornerRadius="6" 
            Padding="14,12"
            Cursor="Hand"
            MouseEnter="Card_MouseEnter"
            MouseLeave="Card_MouseLeave">
        <Border.Effect>
            <DropShadowEffect BlurRadius="8" 
                            ShadowDepth="2" 
                            Opacity="0.25"
                            Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Profile Image -->
            <Image Grid.Column="0" 
                   Source="{Binding PhotoPath}"
                   Width="80" 
                   Height="80" 
                   Stretch="UniformToFill"
                   Margin="0,0,14,0"
                   ContextMenuOpening="Photo_ContextMenuOpening">
                <Image.Clip>
                    <RectangleGeometry Rect="0,0,80,80" RadiusX="4" RadiusY="4"/>
                </Image.Clip>
                <Image.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="PNG olarak kaydet" 
                                 Click="ExportToPng_Click"/>
                    </ContextMenu>
                </Image.ContextMenu>
            </Image>

            <!-- Center: Student Info -->
            <StackPanel Grid.Column="1" VerticalAlignment="Top">
                <!-- Name + Star -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding FullName}" 
                               FontSize="14" 
                               FontWeight="Bold" 
                               Foreground="#ffffff"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1"
                            Content="☆" 
                            Width="24" 
                            Height="24" 
                            Background="Transparent"
                            BorderThickness="0"
                            FontSize="16"
                            Cursor="Hand"
                            Click="FavoriteButton_Click"
                            Margin="8,0,0,0"
                            Padding="0"
                            ToolTip="{Binding FavoriteTooltip}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Foreground" Value="#999999"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                        <Setter Property="Content" Value="★"/>
                                        <Setter Property="Foreground" Value="#ffc107"/>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#ffc107"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <!-- Info Rows -->
                <Grid Margin="0,0,0,3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Sınıf: " 
                               FontSize="11" 
                               Foreground="#7a8a96" 
                               FontWeight="SemiBold"
                               Margin="0,0,4,0"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding Class}" 
                               FontSize="11" 
                               Foreground="#137fec"
                               FontWeight="SemiBold"
                               Margin="0,0,16,0"/>

                    <TextBlock Grid.Column="2"
                               Text="No: " 
                               FontSize="11" 
                               Foreground="#7a8a96" 
                               FontWeight="SemiBold"
                               Margin="0,0,4,0"/>
                    <TextBlock Grid.Column="3"
                               Text="{Binding StudentNumber}" 
                               FontSize="11" 
                               Foreground="#999999"/>
                </Grid>

                <!-- TC No -->
                <Grid Margin="0,0,0,3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="TC No: " 
                               FontSize="11" 
                               Foreground="#7a8a96" 
                               FontWeight="SemiBold"
                               Margin="0,0,4,0"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding TcNo}" 
                               FontSize="11" 
                               Foreground="#999999"/>
                </Grid>

                <!-- Birth Date -->
                <Grid Margin="0,0,0,3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="D.Tarihi: " 
                               FontSize="11" 
                               Foreground="#7a8a96" 
                               FontWeight="SemiBold"
                               Margin="0,0,4,0"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding BirthDateString}" 
                               FontSize="11" 
                               Foreground="#999999"
                               Margin="0,0,16,0"/>

                    <TextBlock Grid.Column="2"
                               Text="Telefon: " 
                               FontSize="11" 
                               Foreground="#7a8a96" 
                               FontWeight="SemiBold"
                               Margin="0,0,4,0"/>
                    <TextBlock Grid.Column="3"
                               Text="{Binding GuardianPhone}" 
                               FontSize="11" 
                               Foreground="#999999"
                               TextTrimming="CharacterEllipsis"/>
                </Grid>
            </StackPanel>

            <!-- Right: Künye Button -->
            <Button Grid.Column="2"
                    Content="Künye" 
                    Style="{StaticResource KunyeButtonStyle}"
                    VerticalAlignment="Bottom"
                    Click="KunyeButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       TextAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Border>
</UserControl>
