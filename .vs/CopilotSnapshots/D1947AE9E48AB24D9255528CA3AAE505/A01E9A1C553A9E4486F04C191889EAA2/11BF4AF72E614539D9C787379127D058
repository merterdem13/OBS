<UserControl x:Class="AlparslanOBS.Views.Components.SearchFilterComponent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:converters="clr-namespace:AlparslanOBS.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <StackPanel Margin="12,8,12,6">

        <!-- Arama -->
        <ui:TextBox PlaceholderText="Öğrenci Ara (Ad, No)..."
                    Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                    Margin="0,0,0,8">
            <ui:TextBox.Icon>
                <ui:SymbolIcon Symbol="Search24"/>
            </ui:TextBox.Icon>
        </ui:TextBox>

        <!-- Filtre Satırı -->
        <Grid Margin="0,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <ComboBox ItemsSource="{Binding ClassList}"
                          SelectedItem="{Binding SelectedClass}"
                          Height="32"
                          VerticalContentAlignment="Center"/>

                <TextBlock Text="Sınıf Seçiniz"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedClass}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <ui:Button Grid.Column="1"
                       Appearance="Danger"
                       Padding="8,4" Margin="6,0,0,0"
                       ToolTip="Favorileri Temizle"
                       Command="{Binding ClearAllFavoritesCommand}"
                       Visibility="{Binding IsFavoriteMode, Converter={StaticResource BoolToVisibility}}">
                <ui:SymbolIcon Symbol="Delete24" FontSize="16"/>
            </ui:Button>
        </Grid>

        <!-- Sınıf Eylemleri (sınıf seçilince görünür) -->
        <UniformGrid Columns="3" Margin="0,8,0,0"
                     Visibility="{Binding IsClassSelected, Converter={StaticResource BoolToVisibility}}">
            <ui:Button Content="Sınıf Listesi"
                       Appearance="Primary"
                       Margin="0,0,3,0" Padding="4,6"
                       FontSize="11"
                       Command="{Binding PrintClassListCommand}"/>
            <ui:Button Content="Fotoğraf Listesi"
                       Appearance="Secondary"
                       Margin="3,0,3,0" Padding="4,6"
                       FontSize="11"
                       Command="{Binding PrintPhotoListCommand}"/>
            <ui:Button Content="Excel Aktar"
                       Appearance="Success"
                       Margin="3,0,0,0" Padding="4,6"
                       FontSize="11"
                       Command="{Binding ExportExcelCommand}"/>
        </UniformGrid>
    </StackPanel>
</UserControl>
