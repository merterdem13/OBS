using System;
using System.Collections.Generic;
using System.IO;
using System.Linq;
using BenchmarkDotNet.Attributes;
using AlparslanOBS.Services;
using AlparslanOBS.Models;
using iText.Kernel.Pdf;
using iText.Layout;
using iText.Layout.Element;
using Microsoft.VSDiagnostics;

[CPUUsageDiagnoser]
public class PdfExtractionBenchmark
{
    private string _tempPdfPath = null!;
    private PdfExtractionService _service = null!;
    [GlobalSetup]
    public void Setup()
    {
        _service = new PdfExtractionService();
        _tempPdfPath = Path.Combine(Path.GetTempPath(), $"benchmark_kunye_{Guid.NewGuid()}.pdf");
        using var writer = new PdfWriter(_tempPdfPath);
        using var pdf = new PdfDocument(writer);
        using var document = new Document(pdf);
        for (int i = 0; i < 30; i++)
        {
            if (i > 0)
                document.Add(new AreaBreak());
            document.Add(new Paragraph("ÖĞRENCİ KÜNYE DEFTERİ"));
            document.Add(new Paragraph($"Okul No : {1000 + i}"));
            document.Add(new Paragraph($"T.C. Kimlik No : {10000000000 + i}"));
            document.Add(new Paragraph($"Adı : Öğrenci{i}"));
            document.Add(new Paragraph($"Soyadı : Soyad{i}"));
            document.Add(new Paragraph($"Doğum Yeri, Tarihi : İstanbul 01.01.2010"));
        }
    }

    [GlobalCleanup]
    public void Cleanup()
    {
        _service.CleanupTempFiles();
        if (File.Exists(_tempPdfPath))
            File.Delete(_tempPdfPath);
    }

    [Benchmark]
    public List<Student> ExtractStudentsFromKunye()
    {
        return _service.ExtractStudentsFromKunyePdf(_tempPdfPath).ToList();
    }

    [Benchmark]
    public PdfDocumentType DetectDocumentType()
    {
        return _service.GetPdfDocumentType(_tempPdfPath);
    }
}