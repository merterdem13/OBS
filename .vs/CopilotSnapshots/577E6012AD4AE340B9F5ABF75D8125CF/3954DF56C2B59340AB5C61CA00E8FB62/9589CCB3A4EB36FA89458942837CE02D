<UserControl x:Class="AlparslanOBS.Views.Components.StudentCardComponent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="110" d:DesignWidth="380">
    
    <!--
        STUDENT CARD COMPONENT (KOMPAKT VERSİYON)
        İSTEM METNİ GEREĞİ KART LAYOUT:
        ┌────┐ Ad Soyad (Kalın)        ⭐
        │FOTO│ SINIF: 9-A  NO: 123
        └────┘ TC: 12345678901
               [KÜNYE]
        
        BOYUT OPTİMİZASYONU: Daha kompakt, ölü alan minimum
    -->
    
    <Border Background="White" 
            BorderBrush="#BDC3C7" 
            BorderThickness="1" 
            CornerRadius="6" 
            Margin="3"
            Padding="6">
        
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sol Bölüm: Fotoğraf (Kompakt) -->
            <Border Grid.Column="0" 
                    Width="70" 
                    Height="90" 
                    CornerRadius="3" 
                    Background="#ECF0F1"
                    Margin="0,0,8,0">
                <Image Source="{Binding PhotoPath}" 
                       Stretch="UniformToFill"
                       ContextMenuOpening="Photo_ContextMenuOpening">
                    <Image.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="PNG olarak kaydet" 
                                     Click="ExportToPng_Click"/>
                        </ContextMenu>
                    </Image.ContextMenu>
                </Image>
            </Border>

            <!-- Sağ Bölüm: Bilgiler (Kompakt) -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Üst: Ad Soyad + Favori Butonu -->
                <Grid Grid.Row="0" Margin="0,0,0,3">
                    <TextBlock Text="{Binding FullName}" 
                               FontSize="13" 
                               FontWeight="Bold" 
                               Foreground="#2C3E50"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                    
                    <!-- Favori Butonu (Sağ Üst - Kompakt) -->
                    <Button Content="⭐" 
                            Width="22" 
                            Height="22" 
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            BorderThickness="0"
                            FontSize="13"
                            Cursor="Hand"
                            Click="FavoriteButton_Click"
                            ToolTip="{Binding FavoriteTooltip}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Foreground" Value="#BDC3C7"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                        <Setter Property="Foreground" Value="#F39C12"/>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#ECF0F1"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <!-- Orta: Öğrenci Bilgileri (Kompakt - 2 sütunlu) -->
                <Grid Grid.Row="1" Margin="0,2,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Satır 1: Sınıf + No -->
                    <TextBlock Grid.Row="0" Grid.Column="0" 
                               FontSize="10" 
                               Foreground="#34495E" 
                               Margin="0,0,2,2">
                        <Run Text="SINIF: " FontWeight="SemiBold"/>
                        <Run Text="{Binding Class, Mode=OneWay}"/>
                    </TextBlock>
                    
                    <TextBlock Grid.Row="0" Grid.Column="1" 
                               FontSize="10" 
                               Foreground="#34495E" 
                               Margin="2,0,0,2">
                        <Run Text="NO: " FontWeight="SemiBold"/>
                        <Run Text="{Binding ClassNo, Mode=OneWay}"/>
                    </TextBlock>

                    <!-- Satır 2: TC (Tam genişlik) -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                               FontSize="10" 
                               Foreground="#34495E" 
                               Margin="0,0,0,2">
                        <Run Text="TC: " FontWeight="SemiBold"/>
                        <Run Text="{Binding TcNo, Mode=OneWay}"/>
                    </TextBlock>

                    <!-- Satır 3: Doğum + Veli (Kısa) -->
                    <TextBlock Grid.Row="2" Grid.Column="0" 
                               FontSize="9" 
                               Foreground="#7F8C8D" 
                               Margin="0,0,2,0"
                               TextTrimming="CharacterEllipsis">
                        <Run Text="D.T: " FontWeight="SemiBold"/>
                        <Run Text="{Binding BirthDateString, Mode=OneWay}"/>
                    </TextBlock>
                    
                    <TextBlock Grid.Row="2" Grid.Column="1" 
                               FontSize="9" 
                               Foreground="#7F8C8D" 
                               Margin="2,0,0,0"
                               TextTrimming="CharacterEllipsis">
                        <Run Text="Veli: " FontWeight="SemiBold"/>
                        <Run Text="{Binding GuardianPhone, Mode=OneWay}"/>
                    </TextBlock>
                </Grid>

                <!-- Alt: Künye Butonu (Kompakt) -->
                <Button Grid.Row="2" 
                        Content="KÜNYE" 
                        Width="60" 
                        Height="22" 
                        HorizontalAlignment="Right"
                        Background="#E74C3C"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="9"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Click="KunyeButton_Click"
                        Margin="0,3,0,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#E74C3C"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="3"
                                                Padding="5,3">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#C0392B"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Grid>
    </Border>
</UserControl>
