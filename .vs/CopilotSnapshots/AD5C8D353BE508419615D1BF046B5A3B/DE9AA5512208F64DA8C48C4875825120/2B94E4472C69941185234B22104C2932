using System;
using System.Windows;
using System.Windows.Controls;
using System.Windows.Media;
using System.Windows.Media.Animation;
using System.Windows.Threading;

namespace AlparslanOBS.Services
{
    /// <summary>
    /// Toast mesaj gösterimi için servis.
    /// İSTEM METNİ GEREĞİ: 
    /// - Büyük popup kullanılmaz
    /// - Pozisyon: Sağ alt veya üst
    /// - Yeşil: Başarılı, Kırmızı: Hata
    /// - Süre: 3 saniye
    /// </summary>
    public static class ToastService
    {
        private static Border? _currentToast;
        private static DispatcherTimer? _timer;

        /// <summary>
        /// Başarılı toast gösterir (Yeşil).
        /// </summary>
        public static void ShowSuccess(string message, Window? owner = null)
        {
            ShowToast(message, "#27AE60", owner);
        }

        /// <summary>
        /// Hata toast gösterir (Kırmızı).
        /// </summary>
        public static void ShowError(string message, Window? owner = null)
        {
            ShowToast(message, "#E74C3C", owner);
        }

        /// <summary>
        /// Bilgi toast gösterir (Mavi).
        /// </summary>
        public static void ShowInfo(string message, Window? owner = null)
        {
            ShowToast(message, "#3498DB", owner);
        }

        /// <summary>
        /// Toast mesajı gösterir.
        /// </summary>
        private static void ShowToast(string message, string backgroundColor, Window? owner)
        {
            var window = owner ?? Application.Current.MainWindow;
            if (window == null) return;

            // Mevcut toast'ı kapat
            CloseCurrentToast();

            // Ana container (Grid overlay)
            if (window.Content is not Grid mainGrid)
                return;

            // Toast container oluştur
            var toast = new Border
            {
                Background = new SolidColorBrush((Color)ColorConverter.ConvertFromString(backgroundColor)),
                CornerRadius = new CornerRadius(6),
                Padding = new Thickness(15, 10, 15, 10),
                MaxWidth = 300,
                HorizontalAlignment = HorizontalAlignment.Right,
                VerticalAlignment = VerticalAlignment.Top,
                Margin = new Thickness(0, 70, 15, 0),
                Opacity = 0
            };

            toast.Effect = new System.Windows.Media.Effects.DropShadowEffect
            {
                BlurRadius = 10,
                ShadowDepth = 3,
                Opacity = 0.3
            };

            // İçerik
            var textBlock = new TextBlock
            {
                Text = message,
                Foreground = Brushes.White,
                FontSize = 13,
                FontWeight = FontWeights.SemiBold,
                TextWrapping = TextWrapping.Wrap
            };

            toast.Child = textBlock;

            // Grid'e ekle (en üstte olması için)
            Grid.SetRowSpan(toast, 10);
            Grid.SetColumnSpan(toast, 10);
            mainGrid.Children.Add(toast);

            _currentToast = toast;

            // Fade in animasyonu
            var fadeIn = new DoubleAnimation
            {
                From = 0,
                To = 1,
                Duration = TimeSpan.FromMilliseconds(300)
            };
            toast.BeginAnimation(UIElement.OpacityProperty, fadeIn);

            // 3 saniye sonra otomatik kapat
            _timer?.Stop();
            _timer = new DispatcherTimer
            {
                Interval = TimeSpan.FromSeconds(3)
            };
            _timer.Tick += (s, e) =>
            {
                _timer.Stop();
                CloseCurrentToast();
            };
            _timer.Start();
        }

        /// <summary>
        /// Mevcut toast'ı kapat.
        /// </summary>
        private static void CloseCurrentToast()
        {
            if (_currentToast == null) return;

            var fadeOut = new DoubleAnimation
            {
                From = 1,
                To = 0,
                Duration = TimeSpan.FromMilliseconds(200)
            };

            fadeOut.Completed += (s, e) =>
            {
                if (_currentToast?.Parent is Panel parent)
                {
                    parent.Children.Remove(_currentToast);
                }
                _currentToast = null;
            };

            _currentToast.BeginAnimation(UIElement.OpacityProperty, fadeOut);
        }
    }
}
