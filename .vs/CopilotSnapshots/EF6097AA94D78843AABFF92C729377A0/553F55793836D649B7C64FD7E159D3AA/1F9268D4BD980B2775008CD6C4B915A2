using System;
using System.Collections.Generic;
using System.Globalization;
using System.IO;
using Microsoft.Data.Sqlite;
using AlparslanOBS.Models;

namespace AlparslanOBS.DataAccess
{
    /// <summary>
    /// Students tablosu için veritabanı işlemlerini yürüten katman (Repository).
    /// İş mantığı barındırmaz, sadece SQL sorgularını ve parametreleri güvenli bir şekilde yönetir.
    /// </summary>
    public class StudentRepository
    {
        public StudentRepository()
        {
            DatabaseConnection.EnsureDatabase();
        }

        /// <summary>
        /// Tüm öğrencileri getirir. Büyük veri setleri için ileride pagination eklenebilir.
        /// </summary>
        public IEnumerable<Student> GetAll()
        {
            using var conn = DatabaseConnection.GetConnection();
            conn.Open();
            using var cmd = conn.CreateCommand();
            cmd.CommandText = "SELECT StudentNumber, FirstName, LastName, Class, ClassNo, TcNo, BirthDate, PhotoPath, Gender, GuardianId, KunyePdfPath FROM Students;";

            using var reader = cmd.ExecuteReader();
            while (reader.Read())
            {
                yield return Map(reader);
            }
        }

        private Student Map(SqliteDataReader r)
        {
            static string getString(SqliteDataReader rd, string name)
            {
                var idx = rd.GetOrdinal(name);
                return rd.IsDBNull(idx) ? string.Empty : rd.GetString(idx);
            }

            static int getInt(SqliteDataReader rd, string name)
            {
                var idx = rd.GetOrdinal(name);
                return rd.IsDBNull(idx) ? 0 : rd.GetInt32(idx);
            }

            static DateTime? getDate(SqliteDataReader rd, string name)
            {
                var idx = rd.GetOrdinal(name);
                if (rd.IsDBNull(idx)) return null;
                try
                {
                    return rd.GetDateTime(idx);
                }
                catch
                {
                    var s = rd.GetString(idx);
                    if (DateTime.TryParse(s, out var dt)) return dt;
                    return null;
                }
            }

            return new Student
            {
                StudentNumber = getString(r, "StudentNumber"),
                FirstName = getString(r, "FirstName"),
                LastName = getString(r, "LastName"),
                Class = getString(r, "Class"),
                ClassNo = getInt(r, "ClassNo"),
                TcNo = getString(r, "TcNo"),
                BirthDate = getDate(r, "BirthDate"),
                PhotoPath = getString(r, "PhotoPath"),
                Gender = getString(r, "Gender"),
                GuardianId = r.IsDBNull(r.GetOrdinal("GuardianId")) ? (int?)null : r.GetInt32(r.GetOrdinal("GuardianId")),
                KunyePdfPath = getString(r, "KunyePdfPath")
            };
        }

        /// <summary>
        /// ON CONFLICT(StudentNumber) DO UPDATE kullanarak UPSERT (Merge) işlemi yapar.
        /// Transaction yönetimi için harici bağlantı kabul edebilir.
        /// </summary>
        public void Upsert(Student s, SqliteConnection? connection = null, SqliteTransaction? transaction = null)
        {
            var externalConn = connection != null;
            using var conn = externalConn ? null : DatabaseConnection.GetConnection();
            if (!externalConn) conn!.Open();

            var cmd = (connection ?? conn)!.CreateCommand();
            if (transaction != null) cmd.Transaction = transaction;

            cmd.CommandText = @"
                INSERT INTO Students (StudentNumber, FirstName, LastName, Class, ClassNo, TcNo, BirthDate, PhotoPath, Gender, GuardianId, KunyePdfPath)
                VALUES (@StudentNumber, @FirstName, @LastName, @Class, @ClassNo, @TcNo, @BirthDate, @PhotoPath, @Gender, @GuardianId, @KunyePdfPath)
                ON CONFLICT(StudentNumber) DO UPDATE SET
                    FirstName  = COALESCE(NULLIF(excluded.FirstName, ''),  Students.FirstName),
                    LastName   = COALESCE(NULLIF(excluded.LastName, ''),   Students.LastName),
                    Class      = COALESCE(NULLIF(excluded.Class, ''),      Students.Class),
                    ClassNo    = CASE WHEN excluded.ClassNo != 0 THEN excluded.ClassNo ELSE Students.ClassNo END,
                    TcNo       = COALESCE(NULLIF(excluded.TcNo, ''),       Students.TcNo),
                    BirthDate  = COALESCE(excluded.BirthDate,              Students.BirthDate),
                    PhotoPath  = COALESCE(NULLIF(excluded.PhotoPath, ''),  Students.PhotoPath),
                    Gender     = COALESCE(NULLIF(excluded.Gender, ''),     Students.Gender),
                    GuardianId = COALESCE(excluded.GuardianId,             Students.GuardianId),
                    KunyePdfPath = COALESCE(NULLIF(excluded.KunyePdfPath, ''), Students.KunyePdfPath);
            ";

            cmd.Parameters.AddWithValue("@StudentNumber", s.StudentNumber ?? string.Empty);
            cmd.Parameters.AddWithValue("@FirstName", s.FirstName ?? string.Empty);
            cmd.Parameters.AddWithValue("@LastName", s.LastName ?? string.Empty);
            cmd.Parameters.AddWithValue("@Class", s.Class ?? string.Empty);
            cmd.Parameters.AddWithValue("@ClassNo", s.ClassNo);
            cmd.Parameters.AddWithValue("@TcNo", s.TcNo ?? string.Empty);
            cmd.Parameters.AddWithValue("@BirthDate", s.BirthDate.HasValue ? s.BirthDate.Value.ToString("o") : (object)DBNull.Value);
            cmd.Parameters.AddWithValue("@PhotoPath", s.PhotoPath ?? string.Empty);
            cmd.Parameters.AddWithValue("@Gender", s.Gender ?? string.Empty);
            cmd.Parameters.AddWithValue("@GuardianId", s.GuardianId.HasValue ? (object)s.GuardianId.Value : DBNull.Value);
            cmd.Parameters.AddWithValue("@KunyePdfPath", s.KunyePdfPath ?? string.Empty);

            cmd.ExecuteNonQuery();
        }

        /// <summary>
        /// Sınıf listesi PDF'inden veri okunduğunda sadece mevcut öğrencinin sınıfını ve cinsiyetini günceller.
        /// Anayasa Kuralı: Öğrenci sistemde yoksa YENİ KAYIT EKLENMEZ, durum loglanır.
        /// </summary>
        public void UpsertClass(Student s, SqliteConnection? connection = null, SqliteTransaction? transaction = null)
        {
            var externalConn = connection != null;
            using var conn = externalConn ? null : DatabaseConnection.GetConnection();
            if (!externalConn) conn!.Open();

            var cmd = (connection ?? conn)!.CreateCommand();
            if (transaction != null) cmd.Transaction = transaction;

            // Class ve Gender'ı güncelle
            cmd.CommandText = @"
                UPDATE Students 
                SET Class = @Class, Gender = @Gender
                WHERE StudentNumber = @StudentNumber;
            ";

            cmd.Parameters.AddWithValue("@StudentNumber", s.StudentNumber ?? string.Empty);
            cmd.Parameters.AddWithValue("@Class", s.Class ?? string.Empty);
            cmd.Parameters.AddWithValue("@Gender", s.Gender ?? string.Empty);

            int rowsAffected = cmd.ExecuteNonQuery();

            if (rowsAffected == 0)
            {
                LogMissingStudent(s.StudentNumber);
            }
        }

        /// <summary>
        /// Sistemde bulunamayan öğrencileri 'Logs/app_log.txt' dosyasına kaydeder.
        /// </summary>
        private void LogMissingStudent(string? studentNumber)
        {
            try
            {
                string logDir = DatabaseConnection.GetLogsFolder();
                string logFile = Path.Combine(logDir, "app_log.txt");
                string logMessage = $"[{DateTime.Now:yyyy-MM-dd HH:mm:ss}] UYARI: Sınıf listesinde bulunan ancak veritabanında kaydı olmayan öğrenci numarası atlandı: {studentNumber}{Environment.NewLine}";

                File.AppendAllText(logFile, logMessage);
            }
            catch
            {
                // Dosya kilitlenmesi vb. log hataları asıl süreci (merge) kesmemeli
            }
        }

        /// <summary>
        /// Belirli bir sınıftaki öğrencileri getirir.
        /// </summary>
        public IEnumerable<Student> GetByClass(string className)
        {
            using var conn = DatabaseConnection.GetConnection();
            conn.Open();
            using var cmd = conn.CreateCommand();
            cmd.CommandText = "SELECT StudentNumber, FirstName, LastName, Class, ClassNo, TcNo, BirthDate, PhotoPath, Gender, GuardianId, KunyePdfPath FROM Students WHERE Class = @Class ORDER BY CAST(StudentNumber AS INTEGER), StudentNumber;";
            cmd.Parameters.AddWithValue("@Class", className ?? string.Empty);

            using var reader = cmd.ExecuteReader();
            var list = new List<Student>();
            while (reader.Read())
                list.Add(Map(reader));
            return list;
        }

        /// <summary>
        /// Ad, soyad veya okul numarasına göre öğrenci arar.
        /// Türkçe büyük/küçük harf duyarsız arama yapar (İ/i, I/ı, Ş/ş, Ç/ç vb.).
        /// SQLite'ın yerleşik LIKE operatörü Türkçe harfleri desteklemediğinden,
        /// tr_lower custom fonksiyonu ile Türkçe-duyarlı eşleşme yapılır.
        /// </summary>
        public IEnumerable<Student> Search(string keyword)
        {
            if (string.IsNullOrWhiteSpace(keyword))
                return [];

            var tr = new CultureInfo("tr-TR");
            var kwLower = keyword.Trim().ToLower(tr);

            // Öğrenci numarası sadece rakamlardan oluşur.
            // Arama metni tamamen sayısal ise yalnızca numara ile eşleştir.
            bool isNumeric = kwLower.All(char.IsDigit);

            // Soyad eşleşmesi için minimum 2 karakter gerekli.
            bool matchLastName = !isNumeric && kwLower.Length >= 2;

            using var conn = DatabaseConnection.GetConnection();
            conn.Open();

            // Türkçe büyük/küçük harf duyarsız arama için custom SQLite fonksiyonu.
            // SQLite yerleşik LIKE yalnızca ASCII (A-Z) harfleri için case-insensitive.
            // Bu fonksiyon İ/i, I/ı, Ş/ş, Ç/ç, Ğ/ğ, Ö/ö, Ü/ü gibi Türkçe harfleri de kapsar.
            conn.CreateFunction("tr_lower", (string? s) => s?.ToLower(tr));

            using var cmd = conn.CreateCommand();

            if (isNumeric)
            {
                cmd.CommandText = @"
                    SELECT StudentNumber, FirstName, LastName, Class, ClassNo, TcNo, BirthDate, PhotoPath, Gender, GuardianId, KunyePdfPath 
                    FROM Students
                    WHERE StudentNumber LIKE @kwPrefix
                    ORDER BY 
                        CAST(StudentNumber AS INTEGER),
                        StudentNumber,
                        LastName, FirstName;";
                cmd.Parameters.AddWithValue("@kwPrefix", $"{keyword.Trim()}%");
            }
            else if (matchLastName)
            {
                cmd.CommandText = @"
                    SELECT StudentNumber, FirstName, LastName, Class, ClassNo, TcNo, BirthDate, PhotoPath, Gender, GuardianId, KunyePdfPath 
                    FROM Students
                    WHERE tr_lower(FirstName) LIKE @kwLower
                        OR tr_lower(LastName) LIKE @kwLower
                        OR tr_lower(FirstName || ' ' || LastName) LIKE @kwLower
                    ORDER BY 
                        CAST(StudentNumber AS INTEGER),
                        StudentNumber,
                        LastName, FirstName;";
                cmd.Parameters.AddWithValue("@kwLower", $"{kwLower}%");
            }
            else
            {
                cmd.CommandText = @"
                    SELECT StudentNumber, FirstName, LastName, Class, ClassNo, TcNo, BirthDate, PhotoPath, Gender, GuardianId, KunyePdfPath 
                    FROM Students
                    WHERE tr_lower(FirstName) LIKE @kwLower
                    ORDER BY 
                        CAST(StudentNumber AS INTEGER),
                        StudentNumber,
                        LastName, FirstName;";
                cmd.Parameters.AddWithValue("@kwLower", $"{kwLower}%");
            }

            using var reader = cmd.ExecuteReader();
            var list = new List<Student>();
            while (reader.Read())
            {
                var s = Map(reader);
                var firstName = (s.FirstName ?? "").ToLower(tr);
                var lastName = (s.LastName ?? "").ToLower(tr);
                var fullName = $"{firstName} {lastName}";
                var studentNo = (s.StudentNumber ?? "").ToLower(tr);

                bool match;
                if (isNumeric)
                {
                    match = studentNo.StartsWith(kwLower, StringComparison.Ordinal);
                }
                else
                {
                    match = firstName.StartsWith(kwLower, StringComparison.Ordinal) ||
                            fullName.StartsWith(kwLower, StringComparison.Ordinal);

                    if (!match && matchLastName)
                        match = lastName.StartsWith(kwLower, StringComparison.Ordinal);
                }

                if (match)
                {
                    list.Add(s);
                }
            }

            // Tam okul numarası eşleşmesini öne al
            list.Sort((a, b) =>
            {
                bool aExact = string.Equals(a.StudentNumber, keyword.Trim(), StringComparison.OrdinalIgnoreCase);
                bool bExact = string.Equals(b.StudentNumber, keyword.Trim(), StringComparison.OrdinalIgnoreCase);
                if (aExact != bExact) return aExact ? -1 : 1;
                return 0;
            });

            return list;
        }

        /// <summary>
        /// Toplam öğrenci sayısını veritabanı seviyesinde döndürür.
        /// GetAll().Count() yerine kullanılmalıdır — tüm satırları belleğe çekmeden sayar.
        /// </summary>
        public int GetCount()
        {
            using var conn = DatabaseConnection.GetConnection();
            conn.Open();
            using var cmd = conn.CreateCommand();
            cmd.CommandText = "SELECT COUNT(*) FROM Students;";
            return Convert.ToInt32(cmd.ExecuteScalar());
        }

        /// <summary>
        /// Tek bir öğrenciyi okul numarasına göre getirir.
        /// </summary>
        public Student? GetByStudentNumber(string studentNumber)
        {
            using var conn = DatabaseConnection.GetConnection();
            conn.Open();
            using var cmd = conn.CreateCommand();
            cmd.CommandText = "SELECT StudentNumber, FirstName, LastName, Class, ClassNo, TcNo, BirthDate, PhotoPath, Gender, GuardianId, KunyePdfPath FROM Students WHERE StudentNumber = @sn LIMIT 1;";
            cmd.Parameters.AddWithValue("@sn", studentNumber ?? string.Empty);

            using var reader = cmd.ExecuteReader();
            return reader.Read() ? Map(reader) : null;
        }

        /// <summary>
        /// Veritabanındaki benzersiz sınıf isimlerini döndürür.
        /// </summary>
        public List<string> GetDistinctClasses()
        {
            var list = new List<string>();
            using var conn = DatabaseConnection.GetConnection();
            conn.Open();
            using var cmd = conn.CreateCommand();
            cmd.CommandText = "SELECT DISTINCT Class FROM Students WHERE Class IS NOT NULL AND Class != '' ORDER BY Class;";

            using var reader = cmd.ExecuteReader();
            while (reader.Read())
                list.Add(reader.GetString(0));
            return list;
        }

        /// <summary>
        /// Öğrencinin ID'sini StudentNumber üzerinden bulur.
        /// </summary>
        public int? FindStudentIdByStudentNumber(string studentNumber)
        {
            using var conn = DatabaseConnection.GetConnection();
            conn.Open();
            using var cmd = conn.CreateCommand();
            cmd.CommandText = "SELECT Id FROM Students WHERE StudentNumber = @sn LIMIT 1;";
            cmd.Parameters.AddWithValue("@sn", studentNumber ?? string.Empty);
            var r = cmd.ExecuteScalar();
            if (r == null || r is DBNull) return null;
            return Convert.ToInt32(r);
        }

        /// <summary>
        /// Anayasa Kuralı: Otomatik silme yasaktır! 
        /// Bu metot SADECE kullanıcının "Öğrenciyi Sil" butonuna basması (manuel) durumunda çalışır.
        /// Öğrenci silinirken fiziksel diskteki fotoğrafının da silinebilmesi için PhotoPath bilgisini geriye döndürür.
        /// Not: Bağlı takım kayıtları (TeamMembers) veritabanındaki ON DELETE CASCADE kuralı sayesinde otomatik temizlenir.
        /// </summary>
        public string? Delete(string studentNumber)
        {
            using var conn = DatabaseConnection.GetConnection();
            conn.Open();

            // 1. İşlem: Silmeden önce fiziksel dosyayı silebilmek için fotoğraf yolunu (Path) al
            using var selectCmd = conn.CreateCommand();
            selectCmd.CommandText = "SELECT PhotoPath FROM Students WHERE StudentNumber = @sn LIMIT 1;";
            selectCmd.Parameters.AddWithValue("@sn", studentNumber ?? string.Empty);
            var photoPath = selectCmd.ExecuteScalar() as string;

            // 2. İşlem: Öğrenciyi sil (ON DELETE CASCADE yoluyla bağlı takım üyelikleri otomatik silinir)
            using var deleteCmd = conn.CreateCommand();
            deleteCmd.CommandText = "DELETE FROM Students WHERE StudentNumber = @sn;";
            deleteCmd.Parameters.AddWithValue("@sn", studentNumber ?? string.Empty);
            deleteCmd.ExecuteNonQuery();

            return photoPath;
        }

        /// <summary>
        /// Belirli bir sınıftaki öğrencilerin veli telefon numaralarını döndürür.
        /// Key: GuardianId, Value: PhoneNumber
        /// </summary>
        public Dictionary<int, string> GetGuardianPhonesByClass(string className)
        {
            var result = new Dictionary<int, string>();

            using var conn = DatabaseConnection.GetConnection();
            conn.Open();

            using var cmd = conn.CreateCommand();
            cmd.CommandText = @"
                SELECT g.Id, g.PhoneNumber
                FROM Students s
                INNER JOIN Guardians g ON g.Id = s.GuardianId
                WHERE s.Class = @Class AND s.GuardianId IS NOT NULL;
            ";
            cmd.Parameters.AddWithValue("@Class", className ?? string.Empty);

            using var reader = cmd.ExecuteReader();
            while (reader.Read())
            {
                var guardianId = reader.GetInt32(0);
                var phone = reader.IsDBNull(1) ? "-" : reader.GetString(1);
                result[guardianId] = string.IsNullOrWhiteSpace(phone) ? "-" : phone;
            }

            return result;
        }
    }
}
