<UserControl x:Class="AlparslanOBS.Views.Components.StudentCardComponent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:AlparslanOBS.Converters"
             mc:Ignorable="d"
             d:DesignHeight="120" d:DesignWidth="350"
             FontFamily="Segoe UI" Background="Transparent" Margin="10">

	<UserControl.Resources>
		<converters:PathToImageConverter x:Key="PathToImage" />
	</UserControl.Resources>

	<Border Background="White" CornerRadius="12" Padding="15" Cursor="Hand">
		<Border.Effect>
			<DropShadowEffect BlurRadius="10" ShadowDepth="2" Direction="270" Color="#D5DBDB" Opacity="0.6"/>
		</Border.Effect>

		<Grid>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>

			<Border Grid.Column="0" Width="70" Height="70" CornerRadius="35" Background="#F0F3F4" Margin="0,0,15,0">
				<Border.Background>
					<ImageBrush ImageSource="{Binding PhotoPath, Converter={StaticResource PathToImage}}" Stretch="UniformToFill"/>
				</Border.Background>
			</Border>

			<StackPanel Grid.Column="1" VerticalAlignment="Center">

				<TextBlock Text="{Binding FullName}"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="#2C3E50"
                           Margin="0,0,0,4"
                           TextTrimming="CharacterEllipsis"/>
				<StackPanel Orientation="Horizontal" Margin="0,0,0,4">
					<TextBlock Text="No: " FontWeight="SemiBold" Foreground="#7F8C8D" FontSize="13"/>
					<TextBlock Text="{Binding StudentNumber}" Foreground="#34495E" FontSize="13" Margin="0,0,10,0"/>

					<TextBlock Text="Sınıf: " FontWeight="SemiBold" Foreground="#7F8C8D" FontSize="13"/>
					<TextBlock Text="{Binding ClassName}" Foreground="#34495E" FontSize="13"/>
				</StackPanel>

				<StackPanel Orientation="Horizontal">
					<TextBlock Text="📞 " Foreground="#95A5A6" FontSize="12" VerticalAlignment="Center"/>
					<TextBlock Text="{Binding GuardianName}" Foreground="#7F8C8D" FontSize="12" TextTrimming="CharacterEllipsis"/>
				</StackPanel>

			</StackPanel>
		</Grid>
	</Border>
</UserControl>