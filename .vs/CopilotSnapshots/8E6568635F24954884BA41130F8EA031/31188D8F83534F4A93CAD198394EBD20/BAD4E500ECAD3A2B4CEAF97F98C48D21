using System.ComponentModel;
using System.Runtime.CompilerServices;
using System.Windows.Input;

namespace AlparslanOBS.ViewModels
{
    /// <summary>
    /// Ana pencerenin (MainWindow) UI durumlarını ve komutlarını yöneten ViewModel sınıfı.
    /// İş mantığı (Database vs) buraya sızdırılmaz, sadece UI manipülasyonları yapılır.
    /// </summary>
    public class MainViewModel : INotifyPropertyChanged
    {
        private bool _isMenuExpanded = true;
        private bool _isTopmost = false;

        /// <summary>
        /// Yan menünün açık (genişletilmiş) veya kapalı (sadece ikonlar) durumunu tutar.
        /// </summary>
        public bool IsMenuExpanded
        {
            get => _isMenuExpanded;
            set
            {
                _isMenuExpanded = value;
                OnPropertyChanged();
            }
        }

        /// <summary>
        /// Uygulamanın diğer tüm pencerelerin üstünde yer alma (Topmost) durumunu tutar.
        /// </summary>
        public bool IsTopmost
        {
            get => _isTopmost;
            set
            {
                _isTopmost = value;
                OnPropertyChanged();
            }
        }

        // --- Komutlar (Commands) ---

        /// <summary>
        /// Yan menüyü açıp kapatan (Accordion/Toggle) komut.
        /// </summary>
        public ICommand ToggleMenuCommand { get; }

        /// <summary>
        /// Topmost özelliğini açıp kapatan komut.
        /// </summary>
        public ICommand ToggleTopmostCommand { get; }

        public MainViewModel()
        {
            // Komut atamaları (RelayCommand kullanılarak View'dan tetiklenmeye hazır hale getirilir)
            ToggleMenuCommand = new RelayCommand(ExecuteToggleMenu);
            ToggleTopmostCommand = new RelayCommand(ExecuteToggleTopmost);
        }

        /// <summary>
        /// Menü durumunu tersine çevirir.
        /// </summary>
        private void ExecuteToggleMenu(object parameter)
        {
            IsMenuExpanded = !IsMenuExpanded;
        }

        /// <summary>
        /// Topmost durumunu tersine çevirir.
        /// </summary>
        private void ExecuteToggleTopmost(object parameter)
        {
            IsTopmost = !IsTopmost;
        }

        // --- INotifyPropertyChanged İmplementasyonu ---
        public event PropertyChangedEventHandler PropertyChanged;

        protected virtual void OnPropertyChanged([CallerMemberName] string propertyName = null)
        {
            PropertyChanged?.Invoke(this, new PropertyChangedEventArgs(propertyName));
        }
    }
}