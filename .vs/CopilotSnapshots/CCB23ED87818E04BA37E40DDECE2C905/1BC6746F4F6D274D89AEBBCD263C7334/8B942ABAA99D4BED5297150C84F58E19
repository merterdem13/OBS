<ui:FluentWindow x:Class="AlparslanOBS.Views.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    mc:Ignorable="d"
    Title="Giriş"
    Width="400" Height="750"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    Topmost="True"
    ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.InputBindings>
        <KeyBinding Key="Enter"    Command="{Binding ConfirmCommand}"/>
        <KeyBinding Key="Back"     Command="{Binding DeleteCommand}"/>
        <KeyBinding Key="D0"       Command="{Binding NumpadCommand}" CommandParameter="0"/>
        <KeyBinding Key="D1"       Command="{Binding NumpadCommand}" CommandParameter="1"/>
        <KeyBinding Key="D2"       Command="{Binding NumpadCommand}" CommandParameter="2"/>
        <KeyBinding Key="D3"       Command="{Binding NumpadCommand}" CommandParameter="3"/>
        <KeyBinding Key="D4"       Command="{Binding NumpadCommand}" CommandParameter="4"/>
        <KeyBinding Key="D5"       Command="{Binding NumpadCommand}" CommandParameter="5"/>
        <KeyBinding Key="D6"       Command="{Binding NumpadCommand}" CommandParameter="6"/>
        <KeyBinding Key="D7"       Command="{Binding NumpadCommand}" CommandParameter="7"/>
        <KeyBinding Key="D8"       Command="{Binding NumpadCommand}" CommandParameter="8"/>
        <KeyBinding Key="D9"       Command="{Binding NumpadCommand}" CommandParameter="9"/>
        <KeyBinding Key="NumPad0"  Command="{Binding NumpadCommand}" CommandParameter="0"/>
        <KeyBinding Key="NumPad1"  Command="{Binding NumpadCommand}" CommandParameter="1"/>
        <KeyBinding Key="NumPad2"  Command="{Binding NumpadCommand}" CommandParameter="2"/>
        <KeyBinding Key="NumPad3"  Command="{Binding NumpadCommand}" CommandParameter="3"/>
        <KeyBinding Key="NumPad4"  Command="{Binding NumpadCommand}" CommandParameter="4"/>
        <KeyBinding Key="NumPad5"  Command="{Binding NumpadCommand}" CommandParameter="5"/>
        <KeyBinding Key="NumPad6"  Command="{Binding NumpadCommand}" CommandParameter="6"/>
        <KeyBinding Key="NumPad7"  Command="{Binding NumpadCommand}" CommandParameter="7"/>
        <KeyBinding Key="NumPad8"  Command="{Binding NumpadCommand}" CommandParameter="8"/>
        <KeyBinding Key="NumPad9"  Command="{Binding NumpadCommand}" CommandParameter="9"/>
    </ui:FluentWindow.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <ui:TitleBar Grid.Row="0"
                     Title="Alparslan OBS"
                     ShowMaximize="False"
                     ShowMinimize="False"/>

        <!-- Content -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="3*"/>
            </Grid.RowDefinitions>

            <!-- Top: Icon + Title + PIN Display -->
            <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="24,0">

                <!-- Lock Icon Circle -->
                <Border Width="84" Height="84" CornerRadius="42"
                        Background="{StaticResource AccentBrush}"
                        HorizontalAlignment="Center" Margin="0,0,0,20">
                    <ui:SymbolIcon Symbol="LockClosed24" FontSize="38"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                </Border>

                <!-- Mode Title -->
                <TextBlock Text="{Binding TitleMessage}"
                           FontSize="18" FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="0,0,0,28"/>

                <!-- PIN Dots -->
                <TextBlock Text="{Binding PinDisplay}"
                           FontSize="46" FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource AccentBrush}"
                           Margin="0,0,0,10"/>

                <!-- Error Message -->
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#ef4444"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           MinHeight="20"/>
            </StackPanel>

            <!-- Numpad -->
            <Grid Grid.Row="2" Margin="20,10,20,32" VerticalAlignment="Bottom">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ui:Button Grid.Row="0" Grid.Column="0" Content="1"
                           FontSize="26" FontWeight="SemiBold" Appearance="Secondary"
                           Margin="4" HorizontalAlignment="Stretch"
                           Command="{Binding NumpadCommand}" CommandParameter="1"/>
                <ui:Button Grid.Row="0" Grid.Column="1" Content="2"
                           FontSize="26" FontWeight="SemiBold" Appearance="Secondary"
                           Margin="4" HorizontalAlignment="Stretch"
                           Command="{Binding NumpadCommand}" CommandParameter="2"/>
                <ui:Button Grid.Row="0" Grid.Column="2" Content="3"
                           FontSize="26" FontWeight="SemiBold" Appearance="Secondary"
                           Margin="4" HorizontalAlignment="Stretch"
                           Command="{Binding NumpadCommand}" CommandParameter="3"/>

                <ui:Button Grid.Row="1" Grid.Column="0" Content="4"
                           FontSize="26" FontWeight="SemiBold" Appearance="Secondary"
                           Margin="4" HorizontalAlignment="Stretch"
                           Command="{Binding NumpadCommand}" CommandParameter="4"/>
                <ui:Button Grid.Row="1" Grid.Column="1" Content="5"
                           FontSize="26" FontWeight="SemiBold" Appearance="Secondary"
                           Margin="4" HorizontalAlignment="Stretch"
                           Command="{Binding NumpadCommand}" CommandParameter="5"/>
                <ui:Button Grid.Row="1" Grid.Column="2" Content="6"
                           FontSize="26" FontWeight="SemiBold" Appearance="Secondary"
                           Margin="4" HorizontalAlignment="Stretch"
                           Command="{Binding NumpadCommand}" CommandParameter="6"/>

                <ui:Button Grid.Row="2" Grid.Column="0" Content="7"
                           FontSize="26" FontWeight="SemiBold" Appearance="Secondary"
                           Margin="4" HorizontalAlignment="Stretch"
                           Command="{Binding NumpadCommand}" CommandParameter="7"/>
                <ui:Button Grid.Row="2" Grid.Column="1" Content="8"
                           FontSize="26" FontWeight="SemiBold" Appearance="Secondary"
                           Margin="4" HorizontalAlignment="Stretch"
                           Command="{Binding NumpadCommand}" CommandParameter="8"/>
                <ui:Button Grid.Row="2" Grid.Column="2" Content="9"
                           FontSize="26" FontWeight="SemiBold" Appearance="Secondary"
                           Margin="4" HorizontalAlignment="Stretch"
                           Command="{Binding NumpadCommand}" CommandParameter="9"/>

                <!-- Row 4: empty | 0 | backspace -->
                <ui:Button Grid.Row="3" Grid.Column="1" Content="0"
                           FontSize="26" FontWeight="SemiBold" Appearance="Secondary"
                           Margin="4" HorizontalAlignment="Stretch"
                           Command="{Binding NumpadCommand}" CommandParameter="0"/>
                <ui:Button Grid.Row="3" Grid.Column="2"
                           Appearance="Caution" Margin="4" HorizontalAlignment="Stretch"
                           Command="{Binding DeleteCommand}">
                    <ui:SymbolIcon Symbol="Backspace24" FontSize="22"/>
                </ui:Button>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>