<Window x:Class="AlparslanOBS.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AlparslanOBS.Views"
        xmlns:components="clr-namespace:AlparslanOBS.Views.Components"
        xmlns:helpers="clr-namespace:AlparslanOBS.Helpers"
        xmlns:converters="clr-namespace:AlparslanOBS.Converters"
        mc:Ignorable="d"
        Title="Öğrenci Bilgi Sistemi" 
        Height="750" 
        Width="400"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="False"
        Background="White"
        Topmost="True"
        WindowStartupLocation="CenterScreen">
    
    <!--
        ANA PENCERE (MODÜLER MİMARİ)
        İSTEM METNİ GEREĞİ:
        - 400x750 piksel sabit boyut
        - Her zaman üstte (Topmost)
        - Taşınabilir
        - Favoriler paneli (Sol alt, animasyonlu)
    -->
    
    <Window.Resources>
        <!-- Converters -->
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        
        <!-- SearchBox Style -->
        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#ECF0F1"/>
        </Style>
    </Window.Resources>
    
    <Grid MouseLeftButtonDown="Window_MouseLeftButtonDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>  <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Search Bar -->
            <RowDefinition Height="*"/>    <!-- Student Cards -->
        </Grid.RowDefinitions>

        <!-- 1. HEADER COMPONENT -->
        <components:HeaderComponent Grid.Row="0"/>

        <!-- 2. SEARCH BAR -->
        <Border Grid.Row="1" 
                Background="White" 
                BorderBrush="#BDC3C7" 
                BorderThickness="0,0,0,1"
                Padding="15,10">
            <TextBox x:Name="SearchBox"
                     Style="{StaticResource SearchBoxStyle}"
                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                     helpers:TextBoxPlaceholderHelper.Placeholder="Öğrenci ara: Ad, Soyad, No"/>
        </Border>

        <!-- 3. STUDENT CARDS AREA -->
        <ScrollViewer Grid.Row="2" 
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="#F8F9FA">
            <ItemsControl ItemsSource="{Binding FilteredStudents}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <components:StudentCardComponent 
                            DataContext="{Binding}"
                            FavoriteToggled="StudentCard_FavoriteToggled"
                            KunyeOpened="StudentCard_KunyeOpened"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 4. FAVORİLER PANELİ (Sol Alt, Pop-up) -->
        <components:FavoritesPanelComponent 
            x:Name="FavoritesPanel"
            Grid.Row="2"
            HorizontalAlignment="Left"
            VerticalAlignment="Bottom"
            Margin="10"
            DataContext="{Binding}"
            Visibility="{Binding IsFavoritesPanelOpen, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- 5. FAVORİLER BUTONU (Favoriler varsa görünür) -->
        <Button Grid.Row="2"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Width="50"
                Height="50"
                Margin="15"
                Background="#F39C12"
                BorderThickness="0"
                Cursor="Hand"
                Command="{Binding ToggleFavoritesPanelCommand}"
                Visibility="{Binding HasFavorites, Converter={StaticResource BoolToVisibilityConverter}}"
                ToolTip="Favorilerim">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="25"
                            Padding="0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" 
                                            ShadowDepth="2" 
                                            Opacity="0.3"
                                            Color="#F39C12"/>
                        </Border.Effect>
                        <Grid>
                            <!-- Yıldız İkonu -->
                            <TextBlock Text="⭐" 
                                     FontSize="24"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Foreground="White"/>
                            
                            <!-- Sayı Badge -->
                            <Border Background="#E74C3C"
                                  Width="20"
                                  Height="20"
                                  CornerRadius="10"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Top"
                                  Margin="0,-5,-5,0"
                                  Visibility="{Binding HasFavorites, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="{Binding FavoriteCount}" 
                                         FontSize="10"
                                         FontWeight="Bold"
                                         Foreground="White"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Button.Template>
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="#F39C12"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#E67E22"/>
                        </Trigger>
                        <DataTrigger Binding="{Binding IsFavoritesPanelOpen}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>

        <!-- 6. YÖNETİM PANELİ BUTONU (Sağ Alt - TODO) -->
        <!-- ManagementButtonComponent eklenecek -->
    </Grid>
</Window>
