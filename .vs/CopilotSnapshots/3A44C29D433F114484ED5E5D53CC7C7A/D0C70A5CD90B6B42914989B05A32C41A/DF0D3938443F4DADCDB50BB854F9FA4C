using System.Windows;

namespace AlparslanOBS.Views
{
    public partial class CreateTeamWindow : Window
    {
        public string TeamName => TxtTeamName.Text.Trim();
        public string Description => TxtDescription.Text.Trim();

        public CreateTeamWindow()
        {
            InitializeComponent();
            TxtTeamName.Focus();
        }

        private void BtnSave_Click(object sender, RoutedEventArgs e)
        {
            if (string.IsNullOrWhiteSpace(TeamName))
            {
                MessageBox.Show("Takım adı boş bırakılamaz!", "Uyarı", MessageBoxButton.OK, MessageBoxImage.Warning);
                return;
            }
            this.DialogResult = true; // Başarılı dönüş
            this.Close();
        }

        private void BtnCancel_Click(object sender, RoutedEventArgs e)
        {
            this.DialogResult = false; // İptal
            this.Close();
        }
    }
}