using System;
using System.Collections.Generic;
using System.Linq;
using Microsoft.Data.Sqlite;
using AlparslanOBS.Models;

namespace AlparslanOBS.DataAccess
{
    /// <summary>
    /// TeamRepository Extension Methods - Category bazlı işlemler.
    /// İSTEM METNİ GEREĞİ: Bir öğrenci aynı kategoride birden fazla takımda olamaz.
    /// </summary>
    public static class TeamRepositoryExtensions
    {
        /// <summary>
        /// Öğrencinin belirli bir kategoride takımı var mı kontrol eder.
        /// İSTEM METNİ GEREĞİ: Constraint kontrolü için.
        /// </summary>
        public static bool IsStudentInCategory(this TeamRepository repo, string studentNumber, string category)
        {
            using var conn = DatabaseConnection.GetConnection();
            conn.Open();

            using var cmd = conn.CreateCommand();
            cmd.CommandText = @"
                SELECT COUNT(*)
                FROM TeamMembers tm
                INNER JOIN Teams t ON tm.TeamId = t.Id
                INNER JOIN Students s ON tm.StudentId = s.Id
                WHERE s.StudentNumber = @StudentNumber AND t.Category = @Category
            ";

            cmd.Parameters.AddWithValue("@StudentNumber", studentNumber);
            cmd.Parameters.AddWithValue("@Category", category);

            var result = cmd.ExecuteScalar();
            return result != null && Convert.ToInt32(result) > 0;
        }

        /// <summary>
        /// Kategoriye göre takımları getirir.
        /// </summary>
        public static List<Team> GetTeamsByCategory(this TeamRepository repo, string category)
        {
            var teams = new List<Team>();

            using var conn = DatabaseConnection.GetConnection();
            conn.Open();

            using var cmd = conn.CreateCommand();
            cmd.CommandText = @"
                SELECT Id, TeamName, Category, MatchDate, Description
                FROM Teams
                WHERE Category = @Category
                ORDER BY TeamName
            ";

            cmd.Parameters.AddWithValue("@Category", category);

            using var reader = cmd.ExecuteReader();
            while (reader.Read())
            {
                teams.Add(new Team
                {
                    Id = reader.GetInt32(0),
                    TeamName = reader.GetString(1),
                    Category = reader.IsDBNull(2) ? string.Empty : reader.GetString(2),
                    MatchDate = reader.IsDBNull(3) ? string.Empty : reader.GetString(3),
                    Description = reader.IsDBNull(4) ? string.Empty : reader.GetString(4)
                });
            }

            return teams;
        }

        /// <summary>
        /// Takıma öğrenci ekler (StudentNumber ile).
        /// İSTEM METNİ GEREĞİ: Constraint kontrolü yapılmalı.
        /// </summary>
        public static void AddTeamMember(this TeamRepository repo, int teamId, string studentNumber)
        {
            using var conn = DatabaseConnection.GetConnection();
            conn.Open();

            using (var cmd = conn.CreateCommand())
            {
                cmd.CommandText = "PRAGMA foreign_keys = ON;";
                cmd.ExecuteNonQuery();
            }

            // Önce Student Id'sini bul
            int? studentId = null;
            using (var selectCmd = conn.CreateCommand())
            {
                selectCmd.CommandText = "SELECT Id FROM Students WHERE StudentNumber = @StudentNumber";
                selectCmd.Parameters.AddWithValue("@StudentNumber", studentNumber);
                var result = selectCmd.ExecuteScalar();
                if (result != null && result != DBNull.Value)
                {
                    studentId = Convert.ToInt32(result);
                }
            }

            if (studentId == null)
                throw new Exception($"Öğrenci bulunamadı: {studentNumber}");

            // TeamMember ekle
            using var insertCmd = conn.CreateCommand();
            insertCmd.CommandText = @"
                INSERT INTO TeamMembers (TeamId, StudentId)
                VALUES (@TeamId, @StudentId)
            ";

            insertCmd.Parameters.AddWithValue("@TeamId", teamId);
            insertCmd.Parameters.AddWithValue("@StudentId", studentId.Value);

            insertCmd.ExecuteNonQuery();
        }

        /// <summary>
        /// Takım oluşturur ve Id döndürür.
        /// </summary>
        public static int CreateTeamWithId(this TeamRepository repo, Team team)
        {
            if (string.IsNullOrWhiteSpace(team.TeamName))
                throw new ArgumentException("Takım adı boş olamaz.");

            using var conn = DatabaseConnection.GetConnection();
            conn.Open();

            using (var cmd = conn.CreateCommand())
            {
                cmd.CommandText = "PRAGMA foreign_keys = ON;";
                cmd.ExecuteNonQuery();
            }

            using var cmd2 = conn.CreateCommand();
            cmd2.CommandText = @"
                INSERT INTO Teams (TeamName, Category, MatchDate, Description)
                VALUES (@TeamName, @Category, @MatchDate, @Description);
                SELECT last_insert_rowid();
            ";

            cmd2.Parameters.AddWithValue("@TeamName", team.TeamName);
            cmd2.Parameters.AddWithValue("@Category", team.Category ?? string.Empty);
            cmd2.Parameters.AddWithValue("@MatchDate", team.MatchDate ?? string.Empty);
            cmd2.Parameters.AddWithValue("@Description", team.Description ?? string.Empty);

            var result = cmd2.ExecuteScalar();
            return result != null ? Convert.ToInt32(result) : 0;
        }

        /// <summary>
        /// Tüm kategorileri getirir (Distinct).
        /// </summary>
        public static List<string> GetAllCategories(this TeamRepository repo)
        {
            var categories = new List<string>();

            using var conn = DatabaseConnection.GetConnection();
            conn.Open();

            using var cmd = conn.CreateCommand();
            cmd.CommandText = "SELECT DISTINCT Category FROM Teams WHERE Category IS NOT NULL AND Category != '' ORDER BY Category";

            using var reader = cmd.ExecuteReader();
            while (reader.Read())
            {
                categories.Add(reader.GetString(0));
            }

            return categories;
        }
    }
}
