<Window x:Class="AlparslanOBS.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AlparslanOBS.Views"
        xmlns:components="clr-namespace:AlparslanOBS.Views.Components"
        mc:Ignorable="d"
        Title="Öğrenci Bilgi Sistemi" 
        Height="750" 
        Width="400"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="False"
        Background="White"
        Topmost="True"
        WindowStartupLocation="CenterScreen">
    
    <!--
        ANA PENCERE (MODÜLER MİMARİ)
        İSTEM METNİ GEREĞİ:
        - 400x750 piksel sabit boyut
        - Kullanıcı manuel resize yapamaz
        - Taşınabilir olmalı
        - Her zaman üstte (Topmost=True)
        - Katlanabilir yan menü mimarisi
        
        MODÜLER BİLEŞENLER:
        1. Header Component
        2. Search Bar
        3. Student Cards (ScrollViewer içinde)
        4. Favorites Panel (Sol alt, pop-up)
        5. Management Button (Sağ alt, blurlu)
    -->
    
    <Window.Resources>
        <!-- Modern stil tanımları -->
        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#ECF0F1"/>
        </Style>
    </Window.Resources>
    
    <Grid MouseLeftButtonDown="Window_MouseLeftButtonDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>  <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Search Bar -->
            <RowDefinition Height="*"/>    <!-- Student Cards -->
        </Grid.RowDefinitions>

        <!-- 1. HEADER COMPONENT (Ayrı Modül) -->
        <components:HeaderComponent Grid.Row="0"/>

        <!-- 2. SEARCH BAR (Arama Çubuğu) -->
        <Border Grid.Row="1" 
                Background="White" 
                BorderBrush="#BDC3C7" 
                BorderThickness="0,0,0,1"
                Padding="15,10">
            <TextBox x:Name="SearchBox"
                     Style="{StaticResource SearchBoxStyle}"
                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                     Tag="Öğrenci ara: Ad, Soyad, No"/>
            <!-- Placeholder text için Tag kullanılıyor -->
        </Border>

        <!-- 3. STUDENT CARDS AREA (ScrollViewer) -->
        <ScrollViewer Grid.Row="2" 
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="#F8F9FA">
            <ItemsControl ItemsSource="{Binding FilteredStudents}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <components:StudentCardComponent 
                            DataContext="{Binding}"
                            FavoriteToggled="StudentCard_FavoriteToggled"
                            KunyeOpened="StudentCard_KunyeOpened"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 4. FAVORITES PANEL (Sol Alt, Pop-up - Ayrı Modül) -->
        <!--<components:FavoritesPanelComponent 
            x:Name="FavoritesPanel"
            Grid.Row="2"
            HorizontalAlignment="Left"
            VerticalAlignment="Bottom"
            Margin="10"
            Visibility="{Binding FavoritesPanelVisibility}"/>-->

        <!-- 5. MANAGEMENT BUTTON (Sağ Alt, Blurlu - Ayrı Modül) -->
        <!--<components:ManagementButtonComponent 
            x:Name="ManagementButton"
            Grid.Row="2"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="15"/>-->
    </Grid>
</Window>
