<UserControl x:Class="AlparslanOBS.Views.Components.ManagementButtonComponent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="250" d:DesignWidth="200">
    
    <!--
        YÖNETİM PANELİ BUTONU (Ayrı Modül)
        İSTEM METNİ GEREĞİ:
        - Pozisyon: Sağ alt köşe
        - Görünüm: Blurlu (hafif bulanık), çok göz almayacak
        - Hover: Blur kalkacak + bump (şişme) efekti
        - İçerik: Ayarlar + Takım Oluşturucu
    -->
    
    <UserControl.Resources>
        <!-- Blur Efekti -->
        <BlurEffect x:Key="BlurEffect" Radius="8"/>
        
        <!-- Bump Animasyonu (Hover) -->
        <Storyboard x:Key="BumpInStoryboard">
            <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                           Storyboard.TargetProperty="ScaleX"
                           To="1.1" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                           Storyboard.TargetProperty="ScaleY"
                           To="1.1" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        
        <Storyboard x:Key="BumpOutStoryboard">
            <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                           Storyboard.TargetProperty="ScaleX"
                           To="1.0" Duration="0:0:0.2"/>
            <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                           Storyboard.TargetProperty="ScaleY"
                           To="1.0" Duration="0:0:0.2"/>
        </Storyboard>
    </UserControl.Resources>

    <Grid>
        <!-- Ana Buton + Popup Menu -->
        <Grid x:Name="MainContainer">
            <Grid.RenderTransform>
                <ScaleTransform x:Name="ScaleTransform" 
                              ScaleX="1" ScaleY="1" 
                              CenterX="30" CenterY="30"/>
            </Grid.RenderTransform>

            <!-- Dişli Butonu (Blurlu) -->
            <Button x:Name="SettingsButton"
                    Width="60"
                    Height="60"
                    Background="#34495E"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="SettingsButton_Click"
                    Effect="{StaticResource BlurEffect}"
                    MouseEnter="SettingsButton_MouseEnter"
                    MouseLeave="SettingsButton_MouseLeave"
                    ToolTip="Yönetim Paneli">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="30"
                                Padding="0">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" 
                                                ShadowDepth="3" 
                                                Opacity="0.3"
                                                Color="#2C3E50"/>
                            </Border.Effect>
                            
                            <!-- Dişli İkonu -->
                            <Viewbox Width="32" Height="32">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="White" 
                                          Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#34495E"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2C3E50"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Popup Menu (Ayarlar + Takım Oluşturucu) -->
            <Border x:Name="MenuPopup"
                    Background="White"
                    BorderBrush="#BDC3C7"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="8"
                    Width="200"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,70"
                    Visibility="Collapsed">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" 
                                    ShadowDepth="3" 
                                    Opacity="0.4"
                                    Color="#2C3E50"/>
                </Border.Effect>

                <StackPanel>
                    <!-- Ayarlar Grubu -->
                    <TextBlock Text="AYARLAR" 
                             FontSize="10" 
                             FontWeight="Bold" 
                             Foreground="#7F8C8D"
                             Margin="8,5,0,5"/>

                    <!-- Künye Yükle -->
                    <Button Content="📄 Künye PDF Yükle"
                            Height="35"
                            Background="Transparent"
                            BorderThickness="0"
                            HorizontalContentAlignment="Left"
                            Padding="10,5"
                            Cursor="Hand"
                            Click="LoadKunyePdf_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#2C3E50"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#ECF0F1"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Sistemi Sıfırla -->
                    <Button Content="🗑️ Sistemi Sıfırla"
                            Height="35"
                            Background="Transparent"
                            BorderThickness="0"
                            HorizontalContentAlignment="Left"
                            Padding="10,5"
                            Cursor="Hand"
                            Foreground="#E74C3C"
                            Click="ResetSystem_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FADBD8"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Ayırıcı -->
                    <Separator Margin="5,8"/>

                    <!-- Takım Yönetimi Grubu -->
                    <TextBlock Text="TAKIM YÖNETİMİ" 
                             FontSize="10" 
                             FontWeight="Bold" 
                             Foreground="#7F8C8D"
                             Margin="8,5,0,5"/>

                    <!-- Takım Oluşturucu -->
                    <Button Content="⚽ Takım Oluştur"
                            Height="35"
                            Background="Transparent"
                            BorderThickness="0"
                            HorizontalContentAlignment="Left"
                            Padding="10,5"
                            Cursor="Hand"
                            Click="CreateTeam_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#2C3E50"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#ECF0F1"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Takımları Yönet -->
                    <Button Content="📋 Takımları Yönet"
                            Height="35"
                            Background="Transparent"
                            BorderThickness="0"
                            HorizontalContentAlignment="Left"
                            Padding="10,5"
                            Cursor="Hand"
                            Click="ManageTeams_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#2C3E50"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#ECF0F1"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
