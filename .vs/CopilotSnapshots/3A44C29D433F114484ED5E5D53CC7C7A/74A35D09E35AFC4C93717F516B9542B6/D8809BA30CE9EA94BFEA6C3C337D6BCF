    /// <summary>
    /// Yönetim Paneli Butonu Component - Sağ alt köşe dişli butonu.
    /// İSTEM METNİ GEREĞİ:
    /// - Blurlu görünüm (çok göz almayacak)
    /// - Hover: Blur kalkacak + bump efekti
    /// - Menu: Ayarlar (Künye, Sıfırla) + Takım Yönetimi
    /// </summary>
    public partial class ManagementButtonComponent : UserControl
    {
        private bool _isMenuOpen = false;

        public ManagementButtonComponent()
        {
            InitializeComponent();
        }

        /// <summary>
        /// Dişli butonuna basıldığında menu aç/kapat.
        /// </summary>
        private void SettingsButton_Click(object sender, RoutedEventArgs e)
        {
            ToggleMenu();
        }

        /// <summary>
        /// Mouse hover - Blur kalkacak + bump efekti.
        /// İSTEM METNİ GEREĞİ: Hover'da blur kalkacak, hafif bump olacak.
        /// </summary>
        private void SettingsButton_MouseEnter(object sender, System.Windows.Input.MouseEventArgs e)
        {
            // Blur'u kaldır
            SettingsButton.Effect = null;

            // Bump animasyonu oynat
            var storyboard = (Storyboard)Resources["BumpInStoryboard"];
            storyboard.Begin();
        }

        /// <summary>
        /// Mouse leave - Blur geri gelecek + normal boyut.
        /// </summary>
        private void SettingsButton_MouseLeave(object sender, System.Windows.Input.MouseEventArgs e)
        {
            // Menu açık değilse blur'u geri getir
            if (!_isMenuOpen)
            {
                SettingsButton.Effect = (BlurEffect)Resources["BlurEffect"];
            }

            // Normal boyuta dön
            var storyboard = (Storyboard)Resources["BumpOutStoryboard"];
            storyboard.Begin();
        }

        /// <summary>
        /// Menu'yu aç/kapat.
        /// </summary>
        private void ToggleMenu()
        {
            _isMenuOpen = !_isMenuOpen;

            if (_isMenuOpen)
            {
                MenuPopup.Visibility = Visibility.Visible;
                SettingsButton.Effect = null; // Menu açıkken blur yok
                
                // Fade in animasyonu
                var fadeIn = new DoubleAnimation
                {
                    From = 0,
                    To = 1,
                    Duration = new Duration(System.TimeSpan.FromMilliseconds(200))
                };
                MenuPopup.BeginAnimation(OpacityProperty, fadeIn);
            }
            else
            {
                // Fade out animasyonu
                var fadeOut = new DoubleAnimation
                {
                    From = 1,
                    To = 0,
                    Duration = new Duration(System.TimeSpan.FromMilliseconds(200))
                };
                
                fadeOut.Completed += (s, e) =>
                {
                    MenuPopup.Visibility = Visibility.Collapsed;
                    SettingsButton.Effect = (BlurEffect)Resources["BlurEffect"]; // Blur geri gelsin
                };
                
                MenuPopup.BeginAnimation(OpacityProperty, fadeOut);
            }
        }

