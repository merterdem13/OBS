        /// <summary>
        /// Sistemi Sıfırla.
        /// İSTEM METNİ GEREĞİ: Çift onay ister, tüm DB silinir, PIN korunur.
        /// </summary>
        private void ResetSystem_Click(object sender, RoutedEventArgs e)
        {
            ToggleMenu(); // Menu'yu kapat

            // İlk onay
            var result1 = MessageBox.Show(
                "Sistemi sıfırlamak istediğinizden emin misiniz?\n\n" +
                "Bu işlem:\n" +
                "• Tüm öğrenci verilerini\n" +
                "• Tüm takımları\n" +
                "• Tüm favorileri\n" +
                "• Tüm fotoğrafları\n\n" +
                "KALICI OLARAK SİLECEKTİR!\n\n" +
                "(PIN ayarı korunacaktır)",
                "⚠️ Sistemi Sıfırla - 1. Onay",
                MessageBoxButton.YesNo,
                MessageBoxImage.Warning
            );

            if (result1 != MessageBoxResult.Yes)
                return;

            // İkinci onay (Çift onay)
            var result2 = MessageBox.Show(
                "SON UYARI!\n\n" +
                "Bu işlem GERİ ALINAMAZ!\n\n" +
                "Devam etmek istediğinizden EMİN MİSİNİZ?",
                "⚠️ Sistemi Sıfırla - 2. Onay",
                MessageBoxButton.YesNo,
                MessageBoxImage.Stop
            );

            if (result2 == MessageBoxResult.Yes)
            {
                try
                {
                    // Sistemi sıfırla
                    DataAccess.DatabaseConnection.ResetDatabase();

                    MessageBox.Show(
                        "Sistem başarıyla sıfırlandı!\n\n" +
                        "Uygulama yeniden başlatılacak.",
                        "✅ Başarılı",
                        MessageBoxButton.OK,
                        MessageBoxImage.Information
                    );

                    // Uygulamayı yeniden başlat
                    System.Diagnostics.Process.Start(
                        System.Diagnostics.Process.GetCurrentProcess().MainModule!.FileName!
                    );
                    Application.Current.Shutdown();
                }
                catch (System.Exception ex)
                {
                    MessageBox.Show(
                        $"Sistem sıfırlama hatası:\n\n{ex.Message}",
                        "❌ Hata",
                        MessageBoxButton.OK,
                        MessageBoxImage.Error
                    );
                }
            }
        }

