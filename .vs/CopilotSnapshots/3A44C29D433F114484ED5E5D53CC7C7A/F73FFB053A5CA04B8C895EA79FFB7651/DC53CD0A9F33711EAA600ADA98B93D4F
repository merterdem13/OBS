<UserControl x:Class="AlparslanOBS.Views.Components.StudentCardComponent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="150" d:DesignWidth="380">
    
    <!--
        STUDENT CARD COMPONENT (Ayrı Modül)
        İSTEM METNİ GEREĞİ KART LAYOUT:
        ┌────┐ Ad Soyad (Kalın)        ⭐
        │FOTO│ SINIF: 9-A
        │    │ NO: 123
        └────┘ TC: 12345678901
               [KÜNYE]
    -->
    
    <Border Background="White" 
            BorderBrush="#BDC3C7" 
            BorderThickness="1" 
            CornerRadius="8" 
            Margin="5"
            Padding="10">
        
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sol Bölüm: Fotoğraf (Kare biçimde) -->
            <Border Grid.Column="0" 
                    Width="100" 
                    Height="120" 
                    CornerRadius="4" 
                    Background="#ECF0F1"
                    Margin="0,0,15,0">
                <Image Source="{Binding PhotoPath}" 
                       Stretch="UniformToFill"
                       ContextMenuOpening="Photo_ContextMenuOpening">
                    <Image.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="PNG olarak kaydet" 
                                     Click="ExportToPng_Click"/>
                        </ContextMenu>
                    </Image.ContextMenu>
                </Image>
            </Border>

            <!-- Sağ Bölüm: Bilgiler -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Üst: Ad Soyad + Favori Butonu -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Text="{Binding FullName}" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               Foreground="#2C3E50"
                               VerticalAlignment="Center"/>
                    
                    <!-- Favori Butonu (Sağ Üst) -->
                    <Button Content="⭐" 
                            Width="30" 
                            Height="30" 
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            BorderThickness="0"
                            FontSize="18"
                            Cursor="Hand"
                            Click="FavoriteButton_Click"
                            ToolTip="{Binding FavoriteTooltip}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Foreground" Value="#BDC3C7"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                        <Setter Property="Foreground" Value="#F39C12"/>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#ECF0F1"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <!-- Orta: Öğrenci Bilgileri -->
                <StackPanel Grid.Row="1" Spacing="5">
                    <TextBlock FontSize="13" Foreground="#34495E">
                        <Run Text="SINIF: " FontWeight="SemiBold"/>
                        <Run Text="{Binding Class}"/>
                    </TextBlock>
                    
                    <TextBlock FontSize="13" Foreground="#34495E">
                        <Run Text="NO: " FontWeight="SemiBold"/>
                        <Run Text="{Binding ClassNo}"/>
                    </TextBlock>
                    
                    <TextBlock FontSize="13" Foreground="#34495E">
                        <Run Text="TC: " FontWeight="SemiBold"/>
                        <Run Text="{Binding TcNo}"/>
                    </TextBlock>
                    
                    <TextBlock FontSize="13" Foreground="#34495E">
                        <Run Text="Doğum Tarihi: " FontWeight="SemiBold"/>
                        <Run Text="{Binding BirthDateString}"/>
                    </TextBlock>
                    
                    <TextBlock FontSize="13" Foreground="#34495E">
                        <Run Text="Veli No: " FontWeight="SemiBold"/>
                        <Run Text="{Binding GuardianPhone}"/>
                    </TextBlock>
                </StackPanel>

                <!-- Alt: Künye Butonu (Sağ Alt - Kırmızı) -->
                <Button Grid.Row="2" 
                        Content="KÜNYE" 
                        Width="80" 
                        Height="30" 
                        HorizontalAlignment="Right"
                        Background="#E74C3C"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="12"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Click="KunyeButton_Click"
                        Margin="0,10,0,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#E74C3C"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#C0392B"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Grid>
    </Border>
</UserControl>
