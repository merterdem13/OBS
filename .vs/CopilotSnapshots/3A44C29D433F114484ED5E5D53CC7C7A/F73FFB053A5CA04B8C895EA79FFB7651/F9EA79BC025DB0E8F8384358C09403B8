using System;
using System.IO;
using Microsoft.Data.Sqlite;

namespace AlparslanOBS.DataAccess
{
    /// <summary>
    /// SQLite veritabanÄ± dosyasÄ±nÄ± oluÅŸturma/aÃ§ma ve gerekli PRAGMA ayarlarÄ±nÄ± saÄŸlamaktan sorumlu.
    /// VeritabanÄ± dosyasÄ± admin izin sorunlarÄ±nÄ± Ã¶nlemek iÃ§in AppData\Local\OBS_System altÄ±na yerleÅŸtirilir.
    /// .NET 10 ile uyumlu Microsoft.Data.Sqlite kullanÄ±r.
    /// </summary>
    public static class DatabaseConnection
    {
        private static readonly string _appFolder = Path.Combine(
            Environment.GetFolderPath(Environment.SpecialFolder.LocalApplicationData), 
            "OBS_System"
        );
        private static readonly string _dbPath = Path.Combine(_appFolder, "obs.db");
        private static readonly string _connectionString = $"Data Source={_dbPath}";

        /// <summary>
        /// VeritabanÄ± dosyasÄ±nÄ±n ve klasÃ¶rlerin var olduÄŸundan emin olur.
        /// BaÄŸlantÄ± aÃ§Ä±ldÄ±ÄŸÄ±nda dosya yoksa otomatik oluÅŸturulur.
        /// </summary>
        public static void EnsureDatabase()
        {
            if (!Directory.Exists(_appFolder))
                Directory.CreateDirectory(_appFolder);

            // Destekleyici klasÃ¶rleri oluÅŸtur
            var photosFolder = Path.Combine(_appFolder, "Photos");
            var logsFolder = Path.Combine(_appFolder, "Logs");
            
            if (!Directory.Exists(photosFolder)) Directory.CreateDirectory(photosFolder);
            if (!Directory.Exists(logsFolder)) Directory.CreateDirectory(logsFolder);

            var isNew = !File.Exists(_dbPath);

            using var conn = GetConnection();
            conn.Open();

            // Bu baÄŸlantÄ± iÃ§in foreign key'leri aktifleÅŸtir (Ä°STEM METNÄ° GEREÄÄ° ZORUNLU)
            using (var cmd = conn.CreateCommand())
            {
                cmd.CommandText = "PRAGMA foreign_keys = ON;";
                cmd.ExecuteNonQuery();
            }

            if (isNew)
            {
                // Ä°lk Ã§alÄ±ÅŸtÄ±rmada gerekli tablolarÄ± oluÅŸtur
                CreateTablesIfNotExist(conn);
                CreateIndexes(conn);
            }
            else
            {
                // Mevcut veritabanlarÄ± iÃ§in ÅŸemayÄ± gÃ¼ncelle
                EnsureSchemaUpToDate(conn);
            }
        }

        /// <summary>
        /// TÃ¼m tablolarÄ± oluÅŸturur (ilk kurulumda).
        /// Ä°STEM METNÄ°NE GÃ–RE: Students, Guardians, Teams, TeamMembers, Favorites, Settings tablolarÄ±.
        /// </summary>
        private static void CreateTablesIfNotExist(SqliteConnection conn)
        {
            using var cmd = conn.CreateCommand();
            cmd.CommandText = @"
                -- Veli bilgileri tablosu
                CREATE TABLE IF NOT EXISTS Guardians (
                    Id INTEGER PRIMARY KEY AUTOINCREMENT,
                    FullName TEXT NOT NULL,
                    PhoneNumber TEXT,
                    StudentNumber TEXT NOT NULL,
                    FOREIGN KEY(StudentNumber) REFERENCES Students(StudentNumber) ON DELETE CASCADE
                );

                -- Ã–ÄŸrenci bilgileri tablosu
                -- StudentNumber UNIQUE index (merge ve arama iÃ§in zorunlu)
                CREATE TABLE IF NOT EXISTS Students (
                    StudentNumber TEXT PRIMARY KEY,
                    FirstName TEXT NOT NULL,
                    LastName TEXT NOT NULL,
                    Class TEXT,
                    ClassNo INTEGER,
                    TcNo TEXT,
                    BirthDate TEXT,
                    PhotoPath TEXT,
                    GuardianId INTEGER,
                    FOREIGN KEY(GuardianId) REFERENCES Guardians(Id) ON DELETE CASCADE
                );

                -- TakÄ±m bilgileri tablosu (Category alanÄ± eklendi)
                CREATE TABLE IF NOT EXISTS Teams (
                    Id INTEGER PRIMARY KEY AUTOINCREMENT,
                    TeamName TEXT NOT NULL UNIQUE,
                    Category TEXT NOT NULL,
                    MatchDate TEXT,
                    Description TEXT
                );

                -- TakÄ±m-Ã–ÄŸrenci iliÅŸki tablosu
                -- StudentNumber ile iliÅŸki kurulur (StudentId deÄŸil)
                -- Bir Ã¶ÄŸrenci birden fazla takÄ±mda olamaz (UNIQUE StudentNumber constraint)
                CREATE TABLE IF NOT EXISTS TeamMembers (
                    Id INTEGER PRIMARY KEY AUTOINCREMENT,
                    TeamId INTEGER NOT NULL,
                    StudentNumber TEXT NOT NULL,
                    AddedDate TEXT NOT NULL,
                    UNIQUE(StudentNumber),
                    UNIQUE(TeamId, StudentNumber),
                    FOREIGN KEY(TeamId) REFERENCES Teams(Id) ON DELETE CASCADE,
                    FOREIGN KEY(StudentNumber) REFERENCES Students(StudentNumber) ON DELETE CASCADE
                );

                -- Favori Ã¶ÄŸrenciler tablosu
                CREATE TABLE IF NOT EXISTS Favorites (
                    Id INTEGER PRIMARY KEY AUTOINCREMENT,
                    StudentNumber TEXT NOT NULL UNIQUE,
                    AddedDate TEXT NOT NULL,
                    FOREIGN KEY(StudentNumber) REFERENCES Students(StudentNumber) ON DELETE CASCADE
                );

                -- Ayarlar tablosu (PIN vb.)
                CREATE TABLE IF NOT EXISTS Settings (
                    Id INTEGER PRIMARY KEY AUTOINCREMENT,
                    Key TEXT NOT NULL UNIQUE,
                    Value TEXT NOT NULL
                );
            ";

            cmd.ExecuteNonQuery();
        }

        /// <summary>
        /// Performans iÃ§in index'leri oluÅŸturur.
        /// Ä°STEM METNÄ° GEREÄÄ° ZORUNLU INDEX'LER.
        /// </summary>
        private static void CreateIndexes(SqliteConnection conn)
        {
            using var cmd = conn.CreateCommand();
            cmd.CommandText = @"
                -- Students.StudentNumber â†’ UNIQUE index (zaten PRIMARY KEY olduÄŸu iÃ§in otomatik)
                
                -- Students.Class â†’ Non-unique index (sÄ±nÄ±f filtreleme iÃ§in)
                CREATE INDEX IF NOT EXISTS idx_students_class ON Students(Class);

                -- TeamMembers.TeamId â†’ Index (takÄ±m listeleme iÃ§in)
                CREATE INDEX IF NOT EXISTS idx_teammembers_teamid ON TeamMembers(TeamId);

                -- TeamMembers (TeamId + StudentNumber) â†’ UNIQUE composite index (zaten UNIQUE constraint'te var)
            ";

            cmd.ExecuteNonQuery();
        }

        /// <summary>
        /// Mevcut veritabanlarÄ± iÃ§in ÅŸemayÄ± gÃ¼nceller (yeni sÃ¼tunlar ekler).
        /// </summary>
        private static void EnsureSchemaUpToDate(SqliteConnection conn)
        {
            try
            {
                // Teams tablosuna Category sÃ¼tunu ekle (yoksa)
                using var cmd = conn.CreateCommand();
                cmd.CommandText = "PRAGMA table_info(Teams);";
                
                using var reader = cmd.ExecuteReader();
                bool hasCategory = false;
                while (reader.Read())
                {
                    var name = reader.GetString(1);
                    if (name.Equals("Category", StringComparison.OrdinalIgnoreCase))
                    {
                        hasCategory = true;
                        break;
                    }
                }
                reader.Close();

                if (!hasCategory)
                {
                    using var alterCmd = conn.CreateCommand();
                    alterCmd.CommandText = "ALTER TABLE Teams ADD COLUMN Category TEXT NOT NULL DEFAULT 'Futbol';";
                    alterCmd.ExecuteNonQuery();
                }

                // Index'leri yeniden oluÅŸtur
                CreateIndexes(conn);
            }
            catch
            {
                // Åema gÃ¼ncelleme hatalarÄ±nÄ± sessizce yoksay
            }
        }

        /// <summary>
        /// Repository'ler tarafÄ±ndan kullanÄ±lacak yeni bir SqliteConnection dÃ¶ndÃ¼rÃ¼r.
        /// Ã‡aÄŸÄ±ran taraf baÄŸlantÄ±yÄ± Open() etmelidir.
        /// </summary>
        public static SqliteConnection GetConnection()
        {
            return new SqliteConnection(_connectionString);
        }

        /// <summary>
        /// DB dosyasÄ±nÄ±n yolunu dÃ¶ndÃ¼rÃ¼r (tanÄ±lama/loglama iÃ§in kullanÄ±ÅŸlÄ±).
        /// </summary>
        public static string GetDatabasePath() => _dbPath;

        /// <summary>
        /// FotoÄŸraf klasÃ¶rÃ¼nÃ¼n yolunu dÃ¶ndÃ¼rÃ¼r.
        /// </summary>
        public static string GetPhotosFolder() => Path.Combine(_appFolder, "Photos");

        /// <summary>
        /// Log klasÃ¶rÃ¼nÃ¼n yolunu dÃ¶ndÃ¼rÃ¼r.
        /// </summary>
        public static string GetLogsFolder() => Path.Combine(_appFolder, "Logs");`r`n`r`n        /// <summary>`r`n        /// PDF klasörünün yolunu döndürür (geçici PDF dosyaları için).`r`n        /// </summary>`r`n        public static string GetPdfFolder() => Path.Combine(_appFolder, "PDFs");

        /// <summary>
        /// TÃ¼m veritabanÄ±nÄ± ve fotoÄŸraf klasÃ¶rÃ¼nÃ¼ siler (SÄ°STEMÄ° SIFIRLA fonksiyonu iÃ§in).
        /// PIN verisi korunur (Settings tablosundan sadece PIN silinmez).
        /// </summary>
        public static void ResetDatabase()
        {
            try
            {
                using var conn = GetConnection();
                conn.Open();

                using var cmd = conn.CreateCommand();
                
                // PIN hariÃ§ tÃ¼m verileri sil
                cmd.CommandText = @"
                    DELETE FROM TeamMembers;
                    DELETE FROM Teams;
                    DELETE FROM Favorites;
                    DELETE FROM Students;
                    DELETE FROM Guardians;
                    DELETE FROM Settings WHERE Key != 'PIN';
                ";
                cmd.ExecuteNonQuery();

                // FotoÄŸraf klasÃ¶rÃ¼nÃ¼ temizle
                var photosFolder = GetPhotosFolder();
                if (Directory.Exists(photosFolder))
                {
                    foreach (var file in Directory.GetFiles(photosFolder))
                    {
                        File.Delete(file);
                    }
                }
            }
            catch (Exception ex)
            {
                throw new Exception($"VeritabanÄ± sÄ±fÄ±rlama hatasÄ±: {ex.Message}", ex);
            }
        }
    }
