<Window x:Class="AlparslanOBS.Views.CreateTeamWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Yeni Takım Oluştur" Height="250" Width="300"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent">

    <Border Background="White" CornerRadius="10" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.2"/>
        </Border.Effect>

        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="YENİ TAKIM OLUŞTUR" FontWeight="Bold" FontSize="14" Foreground="#333" HorizontalAlignment="Center" Margin="0,0,0,15"/>

            <TextBlock Grid.Row="1" Text="Takım Adı (Zorunlu):" Foreground="Gray" FontSize="12" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtTeamName" Grid.Row="2" Height="28" Padding="5" Margin="0,0,0,10" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="3" Text="Açıklama / Kategori:" Foreground="Gray" FontSize="12" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtDescription" Grid.Row="4" Height="28" Padding="5" Margin="0,0,0,15" VerticalContentAlignment="Center"/>

            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                <Button Content="İptal" Width="70" Height="28" Margin="0,0,10,0" Background="#F5F5F5" BorderThickness="0" Cursor="Hand" Click="BtnCancel_Click"/>
                <Button Content="Kaydet" Width="70" Height="28" Background="#4CAF50" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnSave_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>