using System;
using System.Collections.Generic;
using AlparslanOBS.Models;
using Microsoft.Data.Sqlite;

namespace AlparslanOBS.DataAccess
{
    /// <summary>
    /// Favorites tablosu ile ilgili veritabanı işlemlerini yürütür.
    /// İSTEM METNİ GEREĞİ: Favoriler kalıcı saklanır, uygulama kapansa da kaybolmaz.
    /// </summary>
    public class FavoriteRepository
    {
        /// <summary>
        /// Öğrenciyi favorilere ekler.
        /// Duplicate kontrolü yapılır (UNIQUE constraint).
        /// </summary>
        public void AddFavorite(string studentNumber)
        {
            using var conn = DatabaseConnection.GetConnection();
            conn.Open();

            using var cmd = conn.CreateCommand();
            cmd.CommandText = @"
                INSERT OR IGNORE INTO Favorites (StudentNumber, AddedDate) 
                VALUES (@StudentNumber, @AddedDate)
            ";
            cmd.Parameters.AddWithValue("@StudentNumber", studentNumber);
            cmd.Parameters.AddWithValue("@AddedDate", DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss"));
            cmd.ExecuteNonQuery();
        }

        /// <summary>
        /// Öğrenciyi favorilerden çıkarır.
        /// </summary>
        public void RemoveFavorite(string studentNumber)
        {
            using var conn = DatabaseConnection.GetConnection();
            conn.Open();

            using var cmd = conn.CreateCommand();
            cmd.CommandText = "DELETE FROM Favorites WHERE StudentNumber = @StudentNumber";
            cmd.Parameters.AddWithValue("@StudentNumber", studentNumber);
            cmd.ExecuteNonQuery();
        }

        /// <summary>
        /// Tüm favori öğrenci numaralarını döndürür.
        /// </summary>
        public List<string> GetAllFavoriteStudentNumbers()
        {
            var list = new List<string>();

            using var conn = DatabaseConnection.GetConnection();
            conn.Open();

            using var cmd = conn.CreateCommand();
            cmd.CommandText = "SELECT StudentNumber FROM Favorites ORDER BY AddedDate DESC";

            using var reader = cmd.ExecuteReader();
            while (reader.Read())
            {
                list.Add(reader.GetString(0));
            }

            return list;
        }

        /// <summary>
        /// Öğrencinin favori olup olmadığını kontrol eder.
        /// </summary>
        public bool IsFavorite(string studentNumber)
        {
            using var conn = DatabaseConnection.GetConnection();
            conn.Open();

            using var cmd = conn.CreateCommand();
            cmd.CommandText = "SELECT COUNT(*) FROM Favorites WHERE StudentNumber = @StudentNumber";
            cmd.Parameters.AddWithValue("@StudentNumber", studentNumber);

            var count = Convert.ToInt32(cmd.ExecuteScalar());
            return count > 0;
        }

        /// <summary>
        /// Tüm favorileri siler (Toplu silme özelliği).
        /// </summary>
        public void ClearAllFavorites()
        {
            using var conn = DatabaseConnection.GetConnection();
            conn.Open();

            using var cmd = conn.CreateCommand();
            cmd.CommandText = "DELETE FROM Favorites";
            cmd.ExecuteNonQuery();
        }

        /// <summary>
        /// Toplam favori sayısını döndürür.
        /// </summary>
        public int GetFavoriteCount()
        {
            using var conn = DatabaseConnection.GetConnection();
            conn.Open();

            using var cmd = conn.CreateCommand();
            cmd.CommandText = "SELECT COUNT(*) FROM Favorites";

            return Convert.ToInt32(cmd.ExecuteScalar());
        }
    }
}
