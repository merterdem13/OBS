using System;
using System.Collections.ObjectModel;
using System.ComponentModel;
using System.IO;
using System.Linq;
using System.Runtime.CompilerServices;
using System.Threading.Tasks;
using System.Windows.Data;
using System.Windows.Input;
using Microsoft.Win32;
using AlparslanOBS.Models;
using AlparslanOBS.DataAccess;
using AlparslanOBS.Services;

namespace AlparslanOBS.ViewModels
{
    public class MainViewModel : INotifyPropertyChanged
    {
        private string _searchText = string.Empty;
        private bool _isTeamPanelOpen;

        private readonly StudentRepository _repo;
        private readonly IPdfExtractionService _pdfService;
        private readonly IMergeService _mergeService;

        // Kesin çözüm: Derleyiciye bu değerin null kalmayacağı garantisi verildi (= null!)
        private ICollectionView _studentsView = null!;

        private string _toastMessage = string.Empty;
        private bool _isToastVisible;
        private bool _isToastError;

        public ObservableCollection<Student> Students { get; } = new ObservableCollection<Student>();

        public bool IsTeamPanelOpen
        {
            get => _isTeamPanelOpen;
            set { if (_isTeamPanelOpen != value) { _isTeamPanelOpen = value; OnPropertyChanged(); } }
        }

        public string SearchText
        {
            get => _searchText;
            set { if (_searchText != value) { _searchText = value; OnPropertyChanged(); _studentsView.Refresh(); } }
        }

        public string ToastMessage
        {
            get => _toastMessage;
            set { if (_toastMessage != value) { _toastMessage = value; OnPropertyChanged(); } }
        }

        public bool IsToastVisible
        {
            get => _isToastVisible;
            set { if (_isToastVisible != value) { _isToastVisible = value; OnPropertyChanged(); } }
        }

        public bool IsToastError
        {
            get => _isToastError;
            set { if (_isToastError != value) { _isToastError = value; OnPropertyChanged(); } }
        }

        public ICommand ToggleTeamPanelCommand { get; }
        public ICommand ImportPdfCommand { get; }

        public MainViewModel()
        {
            _repo = new StudentRepository();
            _pdfService = new PdfExtractionService();
            _mergeService = new MergeService();

            ToggleTeamPanelCommand = new RelayCommand(_ => IsTeamPanelOpen = !IsTeamPanelOpen);
            ImportPdfCommand = new RelayCommand(async _ => await ImportPdfAsync());

            _studentsView = CollectionViewSource.GetDefaultView(Students);
            _studentsView.Filter = FilterStudents;

            RefreshStudents();
        }

        // Predicate temsilcisine uyması için object obj parametresi kullanıldı
        private bool FilterStudents(object obj)
        {
            if (string.IsNullOrWhiteSpace(SearchText)) return true;
            if (obj is Student student)
            {
                var search = SearchText.ToLowerInvariant();
                return (student.FirstName?.ToLowerInvariant().Contains(search) == true) ||
                       (student.LastName?.ToLowerInvariant().Contains(search) == true) ||
                       (student.StudentNumber?.ToLowerInvariant().Contains(search) == true);
            }
            return false;
        }

        public void RefreshStudents()
        {
            Students.Clear();
            foreach (var s in _repo.GetAll())
            {
                Students.Add(s);
            }
        }

        private async Task ImportPdfAsync()
        {
            var openFileDialog = new OpenFileDialog
            {
                Filter = "PDF Dosyaları (*.pdf)|*.pdf",
                Title = "PDF Dosyasını Seçin"
            };

            if (openFileDialog.ShowDialog() == true)
            {
                try
                {
                    var pdfType = _pdfService.GetPdfDocumentType(openFileDialog.FileName);
                    switch (pdfType)
                    {
                        case PdfDocumentType.KunyeDefteri:
                            await ImportKunyePdfAsync(openFileDialog.FileName);
                            break;
                        case PdfDocumentType.SinifListesi:
                            await ImportClassListPdfAsync(openFileDialog.FileName);
                            break;
                        case PdfDocumentType.ResimListesi:
                            ImportImageListPdf(openFileDialog.FileName);
                            break;
                        default:
                            ShowToast("PDF başlığı tanınamadı. Lütfen künye veya sınıf listesi PDF'si seçin.", isError: true);
                            break;
                    }
                }
                catch (Exception ex)
                {
                    ShowToast($"Aktarım sırasında hata oluştu: {ex.Message}", isError: true);
                }
                finally
                {
                    _pdfService.CleanupTempFiles();
                }
            }
        }

        private async Task ImportKunyePdfAsync(string filePath)
        {
            var extractedStudents = await Task.Run(() => _pdfService.ExtractStudentsFromKunyePdf(filePath));

            if (extractedStudents == null || !extractedStudents.Any())
            {
                ShowToast("PDF dosyasından hiçbir öğrenci verisi okunamadı.", isError: true);
                return;
            }

            await Task.Run(() => _mergeService.MergeStudents(extractedStudents));
            SaveKunyePdfCopies(filePath, extractedStudents);

            RefreshStudents();
            ShowToast($"{extractedStudents.Count()} öğrencinin künye bilgisi başarıyla işlendi.", isError: false);
        }

        private async Task ImportClassListPdfAsync(string filePath)
        {
            var classInfo = _pdfService.ExtractClassHeader(filePath);
            if (string.IsNullOrWhiteSpace(classInfo))
            {
                ShowToast("Sınıf bilgisi okunamadı.", isError: true);
                return;
            }

            var classListData = await Task.Run(() => _pdfService.ExtractClassList(filePath));
            if (classListData == null || !classListData.Any())
            {
                ShowToast("Sınıf listesi PDF'inden öğrenci numarası okunamadı.", isError: true);
                return;
            }

            await Task.Run(() => _mergeService.MergeClassList(classListData));

            var saved = SaveClassPdf(filePath, classInfo, isImageList: false);
            RefreshStudents();
            ShowToast(saved
                ? $"{classInfo} sınıf listesi başarıyla işlendi."
                : "Sınıf listesi işlendi fakat dosya kaydedilemedi.", isError: !saved);
        }

        private void ImportImageListPdf(string filePath)
        {
            var classInfo = _pdfService.ExtractClassHeader(filePath);
            if (string.IsNullOrWhiteSpace(classInfo))
            {
                ShowToast("Resim listesi için sınıf bilgisi okunamadı.", isError: true);
                return;
            }

            var saved = SaveClassPdf(filePath, classInfo, isImageList: true);
            ShowToast(saved
                ? $"{classInfo} resim listesi kaydedildi."
                : "Resim listesi kaydedilemedi.", isError: !saved);
        }

        private void SaveKunyePdfCopies(string sourcePath, IEnumerable<Student> students)
        {
            var pdfFolder = DatabaseConnection.GetPdfFolder();

            foreach (var student in students)
            {
                var baseName = FileNameHelper.BuildStudentFileName(student.StudentNumber, student.FirstName, student.LastName);
                if (string.IsNullOrWhiteSpace(baseName)) continue;

                var dest = Path.Combine(pdfFolder, $"{baseName}.pdf");
                File.Copy(sourcePath, dest, overwrite: true);
            }
        }

        private bool SaveClassPdf(string sourcePath, string classInfo, bool isImageList)
        {
            var pdfFolder = DatabaseConnection.GetPdfFolder();
            var baseName = FileNameHelper.BuildClassListFileName(classInfo, isImageList);
            if (string.IsNullOrWhiteSpace(baseName)) return false;

            var dest = Path.Combine(pdfFolder, $"{baseName}.pdf");
            File.Copy(sourcePath, dest, overwrite: true);
            return true;
        }

        private async void ShowToast(string message, bool isError)
        {
            ToastMessage = message;
            IsToastError = isError;
            IsToastVisible = true;
            await Task.Delay(3000);
            IsToastVisible = false;
        }

        public event PropertyChangedEventHandler? PropertyChanged;
        protected void OnPropertyChanged([CallerMemberName] string? name = null) => PropertyChanged?.Invoke(this, new PropertyChangedEventArgs(name));
    }

    public class RelayCommand : ICommand
    {
        private readonly Action<object?> _execute;
        private readonly Func<object?, bool>? _canExecute;

        public RelayCommand(Action<object?> execute, Func<object?, bool>? canExecute = null)
        {
            _execute = execute ?? throw new ArgumentNullException(nameof(execute));
            _canExecute = canExecute;
        }

        public bool CanExecute(object? parameter) => _canExecute?.Invoke(parameter) ?? true;
        public void Execute(object? parameter) => _execute(parameter);

        public event EventHandler? CanExecuteChanged
        {
            add { CommandManager.RequerySuggested += value; }
            remove { CommandManager.RequerySuggested -= value; }
        }
    }
}
