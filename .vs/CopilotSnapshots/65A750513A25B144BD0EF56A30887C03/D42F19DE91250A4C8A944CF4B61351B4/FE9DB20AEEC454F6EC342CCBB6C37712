<UserControl x:Class="AlparslanOBS.Views.Components.StudentCardComponent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <Border Background="{StaticResource BgCardBrush}"
            BorderBrush="{StaticResource BorderColorBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Margin="0,0,0,8"
            Cursor="Hand"
            Opacity="0">
        <Border.RenderTransform>
            <TranslateTransform Y="20"/>
        </Border.RenderTransform>
        <Border.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.3">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>
        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid Height="100">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Fotoğraf -->
            <Border Grid.Column="0"
                    CornerRadius="10,0,0,10"
                    ClipToBounds="True"
                    Background="#EDF2F7">
                <Image Source="{Binding PhotoPath}"
                       Stretch="UniformToFill"/>
            </Border>

            <!-- Bilgiler -->
            <Grid Grid.Column="1" Margin="10,8,8,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Ad Soyad + Yıldız -->
                <Grid Grid.Row="0" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding FullName}"
                               FontWeight="SemiBold"
                               FontSize="13"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <ui:Button Grid.Column="1"
                               Appearance="Transparent"
                               Padding="2" Width="24" Height="24"
                               ToolTip="{Binding FavoriteTooltip}"
                               Command="{Binding DataContext.ToggleFavoriteItemCommand,
                                   RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                               CommandParameter="{Binding}">
                        <ui:SymbolIcon FontSize="14">
                            <ui:SymbolIcon.Style>
                                <Style TargetType="ui:SymbolIcon">
                                    <Setter Property="Symbol" Value="Star24"/>
                                    <Setter Property="Filled" Value="False"/>
                                    <Setter Property="Foreground" Value="#CBD5E0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                            <Setter Property="Filled" Value="True"/>
                                            <Setter Property="Foreground" Value="#F6AD55"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:SymbolIcon.Style>
                        </ui:SymbolIcon>
                    </ui:Button>
                </Grid>

                <!-- No + Sınıf -->
                <Grid Grid.Row="1" Margin="0,0,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="No: "
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11"/>
                        <TextBlock Text="{Binding StudentNumber}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBlock Text="Sınıf: "
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11"/>
                        <TextBlock Text="{Binding Class}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                </Grid>

                <!-- Doğum Tarihi -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,2">
                    <TextBlock Text="Doğum: "
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"/>
                    <TextBlock Text="{Binding BirthDateString}"
                               FontSize="11"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                </StackPanel>

                <!-- PDF Butonu -->
                <ui:Button Grid.Row="3"
                           Appearance="Danger"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Bottom"
                           Padding="10,3" FontSize="10"
                           ToolTip="Öğrenci Künyesi PDF"
                           Command="{Binding DataContext.ExportStudentPdfCommand,
                               RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                           CommandParameter="{Binding}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Document24" FontSize="11" Margin="0,0,3,0"/>
                        <TextBlock Text="PDF" FontSize="10" FontWeight="SemiBold"/>
                    </StackPanel>
                </ui:Button>
            </Grid>
        </Grid>
    </Border>
</UserControl>
