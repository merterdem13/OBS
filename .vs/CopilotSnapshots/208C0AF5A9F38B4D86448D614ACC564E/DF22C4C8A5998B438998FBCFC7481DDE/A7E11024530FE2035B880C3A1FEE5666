<ui:FluentWindow x:Class="AlparslanOBS.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:converters="clr-namespace:AlparslanOBS.Converters"
    mc:Ignorable="d"
    Title="Alparslan OBS"
    Width="400" Height="750"
    MinWidth="400" MinHeight="750"
    ResizeMode="CanMinimize"
    WindowStartupLocation="CenterScreen"
    Topmost="{Binding IsTopmost}"
    ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════
             SATIR 0 — Özel Başlık Çubuğu (Marka + Eylemler)
        ════════════════════════════════════════════════════ -->
        <ui:TitleBar Grid.Row="0"
                     ShowMaximize="False">
            <ui:TitleBar.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0,0,0">
                    <TextBlock Text="&#x1F3EB;" FontSize="20" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Alparslan Ortaokulu"
                               FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </ui:TitleBar.Header>
            <ui:TitleBar.TrailingContent>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,4,0">
                    <ui:Button Appearance="Transparent" Padding="6,4"
                               ToolTip="Favori Modunu Ac/Kapat"
                               Command="{Binding ToggleFavoriteCommand}">
                        <ui:SymbolIcon Symbol="Star24" FontSize="18"/>
                    </ui:Button>
                    <ui:Button Appearance="Transparent" Padding="6,4"
                               ToolTip="Yonetim Paneli"
                               Command="{Binding ToggleSettingsCommand}">
                        <ui:SymbolIcon Symbol="Settings24" FontSize="18"/>
                    </ui:Button>
                </StackPanel>
            </ui:TitleBar.TrailingContent>
        </ui:TitleBar>

        <!-- ═══════════════════════════════════════════════════
             SATIR 1 — Arama + Filtre + Sınıf Eylemleri
        ════════════════════════════════════════════════════ -->
        <StackPanel Grid.Row="1" Margin="12,8,12,6">

            <!-- Arama -->
            <ui:TextBox PlaceholderText="Ogrenci Ara (Ad, No)..."
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                        Margin="0,0,0,8">
                <ui:TextBox.Icon>
                    <ui:SymbolIcon Symbol="Search24"/>
                </ui:TextBox.Icon>
            </ui:TextBox>

            <!-- Filtre Satırı -->
            <Grid Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding ClassList}"
                          SelectedItem="{Binding SelectedClass}"
                          Height="32"
                          VerticalContentAlignment="Center">
                    <ComboBox.Style>
                        <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedClass}" Value="{x:Null}">
                                    <Setter Property="Text" Value="Sinif Seciniz..."/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ComboBox.Style>
                </ComboBox>

                <ui:Button Grid.Column="1"
                           Appearance="Danger"
                           Padding="8,4" Margin="6,0,0,0"
                           ToolTip="Favorileri Temizle"
                           Command="{Binding ClearAllFavoritesCommand}"
                           Visibility="{Binding IsFavoriteMode, Converter={StaticResource BoolToVisibility}}">
                    <ui:SymbolIcon Symbol="Delete24" FontSize="16"/>
                </ui:Button>
            </Grid>

            <!-- Sinif Eylemleri (sinif secilince gorunur) -->
            <UniformGrid Columns="3" Margin="0,8,0,0"
                         Visibility="{Binding IsClassSelected, Converter={StaticResource BoolToVisibility}}">
                <ui:Button Content="Sinif Listesi"
                           Appearance="Primary"
                           Margin="0,0,3,0" Padding="4,6"
                           FontSize="11"
                           Command="{Binding PrintClassListCommand}"/>
                <ui:Button Content="Fotograf Listesi"
                           Appearance="Secondary"
                           Margin="3,0,3,0" Padding="4,6"
                           FontSize="11"
                           Command="{Binding PrintPhotoListCommand}"/>
                <ui:Button Content="Excel Aktar"
                           Appearance="Success"
                           Margin="3,0,0,0" Padding="4,6"
                           FontSize="11"
                           Command="{Binding ExportExcelCommand}"/>
            </UniformGrid>
        </StackPanel>

        <!-- ═══════════════════════════════════════════════════
             SATIR 2 — Öğrenci Kartları (Kaydırılabilir Liste)
        ════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      Padding="12,4,12,4">
            <ItemsControl ItemsSource="{Binding Students}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>

                        <!-- Öğrenci Kartı -->
                        <Border Background="{StaticResource BgCardBrush}"
                                BorderBrush="{StaticResource BorderColorBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Margin="0,0,0,8"
                                Cursor="Hand">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <Grid Height="100">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Fotoğraf -->
                                <Border Grid.Column="0"
                                        CornerRadius="10,0,0,10"
                                        ClipToBounds="True"
                                        Background="#EDF2F7">
                                    <Image Source="{Binding PhotoPath}"
                                           Stretch="UniformToFill"/>
                                </Border>

                                <!-- Bilgiler -->
                                <Grid Grid.Column="1" Margin="10,8,8,8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Ad Soyad + Yıldız -->
                                    <Grid Grid.Row="0" Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding FullName}"
                                                   FontWeight="SemiBold"
                                                   FontSize="13"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <ui:Button Grid.Column="1"
                                                   Appearance="Transparent"
                                                   Padding="2" Width="24" Height="24"
                                                   ToolTip="{Binding FavoriteTooltip}"
                                                   Command="{Binding DataContext.ToggleFavoriteItemCommand,
                                                       RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                   CommandParameter="{Binding}">
                                            <ui:SymbolIcon FontSize="14">
                                                <ui:SymbolIcon.Style>
                                                    <Style TargetType="ui:SymbolIcon">
                                                                    <Setter Property="Symbol" Value="Star24"/>
                                                                    <Setter Property="Filled" Value="False"/>
                                                                    <Setter Property="Foreground" Value="#CBD5E0"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                                            <Setter Property="Filled" Value="True"/>
                                                                            <Setter Property="Foreground" Value="#F6AD55"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                </ui:SymbolIcon.Style>
                                            </ui:SymbolIcon>
                                        </ui:Button>
                                    </Grid>

                                    <!-- No + Sınıf -->
                                    <Grid Grid.Row="1" Margin="0,0,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <TextBlock Text="No: "
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="11"/>
                                            <TextBlock Text="{Binding StudentNumber}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock Text="Sinif: "
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="11"/>
                                            <TextBlock Text="{Binding Class}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Doğum Tarihi -->
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,2">
                                        <TextBlock Text="Dogum: "
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="11"/>
                                        <TextBlock Text="{Binding BirthDateString}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                    </StackPanel>

                                    <!-- PDF Butonu -->
                                    <ui:Button Grid.Row="3"
                                               Appearance="Danger"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Bottom"
                                               Padding="10,3" FontSize="10"
                                               ToolTip="Ogrenci Kunyesi PDF"
                                               Command="{Binding DataContext.ExportStudentPdfCommand,
                                                   RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                               CommandParameter="{Binding}">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Document24" FontSize="11" Margin="0,0,3,0"/>
                                            <TextBlock Text="PDF" FontSize="10" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </ui:Button>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ═══════════════════════════════════════════════════
             SATIR 3 — Alt Yonetim Paneli (Açılır/Kapanır)
        ════════════════════════════════════════════════════ -->
        <Border Grid.Row="3"
                Background="{StaticResource BgCardBrush}"
                BorderBrush="{StaticResource BorderColorBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,12,16,16"
                Visibility="{Binding IsSettingsPanelVisible, Converter={StaticResource BoolToVisibility}}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" Opacity="0.12" Direction="90" ShadowDepth="4"/>
            </Border.Effect>
            <StackPanel>

                <!-- Başlık + Kapat -->
                <Grid Margin="0,0,0,12">
                    <TextBlock Text="Yonetim Paneli"
                               FontSize="15" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <ui:Button HorizontalAlignment="Right"
                               Appearance="Transparent" Padding="4"
                               Command="{Binding CloseSettingsPanelCommand}">
                        <ui:SymbolIcon Symbol="Dismiss24" FontSize="16"/>
                    </ui:Button>
                </Grid>

                <!-- İstatistikler -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Background="{StaticResource BgBodyBrush}"
                            BorderBrush="{StaticResource BorderColorBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="10">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding TotalStudentCount}"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontSize="22" FontWeight="ExtraBold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="OGRENCI"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="10" FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2"
                            Background="{StaticResource BgBodyBrush}"
                            BorderBrush="{StaticResource BorderColorBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="10">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding TotalClassCount}"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontSize="22" FontWeight="ExtraBold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="SINIF"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="10" FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Veri Aktarımı -->
                <TextBlock Text="VERI AKTARIMI"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="10" FontWeight="ExtraBold"
                           Margin="2,0,0,8"/>
                <ui:Button Content="Kunye PDF Yukle"
                           Appearance="Primary" Margin="0,0,0,6" Padding="12,8"
                           HorizontalAlignment="Stretch"
                           Command="{Binding ImportKunyePdfCommand}"/>
                <ui:Button Content="Sinif Listesi PDF Yukle"
                           Appearance="Secondary" Margin="0,0,0,6" Padding="12,8"
                           HorizontalAlignment="Stretch"
                           Command="{Binding ImportClassListPdfCommand}"/>
                <ui:Button Content="Fotograf Listesi PDF Yukle"
                           Appearance="Caution" Margin="0,0,0,6" Padding="12,8"
                           HorizontalAlignment="Stretch"
                           Command="{Binding ImportPhotoListPdfCommand}"/>
                <ui:Button Content="Veli NO Excel Yukle"
                           Appearance="Success" Margin="0,0,0,12" Padding="12,8"
                           HorizontalAlignment="Stretch"
                           Command="{Binding ImportGuardianExcelCommand}"/>

                <!-- Güvenlik -->
                <TextBlock Text="GUVENLIK VE BAKIM"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="10" FontWeight="ExtraBold"
                           Margin="2,0,0,8"/>
                <ui:Button Content="Sistemi Sifirla"
                           Appearance="Danger" Padding="12,8"
                           HorizontalAlignment="Stretch"
                           Command="{Binding ResetSystemCommand}"/>
            </StackPanel>
        </Border>

        <!-- Yükleme Katmanı (Panel Z-Index) -->
        <Grid Grid.RowSpan="4"
              Background="#E6FFFFFF"
              Panel.ZIndex="200"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ui:ProgressRing IsIndeterminate="True" Width="48" Height="48"
                                 Foreground="{StaticResource AccentBrush}"/>
                <TextBlock Text="Islem yapiliyor..."
                           FontSize="14" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,12,0,4"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <ProgressBar Value="{Binding LoadingProgress}"
                             Width="220" Height="6" Margin="0,4"
                             Foreground="{StaticResource AccentBrush}"/>
                <TextBlock Text="{Binding LoadingProgressText}"
                           FontSize="12" FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource AccentBrush}"/>
            </StackPanel>
        </Grid>

    </Grid>
</ui:FluentWindow>
