<ui:FluentWindow x:Class="AlparslanOBS.Views.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    mc:Ignorable="d"
    Title="Giriş"
    Width="400" Height="750"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    Topmost="True"
    ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.InputBindings>
        <KeyBinding Key="Enter"    Command="{Binding ConfirmCommand}"/>
        <KeyBinding Key="Back"     Command="{Binding DeleteCommand}"/>
        <KeyBinding Key="D0"       Command="{Binding NumpadCommand}" CommandParameter="0"/>
        <KeyBinding Key="D1"       Command="{Binding NumpadCommand}" CommandParameter="1"/>
        <KeyBinding Key="D2"       Command="{Binding NumpadCommand}" CommandParameter="2"/>
        <KeyBinding Key="D3"       Command="{Binding NumpadCommand}" CommandParameter="3"/>
        <KeyBinding Key="D4"       Command="{Binding NumpadCommand}" CommandParameter="4"/>
        <KeyBinding Key="D5"       Command="{Binding NumpadCommand}" CommandParameter="5"/>
        <KeyBinding Key="D6"       Command="{Binding NumpadCommand}" CommandParameter="6"/>
        <KeyBinding Key="D7"       Command="{Binding NumpadCommand}" CommandParameter="7"/>
        <KeyBinding Key="D8"       Command="{Binding NumpadCommand}" CommandParameter="8"/>
        <KeyBinding Key="D9"       Command="{Binding NumpadCommand}" CommandParameter="9"/>
        <KeyBinding Key="NumPad0"  Command="{Binding NumpadCommand}" CommandParameter="0"/>
        <KeyBinding Key="NumPad1"  Command="{Binding NumpadCommand}" CommandParameter="1"/>
        <KeyBinding Key="NumPad2"  Command="{Binding NumpadCommand}" CommandParameter="2"/>
        <KeyBinding Key="NumPad3"  Command="{Binding NumpadCommand}" CommandParameter="3"/>
        <KeyBinding Key="NumPad4"  Command="{Binding NumpadCommand}" CommandParameter="4"/>
        <KeyBinding Key="NumPad5"  Command="{Binding NumpadCommand}" CommandParameter="5"/>
        <KeyBinding Key="NumPad6"  Command="{Binding NumpadCommand}" CommandParameter="6"/>
        <KeyBinding Key="NumPad7"  Command="{Binding NumpadCommand}" CommandParameter="7"/>
        <KeyBinding Key="NumPad8"  Command="{Binding NumpadCommand}" CommandParameter="8"/>
        <KeyBinding Key="NumPad9"  Command="{Binding NumpadCommand}" CommandParameter="9"/>
    </ui:FluentWindow.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <ui:TitleBar Grid.Row="0"
                     Title="Alparslan OBS"
                     ShowMaximize="False"
                     ShowMinimize="False"/>

        <!-- Content -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="3*"/>
            </Grid.RowDefinitions>

            <!-- Top: Icon + Title + PIN Display -->
            <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="24,0">

                <!-- Lock Icon Circle -->
                <Border Width="84" Height="84" CornerRadius="42"
                        Background="{StaticResource AccentBrush}"
                        HorizontalAlignment="Center" Margin="0,0,0,20">
                    <ui:SymbolIcon Symbol="LockClosed24" FontSize="38"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                </Border>

                <!-- Mode Title -->
                <TextBlock Text="{Binding TitleMessage}"
                           FontSize="18" FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="0,0,0,28"/>

                <!-- PIN Dots -->
                <TextBlock Text="{Binding PinDisplay}"
                           FontSize="46" FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource AccentBrush}"
                           Margin="0,0,0,10"/>

                <!-- Error Message -->
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#ef4444"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           MinHeight="20"/>
            </StackPanel>

            <!-- Numpad -->
            <Grid Grid.Row="2" Margin="20,10,20,32" VerticalAlignment="Bottom">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ui:Button Grid.Row="0" Grid.Column="0" Content="1"
                           FontSize="26" FontWeight="SemiBold" Appearance="Secondary"
                           Margin="4" HorizontalAlignment="Stretch"
                           Command="{Binding NumpadCommand}" CommandParameter="1"/>
                <ui:Button Grid.Row="0" Grid.Column="1" Content="2"
                           FontSize="26" FontWeight="SemiBold" Appearance="Secondary"
                           Margin="4" HorizontalAlignment="Stretch"
                           Command="{Binding NumpadCommand}" CommandParameter="2"/>
                <ui:Button Grid.Row="0" Grid.Column="2" Content="3"
                           FontSize="26" FontWeight="SemiBold" Appearance="Secondary"
                           Margin="4" HorizontalAlignment="Stretch"
                           Command="{Binding NumpadCommand}" CommandParameter="3"/>

                <ui:Button Grid.Row="1" Grid.Column="0" Content="4"
                           FontSize="26" FontWeight="SemiBold" Appearance="Secondary"
                           Margin="4" HorizontalAlignment="Stretch"
                           Command="{Binding NumpadCommand}" CommandParameter="4"/>
                <ui:Button Grid.Row="1" Grid.Column="1" Content="5"
                           FontSize="26" FontWeight="SemiBold" Appearance="Secondary"
                           Margin="4" HorizontalAlignment="Stretch"
                           Command="{Binding NumpadCommand}" CommandParameter="5"/>
                <ui:Button Grid.Row="1" Grid.Column="2" Content="6"
                           FontSize="26" FontWeight="SemiBold" Appearance="Secondary"
                           Margin="4" HorizontalAlignment="Stretch"
                           Command="{Binding NumpadCommand}" CommandParameter="6"/>

                <ui:Button Grid.Row="2" Grid.Column="0" Content="7"
                           FontSize="26" FontWeight="SemiBold" Appearance="Secondary"
                           Margin="4" HorizontalAlignment="Stretch"
                           Command="{Binding NumpadCommand}" CommandParameter="7"/>
                <ui:Button Grid.Row="2" Grid.Column="1" Content="8"
                           FontSize="26" FontWeight="SemiBold" Appearance="Secondary"
                           Margin="4" HorizontalAlignment="Stretch"
                           Command="{Binding NumpadCommand}" CommandParameter="8"/>
                <ui:Button Grid.Row="2" Grid.Column="2" Content="9"
                           FontSize="26" FontWeight="SemiBold" Appearance="Secondary"
                           Margin="4" HorizontalAlignment="Stretch"
                           Command="{Binding NumpadCommand}" CommandParameter="9"/>

                <!-- Row 4: empty | 0 | backspace -->
                <ui:Button Grid.Row="3" Grid.Column="1" Content="0"
                           FontSize="26" FontWeight="SemiBold" Appearance="Secondary"
                           Margin="4" HorizontalAlignment="Stretch"
                           Command="{Binding NumpadCommand}" CommandParameter="0"/>
                <ui:Button Grid.Row="3" Grid.Column="2"
                           Appearance="Caution" Margin="4" HorizontalAlignment="Stretch"
                           Command="{Binding DeleteCommand}">
                    <ui:SymbolIcon Symbol="Backspace24" FontSize="22"/>
                </ui:Button>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
    
    <!--
        LOGIN WINDOW (PIN SİSTEMİ - Modül)
        İSTEM METNİ GEREĞİ:
        - 4 haneli PIN ekranı
        - Numpad (ekrandaki tuş takımı)
        - Klavye üst sıra sayılar (1-9, 0)
        - Enter ile doğrulama
        - İlk açılışta PIN oluşturma
        - admin.reset dosyası ile sıfırlama
    -->
    
    <Border Background="White" 
            CornerRadius="10" 
            Margin="10"
            BorderBrush="#BDC3C7"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" 
                            ShadowDepth="3" 
                            Opacity="0.3"
                            Color="#2C3E50"/>
        </Border.Effect>

        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Logo -->
                <RowDefinition Height="Auto"/>  <!-- Başlık -->
                <RowDefinition Height="Auto"/>  <!-- PIN Display -->
                <RowDefinition Height="Auto"/>  <!-- Hata Mesajı -->
                <RowDefinition Height="*"/>     <!-- Numpad -->
            </Grid.RowDefinitions>

            <!-- Logo/İkon -->
            <Viewbox Grid.Row="0" 
                     Width="60" 
                     Height="60" 
                     Margin="0,10,0,20">
                <Canvas Width="24" Height="24">
                    <!-- Kilit ikonu -->
                    <Path Fill="#2C3E50" 
                          Data="M12,17 C10.9,17 10,16.1 10,15 C10,13.9 10.9,13 12,13 C13.1,13 14,13.9 14,15 C14,16.1 13.1,17 12,17 M18,8 C19.1,8 20,8.9 20,10 L20,20 C20,21.1 19.1,22 18,22 L6,22 C4.9,22 4,21.1 4,20 L4,10 C4,8.9 4.9,8 6,8 L7,8 L7,6 C7,3.2 9.2,1 12,1 C14.8,1 17,3.2 17,6 L17,8 L18,8 M12,3 C10.3,3 9,4.3 9,6 L9,8 L15,8 L15,6 C15,4.3 13.7,3 12,3 Z"/>
                </Canvas>
            </Viewbox>

            <!-- Başlık Mesajı -->
            <TextBlock Grid.Row="1" 
                       Text="{Binding TitleMessage}" 
                       TextAlignment="Center"
                       FontWeight="Bold" 
                       FontSize="18" 
                       Foreground="#2C3E50" 
                       Margin="0,0,0,25"/>

            <!-- PIN Display (●●●●) -->
            <TextBlock Grid.Row="2" 
                       Text="{Binding PinDisplay}" 
                       TextAlignment="Center"
                       FontSize="48" 
                       FontWeight="Bold"
                       Foreground="#3498DB" 
                       Margin="0,0,0,10" 
                       Height="60"
                       VerticalAlignment="Center"/>

            <!-- Hata Mesajı -->
            <TextBlock Grid.Row="3" 
                       Text="{Binding ErrorMessage}" 
                       Foreground="#E74C3C"
                       FontSize="12"
                       TextAlignment="Center"
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,15"
                       MinHeight="20"/>

            <!-- Numpad (3x4 Grid) -->
            <UniformGrid Grid.Row="4" 
                         Columns="3" 
                         Rows="4" 
                         Margin="0,10,0,0">
                <UniformGrid.Resources>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#ECF0F1"/>
                        <Setter Property="Foreground" Value="#2C3E50"/>
                        <Setter Property="FontSize" Value="28"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Margin" Value="5"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="8"
                                            Padding="10">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#BDC3C7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#95A5A6"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </UniformGrid.Resources>

                <!-- Row 1 -->
                <Button Content="1" Command="{Binding NumpadCommand}" CommandParameter="1"/>
                <Button Content="2" Command="{Binding NumpadCommand}" CommandParameter="2"/>
                <Button Content="3" Command="{Binding NumpadCommand}" CommandParameter="3"/>

                <!-- Row 2 -->
                <Button Content="4" Command="{Binding NumpadCommand}" CommandParameter="4"/>
                <Button Content="5" Command="{Binding NumpadCommand}" CommandParameter="5"/>
                <Button Content="6" Command="{Binding NumpadCommand}" CommandParameter="6"/>

                <!-- Row 3 -->
                <Button Content="7" Command="{Binding NumpadCommand}" CommandParameter="7"/>
                <Button Content="8" Command="{Binding NumpadCommand}" CommandParameter="8"/>
                <Button Content="9" Command="{Binding NumpadCommand}" CommandParameter="9"/>

                <!-- Row 4 -->
                <Border/> <!-- Boş alan -->
                <Button Content="0" Command="{Binding NumpadCommand}" CommandParameter="0"/>
                <Button Content="⌫" 
                        Command="{Binding DeleteCommand}" 
                        Foreground="#E74C3C"
                        FontSize="24"/>
            </UniformGrid>
        </Grid>
    </Border>
</Window>
