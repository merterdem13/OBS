using System.Windows;
using System.Windows.Input;
using AlparslanOBS.ViewModels;

namespace AlparslanOBS.Views
{
    /// <summary>
    /// Login penceresi - PIN doğrulama ve oluşturma.
    /// İSTEM METNİ GEREĞİ:
    /// - 4 haneli PIN ekranı
    /// - Numpad + klavye desteği (1-9, 0, Enter)
    /// - İlk açılışta PIN oluşturma
    /// - admin.reset dosyası ile sıfırlama
    /// </summary>
    public partial class LoginWindow : Window
    {
        private readonly LoginViewModel _viewModel;

        public LoginWindow()
        {
            InitializeComponent();
            
            _viewModel = new LoginViewModel();
            DataContext = _viewModel;
        }

        /// <summary>
        /// Klavye tuş basımlarını handle eder.
        /// İSTEM METNİ GEREĞİ: Klavyenin üst sırasındaki sayı tuşları (1-9, 0) + Enter.
        /// </summary>
        private void Window_KeyDown(object sender, KeyEventArgs e)
        {
            _viewModel.HandleKeyPress(e.Key);
        }
    }
}
