        [RelayCommand]
        private void ExportExcel()
        {
            if (string.IsNullOrEmpty(SelectedClass)) return;

            var dialog = new SaveFileDialog
            {
                Title = "Excel Dosyası Kaydet",
                Filter = "CSV Dosyaları|*.csv",
                FileName = $"OgrenciListesi_{SelectedClass}.csv"
            };

            if (dialog.ShowDialog() != true) return;

            try
            {
                var students = _studentRepo.GetByClass(SelectedClass).ToList();
                var lines = new List<string> { "Okul No;Ad;Soyad;Sınıf;Sınıf No;TC No;Doğum Tarihi" };

                foreach (var s in students)
                {
                    lines.Add($"{s.StudentNumber};{s.FirstName};{s.LastName};{s.Class};{s.ClassNo};{s.TcNo};{s.BirthDate?.ToString("dd.MM.yyyy") ?? ""}");
                }

                File.WriteAllLines(dialog.FileName, lines, System.Text.Encoding.UTF8);
                ToastService.ShowSuccess($"{students.Count} öğrenci CSV olarak aktarıldı.");
            }
            catch (Exception ex)
            {
                ToastService.ShowError($"Excel aktarım hatası: {ex.Message}");
            }
        }

        // ── Yardımcı Metotlar ───────────────────────────────────────────────

        public void RefreshStudents()
        {
            var favoriteNumbers = new HashSet<string>(_favoriteRepo.GetAllFavoriteStudentNumbers());
            IEnumerable<Models.Student> rawStudents;

            if (IsFavoriteMode)
            {
                var allStudents = _studentRepo.GetAll().ToList();
                rawStudents = allStudents.Where(s => favoriteNumbers.Contains(s.StudentNumber));
            }
            else if (!string.IsNullOrWhiteSpace(SearchText))
            {
                rawStudents = _studentRepo.Search(SearchText);
            }
            else if (!string.IsNullOrEmpty(SelectedClass))
            {
                rawStudents = _studentRepo.GetByClass(SelectedClass);
            }
            else
            {
                Students.Clear();
                return;
            }

            var viewModels = rawStudents
                .Select(s => new StudentViewModel(s, favoriteNumbers.Contains(s.StudentNumber)))
                .ToList();

            Students = new ObservableCollection<StudentViewModel>(viewModels);
        }

        private void LoadClassList()
        {
            var classes = _studentRepo.GetDistinctClasses();
            ClassList = new ObservableCollection<string>(classes);
            TotalClassCount = classes.Count;
            TotalStudentCount = _studentRepo.GetAll().Count();
        }

        private void UpdateFavoriteState()
        {
            HasFavorites = _favoriteRepo.GetFavoriteCount() > 0;
        }

        private void SetLoading(bool isLoading, string text = "", double progress = 0)
        {
            IsLoading = isLoading;
            LoadingProgressText = isLoading ? text : "%0";
            LoadingProgress = progress;
        }

        private static void OpenFile(string filePath)
        {
            Process.Start(new ProcessStartInfo
            {
                FileName = filePath,
                UseShellExecute = true
            });
        }

        public void ClearAllStudents()
        {
            Students.Clear();
        }
    }
