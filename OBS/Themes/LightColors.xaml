<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Light Theme Colors (Modern & Premium Desert Sand Palette) -->
    <SolidColorBrush x:Key="BgBodyBrush" Color="#F5F5F4"/> <!-- Stone 50: Sıcak, doğal ve ferah arka plan -->
    <SolidColorBrush x:Key="BgCardBrush" Color="#FFFFFF"/> <!-- Beyaz: Kartların arka plandan ayrılması için -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#44403C"/> <!-- Stone 800: Yumuşak ama okunaklı ana metin -->
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#78716C"/> <!-- Stone 600: Zarif ikincil metin -->
    <SolidColorBrush x:Key="BorderColorBrush" Color="#E7E5E4"/> <!-- Stone 200: Hafif ve doğal kenarlıklar -->
    <SolidColorBrush x:Key="AccentBrush" Color="#D97706"/> <!-- Amber: Güçlü, asil ve modern vurgu rengi -->
    <SolidColorBrush x:Key="HeaderBgBrush" Color="#E7E5E4CC"/> <!-- Stone 200 with Opacity: Saydamlaştırılmış şık başlık -->
    <SolidColorBrush x:Key="ModalBgBrush" Color="#F5F5F4EE"/> <!-- Stone 50 with Opacity: Temiz modal arka planı -->

    <!-- Özel Butonlar (Desert Sand Style) -->
    <SolidColorBrush x:Key="NoteIndicatorBrush" Color="#D97706"/> <!-- Light Mode Not Vurgusu (Accent) -->
    <SolidColorBrush x:Key="SpecialButtonBgBrush" Color="#D97706"/>
    <SolidColorBrush x:Key="SpecialButtonHoverBrush" Color="#B45309"/>
    <SolidColorBrush x:Key="SpecialButtonTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TeamLogoBrush" Color="#44403C"/>
</ResourceDictionary>
