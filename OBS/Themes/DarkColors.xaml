<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Dark Theme Colors (Siyah-Gri Tonları - Mavi/Lacivert Yok) -->
    <!-- Arkaplan -->
    <SolidColorBrush x:Key="BgBodyBrush" Color="#121212"/> <!-- Saf koyu gri/siyah (Material Design Dark Base) -->
    <SolidColorBrush x:Key="BgCardBrush" Color="#1e1e1e"/> <!-- Daha açık saf gri (Kartlar ve Modallar için) -->
    <!-- Metinler -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#ffffff"/> <!-- Tam beyaz -->
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#a0a0a0"/> <!-- Nötr gri -->
    <!-- Tasarım Elemanları -->
    <SolidColorBrush x:Key="BorderColorBrush" Color="#2d2d2d"/> <!-- İnce gri kenarlık -->
    <SolidColorBrush x:Key="AccentBrush" Color="#555555"/> <!-- Nötr Vurgu (Mavi yerine orta gri) -->
    <SolidColorBrush x:Key="HeaderBgBrush" Color="#e6121212"/> 
    <SolidColorBrush x:Key="ModalBgBrush" Color="#1e1e1e"/> <!-- Kartlarla aynı gri -->
    
    <!-- Özel Butonlar (Zıtlık için) -->
    <SolidColorBrush x:Key="NoteIndicatorBrush" Color="#3B82F6"/> <!-- Dark Mode Not Vurgusu (Canlı Mavi) -->
    <SolidColorBrush x:Key="SpecialButtonBgBrush" Color="#444444"/> <!-- Biraz daha koyu beyaz (Slate 200) -->
    <SolidColorBrush x:Key="SpecialButtonHoverBrush" Color="#5A5A5A"/> <!-- Hover için biraz daha açık gri -->
    <SolidColorBrush x:Key="SpecialButtonTextBrush" Color="#EDEDED"/>
</ResourceDictionary>
