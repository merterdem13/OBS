<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Alternative Theme Colors (Deep Graphite & Amethyst) -->
    <!-- Arkaplan -->
    <SolidColorBrush x:Key="BgBodyBrush" Color="#212124"/> <!-- Deep Graphite Base -->
    <SolidColorBrush x:Key="BgCardBrush" Color="#2b2b2f"/> <!-- Graphite Card -->
    <!-- Metinler -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#f0f0f0"/> <!-- Bright Off-white -->
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#a1a1aa"/> <!-- Soft Gray Text -->
    <!-- Tasarım Elemanları -->
    <SolidColorBrush x:Key="BorderColorBrush" Color="#3a3a40"/> <!-- Graphite Border -->
    <SolidColorBrush x:Key="AccentBrush" Color="#c084fc"/> <!-- Amethyst Purple Accent -->
    
    <!-- Loading Overlay Fırçaları -->
    <SolidColorBrush x:Key="LoadingAccentBrush" Color="#c084fc"/> 
    <SolidColorBrush x:Key="LoadingProgressTextBrush" Color="#e9d5ff"/>
    <SolidColorBrush x:Key="LoadingBgBrush" Color="#e6212124"/>

    <SolidColorBrush x:Key="HeaderBgBrush" Color="#e6212124"/>
    <SolidColorBrush x:Key="ModalBgBrush" Color="#2b2b2f"/>
    <SolidColorBrush x:Key="TeamLogoBrush" Color="#ffffffff"/>
    
    <!-- Özel Butonlar ve Göstergeler (Koyu Temanın Eksik Kısımları) -->
    <SolidColorBrush x:Key="NoteIndicatorBrush" Color="#c084fc"/> <!-- Purple Note Highlight -->
    <SolidColorBrush x:Key="SpecialButtonBgBrush" Color="#3e3e46"/> <!-- Slate-Graphite Button -->
    <SolidColorBrush x:Key="SpecialButtonHoverBrush" Color="#52525b"/>
    <SolidColorBrush x:Key="SpecialButtonTextBrush" Color="#f8fafc"/>
</ResourceDictionary>
