<ui:FluentWindow x:Class="OBS.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:components="clr-namespace:OBS.Views.Components"
    xmlns:local="clr-namespace:OBS.ViewModels"
    mc:Ignorable="d"
    Title="Öğrenci Bilgi Sistemi"
    Width="400" Height="750"
    MinWidth="400" MinHeight="750"
	MaxWidth="400" MaxHeight="750"
    ResizeMode="NoResize"
    WindowStartupLocation="Manual"
    Topmost="True"
    Icon="pack://application:,,,/Assets/app.ico"
    ExtendsContentIntoTitleBar="True" WindowBackdropType="None"
    Background="{DynamicResource BgBodyBrush}"
    FontFamily="{StaticResource MainFont}"
    TextElement.FontFamily="{StaticResource MainFont}">

    <ui:FluentWindow.InputBindings>
        <KeyBinding Key="F12" Modifiers="Ctrl+Shift" Command="{Binding OpenDeveloperPinOverlayCommand, Source={x:Static local:GlobalState.Instance}}" CommandParameter="Settings"/>
    </ui:FluentWindow.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- SATIR 0 — Başlık Çubuğu -->
        <ui:TitleBar Grid.Row="0" ShowMaximize="False">
            <ui:TitleBar.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0,0,0">
					<Image Width="24" Height="24" Margin="0,0,8,0"
						   VerticalAlignment="Center" Stretch="Uniform"
						   SnapsToDevicePixels="True" UseLayoutRounding="True"
						   RenderOptions.BitmapScalingMode="Fant">
						<Image.Source>
							<BitmapImage UriSource="pack://application:,,,/Assets/app.ico" DecodePixelWidth="24" DecodePixelHeight="24" />
						</Image.Source>
					</Image>
                    <TextBlock Text="Öğrenci Bilgi Sistemi"
                               FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <ContentControl Grid.Row="1" Grid.RowSpan="2" Content="{Binding CurrentView}" Focusable="False" />

        <!-- Ayarlar Katmanı -->
        <components:SettingsOverlay Grid.RowSpan="3" Panel.ZIndex="150" DataContext="{x:Static local:GlobalState.Instance}"/>

        <!-- Yükleme Katmanı -->
        <components:LoadingOverlay Grid.RowSpan="3" Panel.ZIndex="200" DataContext="{x:Static local:GlobalState.Instance}"/>

        <!-- Onay Diyaloğu Katmanı -->
        <components:ConfirmDialogOverlay x:Name="ConfirmDialog" Grid.RowSpan="3" Panel.ZIndex="300" DataContext="{x:Static local:GlobalState.Instance}"/>

        <!-- Kurtarma Kodu Değiştirme Katmanı -->
        <components:ChangeRecoveryPinOverlay Grid.RowSpan="3" Panel.ZIndex="310" DataContext="{x:Static local:GlobalState.Instance}"/>

        <!-- Öğrenci Notları Katmanı -->
        <components:StudentNotesOverlay x:Name="StudentNotesOverlay" Grid.RowSpan="3" Panel.ZIndex="320" DataContext="{x:Static local:GlobalState.Instance}"/>

        <!-- Güncelleme Notları Katmanı -->
        <components:ReleaseNotesOverlay x:Name="ReleaseNotesOverlay" Grid.RowSpan="3" Panel.ZIndex="350" DataContext="{x:Static local:GlobalState.Instance}"/>

        <!-- Geliştirici PIN Katmanı -->
        <components:DeveloperPinOverlay Grid.RowSpan="3" Panel.ZIndex="400" DataContext="{x:Static local:GlobalState.Instance}"/>

    </Grid>
</ui:FluentWindow>
