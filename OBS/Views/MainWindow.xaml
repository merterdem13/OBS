<ui:FluentWindow x:Class="OBS.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:components="clr-namespace:OBS.Views.Components"
    mc:Ignorable="d"
    Title="Öğrenci Bilgi Sistemi"
    Width="400" Height="750"
    MinWidth="400" MinHeight="750"
	MaxWidth="400" MaxHeight="750"
    ResizeMode="NoResize"
    WindowStartupLocation="Manual"
    Topmost="True"
    Icon="pack://application:,,,/Assets/app.ico"
    ExtendsContentIntoTitleBar="True" WindowBackdropType="None"
    Background="{DynamicResource BgBodyBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- SATIR 0 — Başlık Çubuğu -->
        <ui:TitleBar Grid.Row="0" ShowMaximize="False">
            <ui:TitleBar.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0,0,0">
					<Image Width="24" Height="24" Margin="0,0,8,0"
						   VerticalAlignment="Center" Stretch="Uniform"
						   SnapsToDevicePixels="True" UseLayoutRounding="True"
						   RenderOptions.BitmapScalingMode="Fant">
						<Image.Source>
							<BitmapImage UriSource="pack://application:,,,/Assets/app.ico" DecodePixelWidth="24" DecodePixelHeight="24" />
						</Image.Source>
					</Image>
                    <TextBlock Text="Öğrenci Bilgi Sistemi"
                               FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <!-- SATIR 1 — Arama + Filtre + Sınıf Eylemleri -->
        <components:SearchFilterComponent Grid.Row="1"/>

        <!-- SATIR 2 — Öğrenci Listesi -->
        <components:EmptyStateComponent Grid.Row="2"/>

        <ListBox Grid.Row="2"
                 x:Name="StudentListBox"
                 ItemsSource="{Binding Students}"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 VirtualizingPanel.ScrollUnit="Pixel"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.CanContentScroll="True"
                 ScrollViewer.ScrollChanged="OnStudentListScrollChanged"
                 Background="Transparent"
                 BorderThickness="0"
                 Padding="12,4,12,4"
                 SelectionMode="Single"
                 IsTabStop="False">
            <ListBox.Resources>
                <Style TargetType="ScrollBar" BasedOn="{StaticResource {x:Type ScrollBar}}">
                    <Setter Property="Width" Value="6"/>
                    <Setter Property="MinWidth" Value="6"/>
                </Style>
            </ListBox.Resources>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="Focusable" Value="False"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <components:StudentCardComponent/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Float Butonlar + Yönetim Menüsü -->
        <components:FloatingActionPanel Grid.Row="0" Grid.RowSpan="3" Panel.ZIndex="101"/>

        <!-- Ayarlar Katmanı -->
        <components:SettingsOverlay Grid.RowSpan="3" Panel.ZIndex="150" DataContext="{Binding}"/>

        <!-- Yükleme Katmanı -->
        <components:LoadingOverlay Grid.RowSpan="3" Panel.ZIndex="200"/>

        <!-- Onay Diyaloğu Katmanı -->
        <components:ConfirmDialogOverlay x:Name="ConfirmDialog" Grid.RowSpan="3" Panel.ZIndex="300"/>

        <!-- Güncelleme Notları Katmanı -->
        <components:ReleaseNotesOverlay x:Name="ReleaseNotesOverlay" Grid.RowSpan="3" Panel.ZIndex="350"/>

        <Button x:Name="FloatingButton" 
                Grid.Row="1" Grid.RowSpan="2"
                HorizontalAlignment="Right" VerticalAlignment="Center"
                Margin="0,0,-4,0"
                Width="38" Height="48"
                Padding="0"
                Cursor="Hand"
                Command="{Binding OpenTeamManagementCommand}"
                Panel.ZIndex="100"
                ToolTip="Takım Yönetimi"
                PreviewMouseDown="OnFloatingButtonPreviewMouseDown"
                PreviewMouseMove="OnFloatingButtonPreviewMouseMove"
                PreviewMouseUp="OnFloatingButtonPreviewMouseUp">
            <Button.RenderTransform>
                <TransformGroup>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                    <TranslateTransform x:Name="FloatingButtonTranslate"/>
                </TransformGroup>
            </Button.RenderTransform>
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Opacity" Value="0.4"/>
                    <Setter Property="Background" Value="{DynamicResource BgCardBrush}"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="12,0,0,12" 
                                        BorderBrush="{DynamicResource BorderColorBrush}"
                                        BorderThickness="1,1,0,1">
                                    <ui:SymbolIcon Symbol="People24" FontSize="20" 
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Margin="0,0,4,0"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="1.0"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)" To="1.1" Duration="0:0:0.1" />
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)" To="1.1" Duration="0:0:0.1" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.1" />
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.1" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>

    </Grid>
</ui:FluentWindow>
