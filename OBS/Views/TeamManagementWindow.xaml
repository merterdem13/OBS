<ui:FluentWindow x:Class="OBS.Views.TeamManagementWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:components="clr-namespace:OBS.Views.Components"
    Title="Takım Yönetimi"
    Width="400" Height="750"
    MinWidth="400" MinHeight="750"
    ResizeMode="NoResize"
    WindowStartupLocation="Manual"
    Topmost="{Binding IsTopmost, Mode=TwoWay}"
    Icon="pack://application:,,,/Assets/app.ico"
    ExtendsContentIntoTitleBar="True" WindowBackdropType="None"
    Background="{DynamicResource BgBodyBrush}">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- SATIR 0 — Başlık Çubuğu -->
        <ui:TitleBar Grid.Row="0" ShowMaximize="False">
            <ui:TitleBar.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0,0,0">
                    <Image Width="24" Height="24" Margin="0,0,8,0"
                           VerticalAlignment="Center" Stretch="Uniform"
                           SnapsToDevicePixels="True" UseLayoutRounding="True"
                           RenderOptions.BitmapScalingMode="Fant">
                        <Image.Source>
                            <BitmapImage UriSource="pack://application:,,,/Assets/app.ico" DecodePixelWidth="24" DecodePixelHeight="24" />
                        </Image.Source>
                    </Image>
                    <TextBlock Text="Takım Yönetimi"
                               FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <!-- SATIR 1 — Üst Bar: Takım Oluştur -->
        <Grid x:Name="TopBarGrid" Grid.Row="1" Margin="12,8,12,6" IsVisibleChanged="OnElementIsVisibleChanged">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsEditingTeam}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsCreatingTeam}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <!-- Takım Oluştur Butonu (Tam Genişlik) -->
            <ui:Button Content="Takım Oluştur"
                       Appearance="Primary"
                       Background="{DynamicResource SpecialButtonBgBrush}"
                       Foreground="{DynamicResource SpecialButtonTextBrush}"
                       HorizontalAlignment="Stretch"
                       Padding="12,8"
                       FontWeight="SemiBold"
                       Command="{Binding OpenCreateTeamCommand}">
                <ui:Button.Icon>
                    <ui:SymbolIcon Symbol="Add24"/>
                </ui:Button.Icon>
            </ui:Button>
        </Grid>

        <!-- SATIR 2 — Takım Listesi -->
        <TextBlock Grid.Row="2"
                   Text="Henüz takım oluşturulmadı."
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   FontSize="14" FontWeight="SemiBold"
                   HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Teams.Count}" Value="0"/>
                                <Condition Binding="{Binding IsEditingTeam}" Value="False"/>
                                <Condition Binding="{Binding IsCreatingTeam}" Value="False"/>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible"/>
                        </MultiDataTrigger>
                        <DataTrigger Binding="{Binding IsEditingTeam}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsCreatingTeam}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <ListBox x:Name="TeamsListBox"
                 Grid.Row="2"
                 ItemsSource="{Binding Teams}"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 VirtualizingPanel.ScrollUnit="Pixel"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.CanContentScroll="True"
                 Background="Transparent"
                 BorderThickness="0"
                 Padding="12,4,12,4"
                 SelectionMode="Single"
                 IsTabStop="False"
                 IsVisibleChanged="OnElementIsVisibleChanged">
            <ListBox.Style>
                <Style TargetType="ListBox">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsEditingTeam}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsCreatingTeam}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListBox.Style>
            <ListBox.Resources>
                <Style TargetType="ScrollBar" BasedOn="{StaticResource {x:Type ScrollBar}}">
                    <Setter Property="Width" Value="6"/>
                    <Setter Property="MinWidth" Value="6"/>
                </Style>
            </ListBox.Resources>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="Focusable" Value="False"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <components:TeamCardComponent/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <components:EditTeamComponent x:Name="InlineEditComponent"
                                      Grid.Row="1" Grid.RowSpan="2"
                                      Visibility="{Binding IsEditingTeam, Converter={StaticResource BoolToVis}}"
                                      DataContext="{Binding}"
                                      EditClosed="InlineEditComponent_EditClosed"
                                      IsVisibleChanged="OnElementIsVisibleChanged" />

        <components:CreateTeamComponent x:Name="InlineCreateComponent"
                                        Grid.Row="1" Grid.RowSpan="2"
                                        Visibility="{Binding IsCreatingTeam, Converter={StaticResource BoolToVis}}"
                                        CreateClosed="InlineCreateComponent_CreateClosed"
                                        IsVisibleChanged="OnElementIsVisibleChanged" />

        <Button x:Name="HomeButton" 
                Grid.Row="1" Grid.RowSpan="2"
                HorizontalAlignment="Left" VerticalAlignment="Center"
                Margin="-4,0,0,0"
                Width="38" Height="48"
                Padding="0"
                Cursor="Hand"
                Command="{Binding GoBackToMainCommand}"
                Panel.ZIndex="100"
                ToolTip="Ana Sayfaya Dön"
                PreviewMouseDown="OnHomeButtonPreviewMouseDown"
                PreviewMouseMove="OnHomeButtonPreviewMouseMove"
                PreviewMouseUp="OnHomeButtonPreviewMouseUp">
            <Button.RenderTransform>
                <TransformGroup>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                    <TranslateTransform x:Name="HomeButtonTranslate"/>
                </TransformGroup>
            </Button.RenderTransform>
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Opacity" Value="0.4"/>
                    <Setter Property="Background" Value="{DynamicResource BgCardBrush}"/>
                    <Setter Property="Visibility" Value="Visible"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="0,12,12,0" 
                                        BorderBrush="{DynamicResource BorderColorBrush}"
                                        BorderThickness="0,1,1,1">
                                    <ui:SymbolIcon Symbol="Home24" FontSize="20" 
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Margin="4,0,0,0"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsEditingTeam}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsCreatingTeam}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="1.0"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)" To="1.1" Duration="0:0:0.1" />
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)" To="1.1" Duration="0:0:0.1" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.1" />
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.1" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>
    </Grid>
</ui:FluentWindow>
