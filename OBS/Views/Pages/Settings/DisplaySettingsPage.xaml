<UserControl x:Class="OBS.Views.Pages.Settings.DisplaySettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:converters="clr-namespace:OBS.Converters"
             Background="Transparent">
    
    <UserControl.Resources>
        <converters:StringMatchToBooleanConverter x:Key="StringMatchToBool"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <StackPanel>
            <TextBlock Text="Ekran Ayarları" FontSize="20" FontWeight="Bold" Margin="0,0,0,24" Foreground="{DynamicResource TextPrimaryBrush}"/>
            
            <Border Background="{DynamicResource BgBodyBrush}" CornerRadius="12" Padding="20" BorderBrush="{DynamicResource BorderColorBrush}" BorderThickness="1">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <ui:SymbolIcon Symbol="Color24" FontSize="20" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,8,0"/>
                        <TextBlock Text="Uygulama Teması" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <TextBlock Text="Uygulamanın genel görünümünü değiştirmek için bir tema seçin." 
                               Foreground="{DynamicResource TextSecondaryBrush}" 
                               FontSize="13" TextWrapping="Wrap" Margin="0,0,0,20"/>

                    <WrapPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <RadioButton Content="Aydınlık" 
                                     GroupName="ThemeGroup" 
                                     Margin="0,0,16,12"
                                     Cursor="Hand"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     IsChecked="{Binding CurrentTheme, Converter={StaticResource StringMatchToBool}, ConverterParameter=Light, Mode=OneWay}"
                                     Command="{Binding ChangeThemeCommand}" 
                                     CommandParameter="Light"/>
                        
                        <RadioButton Content="Karanlık" 
                                     GroupName="ThemeGroup" 
                                     Margin="0,0,16,12"
                                     Cursor="Hand"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     IsChecked="{Binding CurrentTheme, Converter={StaticResource StringMatchToBool}, ConverterParameter=Dark, Mode=OneWay}"
                                     Command="{Binding ChangeThemeCommand}" 
                                     CommandParameter="Dark"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
