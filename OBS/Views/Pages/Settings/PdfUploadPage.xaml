<UserControl x:Class="OBS.Views.Pages.Settings.PdfUploadPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <Style TargetType="ScrollBar" BasedOn="{StaticResource {x:Type ScrollBar}}">
            <Setter Property="Width" Value="3"/>
            <Setter Property="Height" Value="3"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="PDF Yükleme" FontSize="20" FontWeight="Bold" Margin="0,0,0,24" Foreground="{DynamicResource TextPrimaryBrush}"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                
                <!-- PDF Yükleme Kartı -->
                <Border Background="{DynamicResource BgCardBrush}" 
                        BorderBrush="{DynamicResource BorderColorBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="20"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <ui:SymbolIcon Symbol="DocumentPdf24" FontSize="20" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,8,0"/>
                            <TextBlock Text="PDF Dosyası Yükle" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <TextBlock Text="Künye defteri, sınıf listesi veya fotoğraf listesi PDF dosyalarını seçerek sisteme aktarır. Birden fazla dosya aynı anda seçilebilir. Dosya türleri otomatik olarak algılanır ve uygun şekilde işlenir." 
                                   Foreground="{DynamicResource TextSecondaryBrush}" 
                                   FontSize="13" TextWrapping="Wrap" Margin="0,0,0,20"/>

                        <WrapPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <ui:Button Content="PDF Yükle" 
                                       Appearance="Primary"
                                       Cursor="Hand"
                                       Margin="0,0,16,12"
                                       Command="{Binding ImportKunyePdfCommand}">
                                <ui:Button.Icon>
                                    <ui:SymbolIcon Symbol="DocumentPdf24"/>
                                </ui:Button.Icon>
                            </ui:Button>
                        </WrapPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
