<UserControl x:Class="OBS.Views.Pages.Settings.SystemSettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Background="Transparent">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Sistem Ayarları" FontSize="20" FontWeight="Bold" Margin="0,0,0,24" Foreground="{DynamicResource TextPrimaryBrush}"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                
                <!-- Sistemi Sıfırla Kartı -->
                <Border Background="{DynamicResource BgBodyBrush}" 
                        CornerRadius="12"
                        Padding="20"
                        Margin="0,0,0,24">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <ui:SymbolIcon Symbol="Warning24" FontSize="20" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,8,0"/>
                            <TextBlock Text="Sistemi Sıfırla" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <TextBlock Text="Uygulamadaki tüm kayıtlı öğrencileri, takımları ve veritabanını temizler. Bu işlem geri alınamaz ve uygulama ilk kurulduğu temiz duruma döner." 
                                   Foreground="{DynamicResource TextSecondaryBrush}" 
                                   FontSize="13" TextWrapping="Wrap" Margin="0,0,0,20"/>

                        <WrapPanel Orientation="Horizontal">
                            <ui:Button Content="Sistemi Sıfırla" 
                                       Appearance="Danger"
                                       Cursor="Hand"
                                       Margin="0,0,16,12"
                                       Command="{Binding ResetSystemCommand}">
                                <ui:Button.Icon>
                                    <ui:SymbolIcon Symbol="Delete24"/>
                                </ui:Button.Icon>
                            </ui:Button>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Güncelleme Kontrol Kartı -->
                <Border Background="{DynamicResource BgBodyBrush}" 
                        CornerRadius="12"
                        Padding="20"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <ui:SymbolIcon Symbol="ArrowSync24" FontSize="20" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,8,0"/>
                            <TextBlock Text="Güncelleme Kontrol Et" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <TextBlock Text="Yeni bir OBS sürümü olup olmadığını kontrol eder. Eğer yeni bir sürüm yayınlanmışsa, indirip sisteminize yüklemenizi sağlar." 
                                   Foreground="{DynamicResource TextSecondaryBrush}" 
                                   FontSize="13" TextWrapping="Wrap" Margin="0,0,0,20"/>

                        <WrapPanel Orientation="Horizontal">
                            <ui:Button Content="Kontrol Et" 
                                       Appearance="Secondary"
                                       Cursor="Hand"
                                       Margin="0,0,16,12"
                                       Command="{Binding CheckForUpdateCommand}">
                                <ui:Button.Icon>
                                    <ui:SymbolIcon Symbol="CloudSync24"/>
                                </ui:Button.Icon>
                            </ui:Button>
                        </WrapPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
