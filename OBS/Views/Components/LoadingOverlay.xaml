<UserControl x:Class="OBS.Views.Components.LoadingOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:converters="clr-namespace:OBS.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <Grid Background="#E6FFFFFF"
          Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <ui:ProgressRing IsIndeterminate="True" Width="48" Height="48"
                             Foreground="{StaticResource AccentBrush}"/>
            <TextBlock Text="İşlem yapılıyor..."
                       FontSize="14" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Margin="0,12,0,4"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <ProgressBar Value="{Binding LoadingProgress}"
                         Width="220" Height="6" Margin="0,4"
                         Foreground="{StaticResource AccentBrush}"/>
            <TextBlock Text="{Binding LoadingProgressText}"
                       FontSize="12" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Foreground="{StaticResource AccentBrush}"/>
        </StackPanel>
    </Grid>
</UserControl>
