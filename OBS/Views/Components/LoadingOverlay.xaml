<UserControl x:Class="OBS.Views.Components.LoadingOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:converters="clr-namespace:OBS.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <Grid Background="{DynamicResource LoadingBgBrush}"
          Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <ui:ProgressRing IsIndeterminate="True" Width="54" Height="54"
                             Foreground="{DynamicResource LoadingAccentBrush}"/>
            <TextBlock Text="İşlem yapılıyor..."
                       FontSize="15" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Margin="0,16,0,6"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <ProgressBar Value="{Binding LoadingProgress}"
                         Width="240" Height="6" Margin="0,4"
                         Foreground="{DynamicResource LoadingAccentBrush}"
                         Background="{DynamicResource BorderColorBrush}"/>
            <TextBlock Text="{Binding LoadingProgressText}"
                       FontSize="13" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource LoadingProgressTextBrush}"/>
        </StackPanel>
    </Grid>
</UserControl>
