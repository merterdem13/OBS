<UserControl x:Class="OBS.Views.Components.ForceUpdateOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Visibility="Collapsed">

    <UserControl.Resources>
        <Storyboard x:Key="FadeInStoryboard">
            <DoubleAnimation Storyboard.TargetName="Backdrop"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetName="DialogCard"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetName="DialogCard"
                             Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                             From="24" To="0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <Grid>
        <!-- Tam ekran, kapatılamaz arka plan -->
        <Border x:Name="Backdrop"
                Background="#CC000000"
                Opacity="0"/>

        <!-- Dialog Kartı -->
        <Border x:Name="DialogCard"
                Opacity="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="400"
                Background="{DynamicResource BgCardBrush}"
                CornerRadius="16"
                Padding="32">

            <Border.Effect>
                <DropShadowEffect BlurRadius="32"
                                  ShadowDepth="8"
                                  Opacity="0.45"
                                  Color="#000000"/>
            </Border.Effect>

            <Border.RenderTransform>
                <TranslateTransform Y="0"/>
            </Border.RenderTransform>

            <StackPanel>
                <!-- İkon -->
                <Border Width="56" Height="56"
                        CornerRadius="28"
                        Background="#15EF4444"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,20">
                    <ui:SymbolIcon Symbol="ArrowSync24"
                                   FontSize="28"
                                   Foreground="#EF4444"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                </Border>

                <!-- Başlık -->
                <TextBlock Text="Zorunlu Güncelleme"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12"/>

                <!-- Mesaj -->
                <TextBlock x:Name="MessageText"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           FontSize="13"
                           LineHeight="20"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,0,0,28"/>

                <!-- İndirme Durumu -->
                <StackPanel x:Name="ProgressPanel">
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="İndiriliyor..."
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Left"/>
                        <TextBlock x:Name="ProgressText"
                                   Text="0%"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                    <ProgressBar x:Name="DownloadBar"
                                 Value="0"
                                 Minimum="0"
                                 Maximum="100"
                                 Height="6"/>
                    <TextBlock Text="İndirme tamamlandığında uygulama otomatik olarak yeniden başlayacak."
                               FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Margin="0,12,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
