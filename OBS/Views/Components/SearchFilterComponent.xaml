<UserControl x:Class="OBS.Views.Components.SearchFilterComponent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:converters="clr-namespace:OBS.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
    </UserControl.Resources>

    <StackPanel Margin="12,8,12,6">

        <!-- Arama / Sınıf Seçme Satırı -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Arama / Sınıf Seçme Barı Konteyneri -->
            <Border Grid.Column="0"
                    Background="{DynamicResource BgCardBrush}"
                    CornerRadius="20"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource BorderColorBrush}"
                    Height="40"
                    VerticalAlignment="Center"
                    Padding="12,0,4,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Arama Modu (IsClassFilterMode = false iken görünür) -->
                    <ui:TextBox Grid.Column="0"
                                PlaceholderText="Öğrenci Ara (Ad, No)..."
                                Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                Margin="0,0,8,0"
                                VerticalContentAlignment="Center"
                                Visibility="{Binding IsClassFilterMode, Converter={StaticResource InverseBoolToVisibility}}">
                        <ui:TextBox.Resources>
                            <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                            <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                            <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
                            <SolidColorBrush x:Key="TextControlFillColorSecondaryBrush" Color="Transparent" />
                            <SolidColorBrush x:Key="TextControlFillColorTertiaryBrush" Color="Transparent" />
                            <SolidColorBrush x:Key="TextControlFillColorTransparentBrush" Color="Transparent" />
                            <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                            <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
                        </ui:TextBox.Resources>
                    </ui:TextBox>

                    <!-- Sınıf Dropdown (IsClassFilterMode = true iken görünür) -->
                    <Grid Grid.Column="0" Margin="0,0,8,0"
                          Visibility="{Binding IsClassFilterMode, Converter={StaticResource BoolToVisibility}}">
                        <ComboBox ItemsSource="{Binding ClassList}"
                                  SelectedItem="{Binding SelectedClass}"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  VerticalContentAlignment="Center"/>

                        <TextBlock Text="Sınıf Seçiniz"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedClass}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <!-- Değiştirme Butonu -->
                    <Button Grid.Column="1"
                            Width="32" Height="32"
                            BorderThickness="0"
                            Background="{DynamicResource SpecialButtonBgBrush}"
                            Foreground="White"
                            Cursor="Hand"
                            Command="{Binding ToggleFilterModeCommand}"
                            ToolTip="Arama / Sınıf Filtresi"
                            RenderTransformOrigin="0.5,0.5">
                        <Button.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </Button.RenderTransform>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource SpecialButtonHoverBrush}"/>
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:0.15"/>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:0.15"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.15"/>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.15"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.ExitActions>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="16">
                                    <ui:SymbolIcon FontSize="18"
                                                   Foreground="{TemplateBinding Foreground}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <ui:SymbolIcon.Style>
                                            <Style TargetType="ui:SymbolIcon">
                                                <Setter Property="Symbol" Value="Filter24"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsClassFilterMode}" Value="True">
                                                        <Setter Property="Symbol" Value="Search24"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ui:SymbolIcon.Style>
                                    </ui:SymbolIcon>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Favoriler Butonu -->
            <Button Grid.Column="1"
                    Width="40" Height="40"
                    VerticalAlignment="Center"
                    Margin="12,0,0,0"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource BorderColorBrush}"
                    Background="{DynamicResource BgCardBrush}"
                    Cursor="Hand"
                    Command="{Binding ToggleFavoriteCommand}"
                    Visibility="{Binding HasFavorites, Converter={StaticResource BoolToVisibility}, FallbackValue=Visible}"
                    RenderTransformOrigin="0.5,0.5">
                <Button.RenderTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Button.RenderTransform>
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="20">
                            <ui:SymbolIcon FontSize="18"
                                           HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ui:SymbolIcon.Style>
                                    <Style TargetType="ui:SymbolIcon">
                                        <Setter Property="Symbol" Value="Star24"/>
                                        <Setter Property="Filled" Value="False"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFavoriteMode}" Value="True">
                                                <Setter Property="Filled" Value="True"/>
                                                <Setter Property="Foreground" Value="#F59E0B"/> <!-- Amber/Yellow -->
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:SymbolIcon.Style>
                            </ui:SymbolIcon>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Ayarlar Butonu -->
            <Button Grid.Column="2"
                    Width="40" Height="40"
                    VerticalAlignment="Center"
                    Margin="8,0,0,0"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource BorderColorBrush}"
                    Background="{DynamicResource BgCardBrush}"
                    Cursor="Hand"
                    Command="{Binding OpenSettingsOverlayCommand}"
                    RenderTransformOrigin="0.5,0.5">
                <Button.RenderTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Button.RenderTransform>
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="20">
                            <ui:SymbolIcon Symbol="Settings24" FontSize="18"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- Filtre Satırı (Boş bırakıldı çünkü favori temizle butonu HomeView'e float olarak taşındı) -->
        <Grid Margin="0,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
        </Grid>

        <!-- Sınıf Eylemleri (sınıf seçilince görünür) -->
        <Grid Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="10*"/>
                <ColumnDefinition Width="11*"/>
                <ColumnDefinition Width="8*"/>
            </Grid.ColumnDefinitions>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Setter Property="Opacity" Value="0"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsClassSelected}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" Duration="0:0:0">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.5">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseIn"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" Duration="0:0:0.5">
                                            <DiscreteObjectKeyFrame KeyTime="0:0:0.5" Value="{x:Static Visibility.Collapsed}"/>
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <ui:Button Grid.Column="0" Content="Sınıf Listesi"
                       Appearance="Primary"
                       MouseOverBackground="{DynamicResource SpecialButtonHoverBrush}"
                       Background="{DynamicResource SpecialButtonBgBrush}"
                       Foreground="{DynamicResource SpecialButtonTextBrush}"
                       Margin="0,0,3,0" Padding="4,6"
                       FontSize="11" FontWeight="SemiBold"
                       HorizontalAlignment="Stretch"
                       Command="{Binding PrintClassListCommand}">
                <ui:Button.Icon>
                    <ui:SymbolIcon Symbol="People24"/>
                </ui:Button.Icon>
            </ui:Button>
            <ui:Button Grid.Column="1" Content="Fotoğraf Listesi"
                       Appearance="Primary"
                       MouseOverBackground="{DynamicResource SpecialButtonHoverBrush}"
                       Background="{DynamicResource SpecialButtonBgBrush}"
                       Foreground="{DynamicResource SpecialButtonTextBrush}"
                       Margin="3,0,3,0" Padding="4,6"
                       FontSize="11" FontWeight="SemiBold"
                       HorizontalAlignment="Stretch"
                       Command="{Binding PrintPhotoListCommand}">
                <ui:Button.Icon>
                    <ui:SymbolIcon Symbol="Camera24"/>
                </ui:Button.Icon>
            </ui:Button>
            <ui:Button Grid.Column="2" Content="Excel"
                       Appearance="Primary"
                       MouseOverBackground="{DynamicResource SpecialButtonHoverBrush}"
                       Background="{DynamicResource SpecialButtonBgBrush}"
                       Foreground="{DynamicResource SpecialButtonTextBrush}"
                       Margin="3,0,0,0" Padding="4,6"
                       FontSize="11" FontWeight="SemiBold"
                       HorizontalAlignment="Stretch"
                       Command="{Binding ExportExcelCommand}">
                <ui:Button.Icon>
                    <ui:SymbolIcon Symbol="DocumentTable24"/>
                </ui:Button.Icon>
            </ui:Button>
        </Grid>
    </StackPanel>
</UserControl>
