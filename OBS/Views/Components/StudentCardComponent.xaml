<UserControl x:Class="OBS.Views.Components.StudentCardComponent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:converters="clr-namespace:OBS.Converters"
             xmlns:helpers="clr-namespace:OBS.Helpers"
             xmlns:local="clr-namespace:OBS.ViewModels">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:PathToImageConverter x:Key="PathToImage"/>
    </UserControl.Resources>

    <Border Background="{DynamicResource BgCardBrush}"
            BorderBrush="{DynamicResource BorderColorBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Margin="0,0,0,8"
            Cursor="Hand"
            helpers:AnimationHelper.IsSlideUpEnabled="True"
            helpers:AnimationHelper.StaggerDelay="{Binding StaggerDelay}"
            helpers:AnimationHelper.IsRemoving="{Binding IsRemoving}">
        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <StackPanel>
            <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="95"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Fotoğraf -->
            <Border Grid.Column="0"
                    CornerRadius="10,0,0,10"
                    ClipToBounds="True"
                    Background="{DynamicResource BgBodyBrush}"
                    ToolTip="Fotoğrafı indirmek için sağ tıklayın"
                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Resmi Kaydet" 
                                  Command="{Binding PlacementTarget.Tag.DownloadImageCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    </ContextMenu>
                </Border.ContextMenu>
                <Image Source="{Binding PhotoPath, Converter={StaticResource PathToImage}}"
                       Stretch="UniformToFill"/>
            </Border>

            <!-- Bilgiler -->
            <Grid Grid.Column="1" Margin="12,8,8,8" Grid.IsSharedSizeScope="True">
                <Grid.Resources>
                    <Style x:Key="SelectValue" TargetType="TextBox">
                        <Setter Property="IsReadOnly" Value="True"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="IsHitTestVisible" Value="True"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                    </Style>
                    <Style x:Key="LabelText" TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="Margin" Value="0,0,4,0"/>
                    </Style>
                </Grid.Resources>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Ad Soyad + Yıldız -->
                <Grid Grid.Row="0" Margin="0,0,0,3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding FullName, Mode=OneWay}"
                             FontWeight="SemiBold"
                             FontSize="14"
                             Style="{StaticResource SelectValue}"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <!-- Not Butonu -->
                        <Button x:Name="btnNote"
                                Padding="2" Width="24" Height="24" Margin="0,0,4,0"
                                ToolTip="Öğrenci Notu"
                                Cursor="Hand"
                                Background="Transparent"
                                BorderThickness="0"
                                Command="{Binding OpenStudentNotesCommand, Source={x:Static local:GlobalState.Instance}}"
                                CommandParameter="{Binding}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <ui:SymbolIcon FontSize="15" RenderTransformOrigin="0.5,0.5">
                                <ui:SymbolIcon.Style>
                                    <Style TargetType="ui:SymbolIcon">
                                        <Setter Property="Symbol" Value="DocumentEdit24"/>
                                        <Setter Property="Filled" Value="False"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasNote}" Value="True">
                                                <Setter Property="Filled" Value="True"/>
                                                <Setter Property="Foreground" Value="{DynamicResource NoteIndicatorBrush}"/> 
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:SymbolIcon.Style>
                            </ui:SymbolIcon>
                        </Button>

                        <!-- Yıldız Butonu -->
                        <Button Padding="2" Width="24" Height="24"
                                ToolTip="{Binding FavoriteTooltip}"
                                Command="{Binding DataContext.ToggleFavoriteItemCommand,
                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                CommandParameter="{Binding}"
                                Cursor="Hand"
                                Background="Transparent"
                                BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <ui:SymbolIcon FontSize="15" RenderTransformOrigin="0.5,0.5">
                                <ui:SymbolIcon.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </ui:SymbolIcon.RenderTransform>
                                <ui:SymbolIcon.Style>
                                    <Style TargetType="ui:SymbolIcon">
                                        <Setter Property="Symbol" Value="Star24"/>
                                        <Setter Property="Filled" Value="False"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                <Setter Property="Filled" Value="True"/>
                                                <Setter Property="Foreground" Value="#F59E0B"/>
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="1" To="1.3" Duration="0:0:0.15" AutoReverse="True"/>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="1" To="1.3" Duration="0:0:0.15" AutoReverse="True"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:SymbolIcon.Style>
                            </ui:SymbolIcon>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Sınıf -->
                <Grid Grid.Row="1" Margin="0,0,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition SharedSizeGroup="LabelCol" Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Sınıf:" Style="{StaticResource LabelText}"/>
                    <TextBox Grid.Column="1" Text="{Binding Class, Mode=OneWay}" Style="{StaticResource SelectValue}"/>
                </Grid>

                <!-- No -->
                <Grid Grid.Row="2" Margin="0,0,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition SharedSizeGroup="LabelCol" Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="NO:" Style="{StaticResource LabelText}"/>
                    <TextBox Grid.Column="1" Text="{Binding StudentNumber, Mode=OneWay}" Style="{StaticResource SelectValue}"/>
                </Grid>

                <!-- TC -->
                <Grid Grid.Row="3" Margin="0,0,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition SharedSizeGroup="LabelCol" Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="TC:" Style="{StaticResource LabelText}"/>
                    <TextBox Grid.Column="1" Text="{Binding TcNo, Mode=OneWay}" Style="{StaticResource SelectValue}"/>
                </Grid>

                <Grid Grid.Row="4" Margin="0,0,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <!-- Doğum Tarihi -->
                        <Grid Margin="0,0,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition SharedSizeGroup="LabelCol" Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Doğum T:" Style="{StaticResource LabelText}"/>
                            <TextBox Grid.Column="1" Text="{Binding BirthDateString, Mode=OneWay}" Style="{StaticResource SelectValue}"/>
                        </Grid>

                        <!-- Veli NO -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition SharedSizeGroup="LabelCol" Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Veli NO:" Style="{StaticResource LabelText}"/>
                            <TextBox Grid.Column="1" Text="{Binding GuardianPhone, Mode=OneWay}" Style="{StaticResource SelectValue}"/>
                        </Grid>
                    </StackPanel>

                    <!-- PDF Butonu (Künye) -->
                    <ui:Button Grid.Column="1"
                               Appearance="Danger"
                               Background="#E53E3E"
                               Foreground="White"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Bottom"
                               Padding="8,4" FontSize="11"
                               ToolTip="Öğrenci Künyesi PDF"
                               Command="{Binding DataContext.ExportStudentPdfCommand,
                                   RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                               CommandParameter="{Binding}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="DocumentPdf24" Foreground="White" FontSize="13" Margin="0,0,4,0"/>
                            <TextBlock Text="Künye" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                    </ui:Button>
                </Grid>
            </Grid>
        </Grid>

        </StackPanel>
    </Border>
</UserControl>
