<UserControl x:Class="OBS.Views.Components.StudentNotesOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Visibility="Collapsed">

    <UserControl.Resources>
        <Storyboard x:Key="FadeInStoryboard">
            <DoubleAnimation Storyboard.TargetName="Backdrop"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.25"/>
            <DoubleAnimation Storyboard.TargetName="DialogCard"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.25"/>
            <DoubleAnimation Storyboard.TargetName="DialogCard"
                             Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                             From="30" To="0" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="FadeOutStoryboard">
            <DoubleAnimation Storyboard.TargetName="Backdrop"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.2"/>
            <DoubleAnimation Storyboard.TargetName="DialogCard"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.2"/>
        </Storyboard>
    </UserControl.Resources>

    <Grid>
        <!-- Yarı saydam arka plan -->
        <Border x:Name="Backdrop"
                Background="#AA000000"
                Opacity="0"
                MouseLeftButtonDown="Backdrop_Click"/>

        <!-- Açılır Dialog Kartı -->
        <Border x:Name="DialogCard"
                Opacity="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="380"
                Background="{DynamicResource BgCardBrush}"
                CornerRadius="12"
                Padding="20">

            <Border.Effect>
                <DropShadowEffect BlurRadius="24"
                                  ShadowDepth="6"
                                  Opacity="0.35"
                                  Color="#000000"/>
            </Border.Effect>

            <Border.RenderTransform>
                <TranslateTransform Y="0"/>
            </Border.RenderTransform>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Başlık Kısmı -->
                <StackPanel Grid.Row="0" Margin="0,0,0,16">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <ui:SymbolIcon Symbol="DocumentEdit24" FontSize="22" Foreground="{DynamicResource NoteIndicatorBrush}" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding SelectedStudentForNotes.FullName}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <!-- Kapat Butonu -->
                        <ui:Button Click="CloseButton_Click" HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" Padding="4">
                            <ui:SymbolIcon Symbol="Dismiss24" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="16"/>
                        </ui:Button>
                    </Grid>
                </StackPanel>

                <!-- Notların Listelendiği Scroll Alanı -->
                <ScrollViewer Grid.Row="1" MaxHeight="350" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16" Padding="0,0,8,0">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource {x:Type ScrollBar}}">
                            <Setter Property="Width" Value="4"/>
                            <Setter Property="MinWidth" Value="4"/>
                        </Style>
                    </ScrollViewer.Resources>
                    <ItemsControl ItemsSource="{Binding SelectedStudentForNotes.Notes}">
                        <!-- Liste Boşken Görünecek Metin (Notes.Count == 0 ise) -->
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedStudentForNotes.Notes.Count}" Value="0">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate>
                                                    <TextBlock Text="Bu öğrenciye henüz hiç not bırakılmamış..."
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               FontStyle="Italic"
                                                               HorizontalAlignment="Center"
                                                               Margin="0,20,0,20"/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource BgBodyBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                    <Border.RenderTransform>
                                        <TranslateTransform Y="0"/>
                                    </Border.RenderTransform>
                                    <Border.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.4">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Border.Triggers>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">
                                            <!-- Zaman Çizelgesi Detayı -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <ui:SymbolIcon Symbol="Clock20" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                                                <TextBlock Text="{Binding CreatedAt, StringFormat='dd MMM yyyy HH:mm'}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding NoteText}" TextWrapping="Wrap" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" LineHeight="18"/>
                                        </StackPanel>
                                        <ui:Button Grid.Column="1" Click="BtnDeleteNote_Click" 
                                                   Background="Transparent" BorderThickness="0" Padding="4" VerticalAlignment="Top" ToolTip="Notu Sil">
                                            <ui:SymbolIcon Symbol="Delete24" Foreground="#E53E3E" FontSize="14"/>
                                        </ui:Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Footer (Yeni Not Yazma Alanı) -->
                <Border Grid.Row="2" 
                        Background="{DynamicResource BgBodyBrush}" 
                        CornerRadius="10" 
                        Padding="2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <ui:TextBox x:Name="NoteInputBox" Grid.Column="0" 
                                    Text="{Binding SelectedStudentForNotes.NewNoteText, UpdateSourceTrigger=PropertyChanged}" 
                                    TextWrapping="Wrap" AcceptsReturn="True" MinHeight="34" MaxHeight="80" Padding="10,6"
                                    VerticalContentAlignment="Top" VerticalAlignment="Stretch"
                                    Background="Transparent" BorderThickness="0"
                                    PlaceholderText="Yeni not yazın..">
                            <ui:TextBox.Resources>
                                <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                                <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                                <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
                            </ui:TextBox.Resources>
                        </ui:TextBox>
                        
                        <ui:Button Grid.Column="1" Click="BtnSaveNote_Click" 
                                   MouseOverBackground="{DynamicResource LoadingAccentBrush}"
                                   Background="{DynamicResource NoteIndicatorBrush}" 
                                   Foreground="White" 
                                   Width="34" Height="34" Padding="0"
                                   VerticalAlignment="Bottom" BorderThickness="0" ToolTip="Notu Kaydet">
                             <ui:SymbolIcon Symbol="Send24" Foreground="White" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2,0,0,0"/>
                        </ui:Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
