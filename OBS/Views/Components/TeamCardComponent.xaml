<UserControl x:Class="OBS.Views.Components.TeamCardComponent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             MouseLeave="OnMouseLeave">

    <Border Background="{DynamicResource BgCardBrush}"
            BorderBrush="{DynamicResource BorderColorBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Margin="0,0,0,8"
            Cursor="Hand"
            Opacity="0">
        <Border.InputBindings>
            <MouseBinding MouseAction="LeftClick"
                          Command="{Binding DataContext.OpenTeamDetailCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                          CommandParameter="{Binding}"/>
        </Border.InputBindings>
        <Border.RenderTransform>
            <TranslateTransform Y="20"/>
        </Border.RenderTransform>
        <Border.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.3">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>
        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                    </Trigger>
                    <DataTrigger Binding="{Binding IsRemoving}" Value="True">
                        <DataTrigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.3"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="-50" Duration="0:0:0.3">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseIn"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </DataTrigger.EnterActions>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid Margin="12,10,12,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Kategori İkonu -->
            <Border Grid.Column="0"
                    Background="{DynamicResource BgBodyBrush}"
                    CornerRadius="8"
                    Width="48" Height="48"
                    VerticalAlignment="Center"
                    Margin="0,0,12,0">
                <TextBlock Text="{Binding CategoryIcon}"
                           FontSize="24"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

            <!-- Takım Bilgileri -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="{Binding TeamName}"
                           FontSize="14" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <TextBlock Text="{Binding Category}"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Text="  •  "
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding MemberCountText}"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>

            <!-- Excel + Düzenle + Sil Butonları -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <ui:Button Appearance="Secondary"
                           Padding="6,4"
                           Margin="0,0,4,0"
                           ToolTip="Excel'e Aktar"
                           Command="{Binding DataContext.ExportTeamExcelCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                           CommandParameter="{Binding}">
                    <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="16"/>
                </ui:Button>

                <ui:Button Appearance="Secondary"
                           Padding="6,4"
                           Margin="0,0,4,0"
                           ToolTip="Takımı Düzenle"
                           Command="{Binding DataContext.EditTeamCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                           CommandParameter="{Binding}">
                    <ui:SymbolIcon Symbol="Edit24" FontSize="16"/>
                </ui:Button>

                <ui:Button ToolTip="Takımı Sil"
                           ClipToBounds="True"
                           Command="{Binding DataContext.DeleteTeamCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                           CommandParameter="{Binding}">
                    <ui:Button.Style>
                        <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                            <Setter Property="Appearance" Value="Secondary"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Width" Value="32"/>
                            <Setter Property="Height" Value="28"/>
                            <Setter Property="Content">
                                <Setter.Value>
                                    <ui:SymbolIcon Symbol="Delete24" FontSize="16"/>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDeleteConfirming}" Value="True">
                                    <Setter Property="Appearance" Value="Danger"/>
                                    <Setter Property="Content" Value="Emin misiniz?"/>
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Width" From="32" To="105" Duration="0:0:0.2">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Width" From="105" To="32" Duration="0:0:0.2">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseIn"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
