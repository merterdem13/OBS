<UserControl x:Class="OBS.Views.Components.ReleaseNotesOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Visibility="Collapsed">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <Storyboard x:Key="FadeInStoryboard">
            <DoubleAnimation Storyboard.TargetName="Backdrop"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.25"/>
            <DoubleAnimation Storyboard.TargetName="DialogCard"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.25"/>
            <DoubleAnimation Storyboard.TargetName="DialogCard"
                             Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                             From="30" To="0" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="FadeOutStoryboard">
            <DoubleAnimation Storyboard.TargetName="Backdrop"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.2"/>
            <DoubleAnimation Storyboard.TargetName="DialogCard"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.2"/>
        </Storyboard>
    </UserControl.Resources>

    <Grid>
        <!-- Yarı saydam arka plan -->
        <Border x:Name="Backdrop"
                Background="#99000000"
                Opacity="0"
                MouseLeftButtonDown="Backdrop_Click"/>

        <!-- Dialog Kartı -->
        <Border x:Name="DialogCard"
                Opacity="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="360"
                Background="{DynamicResource BgCardBrush}"
                CornerRadius="12"
                Padding="24">

            <Border.Effect>
                <DropShadowEffect BlurRadius="24"
                                  ShadowDepth="6"
                                  Opacity="0.35"
                                  Color="#000000"/>
            </Border.Effect>

            <Border.RenderTransform>
                <TranslateTransform Y="0"/>
            </Border.RenderTransform>

            <StackPanel>
                <!-- Header Icon & Title -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                    <ui:SymbolIcon Symbol="Megaphone28" FontSize="28" Foreground="{StaticResource BtnOrangeBrush}" Margin="0,0,10,0" />
                    <TextBlock Text="Yeni Sürümde Neler Var?" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                    <TextBlock Text="Versiyon " FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding Version}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource BtnOrangeBrush}" />
                    <TextBlock Text=" • " FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding Date}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" />
                </StackPanel>

                <!-- Critical Warning Section (Optional) -->
                <Border Background="#15EF4444" BorderBrush="#EF4444" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,16"
                        Visibility="{Binding HasCriticalWarning, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Warning24" FontSize="20" Foreground="#EF4444" Margin="0,0,12,0" VerticalAlignment="Top"/>
                        <TextBlock Text="{Binding CriticalWarning}" TextWrapping="Wrap" FontSize="13" Foreground="#EF4444" FontWeight="SemiBold" LineHeight="18" Width="270" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Features List -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="180" Margin="0,0,0,24">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource {x:Type ScrollBar}}">
                            <Setter Property="Width" Value="6"/>
                            <Setter Property="MinWidth" Value="6"/>
                        </Style>
                    </ScrollViewer.Resources>
                    <ItemsControl ItemsSource="{Binding Features}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
                                    <ui:SymbolIcon Symbol="Sparkle24" FontSize="16" Foreground="{StaticResource BtnOrangeBrush}" Margin="0,2,8,0" VerticalAlignment="Top"/>
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="13" Width="280" LineHeight="18" Foreground="{DynamicResource TextSecondaryBrush}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Footer Button -->
                <Button Content="Harika, Anladım!" 
                        Style="{StaticResource ActionBtnStyle}"
                        Background="{StaticResource BtnBlueBrush}"
                        Foreground="#FFFFFF"
                        HorizontalAlignment="Stretch" 
                        Height="40" 
                        FontSize="14" FontWeight="Medium" 
                        Click="CloseButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
