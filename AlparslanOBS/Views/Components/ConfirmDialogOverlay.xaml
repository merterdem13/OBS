<UserControl x:Class="AlparslanOBS.Views.Components.ConfirmDialogOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Visibility="Collapsed">

    <UserControl.Resources>
        <Storyboard x:Key="FadeInStoryboard">
            <DoubleAnimation Storyboard.TargetName="Backdrop"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.25"/>
            <DoubleAnimation Storyboard.TargetName="DialogCard"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.25"/>
            <DoubleAnimation Storyboard.TargetName="DialogCard"
                             Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                             From="30" To="0" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="FadeOutStoryboard">
            <DoubleAnimation Storyboard.TargetName="Backdrop"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.2"/>
            <DoubleAnimation Storyboard.TargetName="DialogCard"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.2"/>
        </Storyboard>
    </UserControl.Resources>

    <Grid>
        <!-- Yarı saydam arka plan -->
        <Border x:Name="Backdrop"
                Background="#99000000"
                Opacity="0"
                MouseLeftButtonDown="Backdrop_Click"/>

        <!-- Dialog Kartı -->
        <Border x:Name="DialogCard"
                Opacity="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="340"
                Background="{StaticResource BgCardBrush}"
                CornerRadius="12"
                Padding="24">

            <Border.Effect>
                <DropShadowEffect BlurRadius="24"
                                  ShadowDepth="6"
                                  Opacity="0.35"
                                  Color="#000000"/>
            </Border.Effect>

            <Border.RenderTransform>
                <TranslateTransform Y="0"/>
            </Border.RenderTransform>

            <StackPanel>
                <!-- İkon -->
                <ui:SymbolIcon x:Name="DialogIcon"
                               Symbol="Warning24"
                               FontSize="40"
                               Foreground="{StaticResource BtnOrangeBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>

                <!-- Başlık -->
                <TextBlock x:Name="DialogTitle"
                           Text="Onay"
                           FontSize="18" FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="0,0,0,8"/>

                <!-- Mesaj -->
                <TextBlock x:Name="DialogMessage"
                           TextWrapping="Wrap"
                           FontSize="13"
                           TextAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           LineHeight="20"
                           Margin="0,0,0,20"/>

                <!-- Butonlar -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,4,0,0">
                    <Button x:Name="CancelButton"
                            Content="Vazgeç"
                            Style="{StaticResource ActionBtnStyle}"
                            Background="{StaticResource BorderColorBrush}"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Width="120" Height="38"
                            FontSize="13"
                            Margin="0,0,8,0"
                            Click="CancelButton_Click"/>

                    <Button x:Name="ConfirmButton"
                            Content="Evet"
                            Style="{StaticResource ActionBtnRed}"
                            Width="140" Height="38"
                            FontSize="13"
                            Click="ConfirmButton_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
