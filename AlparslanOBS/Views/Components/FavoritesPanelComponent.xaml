<UserControl x:Class="AlparslanOBS.Views.Components.FavoritesPanelComponent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:AlparslanOBS.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="320">
    
    <!--
        FAVORİLER PANELİ (Ayrı Modül)
        İSTEM METNİ GEREĞİ:
        - Pozisyon: Sol alt köşe
        - Fade in/out animasyonu
        - Parıldayan görsel efekt
        - Favoriye eklenince otomatik çıkar
        - Basınca açılır/kapanır
        - Toplu silme özelliği
    -->
    
    <UserControl.Resources>
        <!-- Converters -->
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        
        <!-- Fade In Animasyonu -->
        <Storyboard x:Key="FadeInStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                           From="0" To="1" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                           From="20" To="0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Parıldama Animasyonu (Favoriye ekleme anında) -->
        <Storyboard x:Key="SparkleStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                           From="1" To="1.05" Duration="0:0:0.15" AutoReverse="True" RepeatBehavior="2x"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                           From="1" To="1.05" Duration="0:0:0.15" AutoReverse="True" RepeatBehavior="2x"/>
            <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                          From="#F39C12" To="#E67E22" Duration="0:0:0.3" AutoReverse="True" RepeatBehavior="2x"/>
        </Storyboard>
    </UserControl.Resources>

    <Grid>
        <!-- Ana Container (Animasyonlu) -->
        <Border x:Name="FavoritesPanelBorder"
                Background="White"
                BorderBrush="#F39C12"
                BorderThickness="2"
                CornerRadius="8"
                Padding="10"
                MaxHeight="400"
                MinWidth="300"
                MaxWidth="320"
                Opacity="0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" 
                                ShadowDepth="3" 
                                Opacity="0.4"
                                Color="#F39C12"/>
            </Border.Effect>
            <Border.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="SparkleScale" ScaleX="1" ScaleY="1" 
                                  CenterX="150" CenterY="200"/>
                    <TranslateTransform x:Name="SlideTransform" Y="20"/>
                </TransformGroup>
            </Border.RenderTransform>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Header -->
                    <RowDefinition Height="*"/>     <!-- Favori Listesi -->
                    <RowDefinition Height="Auto"/>  <!-- Footer -->
                </Grid.RowDefinitions>

                <!-- Header (Başlık + Kapat Butonu) -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Yıldız İkonu -->
                    <TextBlock Grid.Column="0"
                             Text="⭐" 
                             FontSize="20"
                             VerticalAlignment="Center"
                             Margin="0,0,8,0"/>

                    <!-- Başlık + Sayı -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="FAVORİLERİM" 
                                 FontWeight="Bold" 
                                 FontSize="14"
                                 Foreground="#2C3E50"/>
                        <TextBlock FontSize="10" 
                                 Foreground="#7F8C8D"
                                 Margin="0,2,0,0">
                            <Run Text="{Binding FavoriteCount, Mode=OneWay}"/>
                            <Run Text=" öğrenci"/>
                        </TextBlock>
                    </StackPanel>

                    <!-- Kapat Butonu -->
                    <Button Grid.Column="2"
                            Content="✕" 
                            Width="24" 
                            Height="24"
                            Background="Transparent"
                            BorderThickness="0"
                            FontSize="16"
                            Foreground="#7F8C8D"
                            Cursor="Hand"
                            Click="CloseButton_Click"
                            ToolTip="Kapat">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#ECF0F1"/>
                                        <Setter Property="Foreground" Value="#E74C3C"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <!-- Favori Listesi (ScrollViewer) -->
                <ScrollViewer Grid.Row="1" 
                            VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding FavoriteStudents}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Mini Öğrenci Kartı -->
                                <Border Background="#F8F9FA"
                                      BorderBrush="#BDC3C7"
                                      BorderThickness="1"
                                      CornerRadius="4"
                                      Margin="0,0,0,5"
                                      Padding="6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Fotoğraf (Mini) -->
                                        <Border Grid.Column="0"
                                              Width="40"
                                              Height="50"
                                              CornerRadius="3"
                                              Background="#ECF0F1"
                                              Margin="0,0,8,0">
                                            <Image Source="{Binding PhotoPath}" 
                                                 Stretch="UniformToFill"/>
                                        </Border>

                                        <!-- Bilgiler -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding FullName}" 
                                                     FontWeight="Bold" 
                                                     FontSize="11"
                                                     Foreground="#2C3E50"
                                                     TextTrimming="CharacterEllipsis"/>
                                            <TextBlock FontSize="9" Foreground="#7F8C8D" Margin="0,2,0,0">
                                                <Run Text="{Binding Class}"/>
                                                <Run Text=" - "/>
                                                <Run Text="{Binding StudentNumber}"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Çıkar Butonu -->
                                        <Button Grid.Column="2"
                                              Content="×"
                                              Width="20"
                                              Height="20"
                                              Background="#E74C3C"
                                              Foreground="White"
                                              BorderThickness="0"
                                              FontSize="14"
                                              FontWeight="Bold"
                                              Cursor="Hand"
                                              Click="RemoveFavorite_Click"
                                              Tag="{Binding}"
                                              ToolTip="Favoriden çıkar">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                          CornerRadius="10"
                                                          Padding="0">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="#E74C3C"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#C0392B"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Footer (Toplu Silme) -->
                <Button Grid.Row="2"
                      Content="Tümünü Temizle"
                      Height="28"
                      Background="#E74C3C"
                      Foreground="White"
                      BorderThickness="0"
                      FontSize="11"
                      FontWeight="SemiBold"
                      Cursor="Hand"
                      Click="ClearAll_Click"
                      Margin="0,10,0,0"
                      Visibility="{Binding HasFavorites, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                  CornerRadius="4"
                                  Padding="10,5">
                                <ContentPresenter HorizontalAlignment="Center"
                                                VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#E74C3C"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#C0392B"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
